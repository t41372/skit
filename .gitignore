
reference

# Python
__pycache__/
*.py[cod]
.venv/
dist/
build/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Claude Code session-local state (worktrees, task metadata) — transient agent
# artifacts, never sources; ruff/ty skip gitignored trees, so this also keeps the
# pre-commit gates from tripping over another agent's in-flight worktree.
.claude/

# Test / coverage artifacts
.coverage
.coverage.*
coverage.xml
htmlcov/
mutants/
.mutmut-cache
.mutmut-results.txt

# Benchmark pipeline artifacts (results are CI artifacts, never committed)
.bench/

# Environment variables
.env*.local

# OS
.DS_Store

# Demo videos are uploaded to GitHub user-attachments, not hotlinked from the
# repo like the PNGs — keeping them out of git stops history from ballooning.
docs/assets/demo-*.mp4
