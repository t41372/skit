msgid "Type"
msgstr "类型"

#: src/skit/cli.py:700
msgid "Default"
msgstr "默认值"

#: src/skit/cli.py:701 src/skit/cli.py:808 src/skit/tui.py:116
#: src/skit/tui.py:187
msgid "Secret"
