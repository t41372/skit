msgstr "%(name)s 尚未选择执行器。请带上 --runner NAME,或固定一个:skit params %(name)s --runner NAME"

#: src/skit/cli.py:1838 src/skit/cli.py:2006 src/skit/cli.py:2974
#: src/skit/langs/launch.py:513
#, python-format
