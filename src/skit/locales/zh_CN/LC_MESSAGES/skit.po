msgstr "列出所有已登记的条目。"

#: src/skit/cli.py:2245 src/skit/cli.py:2449 src/skit/cli.py:3218
#: src/skit/cli.py:3569 src/skit/cli.py:4848 src/skit/cli.py:5075
#: src/skit/cli.py:5419
msgid "Output as JSON"
msgstr "以 JSON 输出"

#: src/skit/cli.py:2268
