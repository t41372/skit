msgstr "--raw 会原样运行脚本;--set、--preset、--save-preset 都不适用。"

#: src/skit/cli.py:1940
#, python-format
msgid "--raw only applies to kinds skit injects into; a %(kind)s entry's parameters are its interface and always apply."
msgstr "--raw 只适用于 skit 会注入的种类；%(kind)s 条目的参数就是它的界面，始终生效。"

#: src/skit/cli.py:1963
msgid "Raw mode: skipping the parameter form and injection."
msgstr "raw 模式:已跳过参数表单与注入。"

