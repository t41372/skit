#: src/skit/analysis.py:116
#, python-format
msgid "The parameter definitions for %(name)s have drifted from the script:"
msgstr "%(name)s 的参数定义与脚本内容已漂移:"

#: src/skit/analysis.py:125
#, python-brace-format, python-format
msgid "%(name)s is no longer read from the environment (its ${...:-default} was removed or overridden by a plain assignment) — your value would be silently ignored. Re-add or resync."
msgstr "%(name)s 不再从环境变量读取(其 ${...:-default} 已被删除,或被普通赋值覆盖)——你设置的值会被悄悄忽略。请重新添加或执行 resync。"

#: src/skit/analysis.py:135
#, python-format
msgid "%(name)s: injection target no longer exists (dropped from this run's form)"
msgstr "%(name)s:找不到注入目标(已从本次表单剔除)"

#: src/skit/analysis.py:143
#, python-format
msgid "%(name)s: type changed from %(old)s to %(new)s in the source (still injected — double-check the value)"
msgstr "%(name)s:源码中的类型已从 %(old)s 变为 %(new)s(仍会注入,请确认值)"

#: src/skit/analysis.py:151
#, python-format
msgid "%(name)s: its prompt no longer matches a unique input() call; falling back to position (still injected — double-check this lands on the right question, especially if it's a secret)"
msgstr "%(name)s:其提示文字已无法对应到唯一的 input() 调用;改以位置对应(仍会注入——请再次确认其对应到正确的问题,尤其是机密参数)"

#: src/skit/analysis.py:159
msgid "To refresh the definitions, re-run `skit add` or edit the [tool.skit] block."
msgstr "要更新定义,请重新运行 `skit add` 或手改 [tool.skit] 区块。"

#: src/skit/analysis.py:173
#, python-format
msgid "%(name)s isn't a managed parameter; skipped."
msgstr "%(name)s 不是受管理的参数;已跳过。"

#: src/skit/analysis.py:174
#, python-format
msgid "Dropped %(name)s: it no longer exists in the script."
msgstr "已剔除 %(name)s:脚本中已找不到。"

#: src/skit/analysis.py:175
#, python-format
msgid "%(name)s is already managed; skipped."
msgstr "%(name)s 已在管理中;已跳过。"

#: src/skit/analysis.py:177
#, python-format
msgid "%(name)s isn't a detectable parameter in the current script; skipped."
msgstr "%(name)s 在当前脚本中检测不到;已跳过。"

#: src/skit/analysis.py:180
msgid "Could not parse the script (syntax error); resync skipped. Parameter definitions are unchanged."
msgstr "无法解析脚本(语法错误);已跳过重新同步。参数定义保持不变。"

#: src/skit/analysis.py:184
#, python-format
msgid "%(name)s: re-anchored to its current position after its prompt stopped matching uniquely; double-check the prompt/secret assignment is still correct."
msgstr "%(name)s:因提示文字无法唯一对应,已重新锚定到其当前位置;请再次确认提示文字/机密设置仍然正确。"

#: src/skit/cli.py:63
msgid "skit — a script launcher and parameter manager. Run it without a subcommand to open the main menu."
msgstr "skit — 脚本启动器 + 参数管家。不带子命令运行即进入主菜单。"

#: src/skit/cli.py:120
msgid "Script name or slug"
msgstr "脚本名称或 slug"

#: src/skit/cli.py:127
msgid "Show version"
msgstr "显示版本"

#: src/skit/cli.py:159
#, python-format
msgid "The script declares its own dependencies (PEP 723): %(deps)s"
msgstr "脚本已用 PEP 723 语法声明依赖：%(deps)s"

#: src/skit/cli.py:171 src/skit/cli.py:210
msgid "Dependencies to install (Enter to accept, edit the list, or '-' for none)"
msgstr "要安装的依赖(Enter 采用,可自行编辑,或输入 - 表示不需要)"

#: src/skit/cli.py:180
msgid "Python version (leave empty for automatic)"
msgstr "Python 版本(留空 = 自动)"

#: src/skit/cli.py:236
msgid "Reference-mode entries take no managed dependencies — they run from their own project. Add it as a copy, or drop --dep."
msgstr "reference 模式条目不受理依赖管理——它从自己的项目运行。以复制模式加入，或去掉 --dep。"

#: src/skit/cli.py:239
#, python-format
msgid "%(kind)s entries don't take package dependencies — drop --dep."
msgstr "%(kind)s 条目不接受依赖包——去掉 --dep。"

#: src/skit/cli.py:246 src/skit/store.py:482
#, python-format
msgid "A Python constraint doesn't apply to %(kind)s scripts."
msgstr "Python 约束不适用于 %(kind)s 脚本。"

#: src/skit/cli.py:258 src/skit/cli.py:457
msgid "Name in skit"
msgstr "在 skit 里的名称"

#: src/skit/cli.py:261
msgid "Description (optional)"
msgstr "描述(可留空)"

#: src/skit/cli.py:270 src/skit/store.py:208 src/skit/store.py:309
#: src/skit/store.py:336 src/skit/tui_add.py:150
#, python-format
msgid "File not found: %(path)s"
msgstr "找不到文件：%(path)s"

#: src/skit/cli.py:299
msgid " (secret)"
msgstr " (机密)"

#: src/skit/cli.py:303
#, python-format
msgid "%(num)s. %(name)s (%(type)s) = %(value)s%(secret)s"
msgstr "%(num)s. %(name)s(%(type)s)= %(value)s%(secret)s"

#: src/skit/cli.py:315
#, python-format
msgid "%(num)s. input() #%(ordinal)s: %(prompt)s%(secret)s"
msgstr "%(num)s. input() 第 %(ordinal)s 个:%(prompt)s%(secret)s"

#: src/skit/cli.py:320
msgid "⚠ looks like a loop accumulator — probably not a parameter"
msgstr "⚠ 看起来是循环的累加变量，多半不是参数"

#: src/skit/cli.py:330 src/skit/tui_add.py:385
msgid "This script reads command-line arguments; the run form has an extra-arguments field for them."
msgstr "这个脚本会吃命令行参数；运行表单里有「额外参数」栏可以填。"

#: src/skit/cli.py:339
#, python-format
msgid "💡 %(names)s are written directly inside the code, so skit can't turn them into form fields. To manage one, first give it a name at the top of the script, e.g. OUTPUT = '…' (skit edit %(script)s)."
msgstr "💡 %(names)s 直接写在代码里，skit 没法把它们变成表单字段。想管理其中一个，先在脚本开头给它取个名字，例如 OUTPUT = '…'（skit edit %(script)s）。"

#: src/skit/cli.py:361 src/skit/tui_add.py:339
#, python-format
msgid "✓ skit read this script's own arguments (%(count)s fields). Running it opens a form — nothing to memorize."
msgstr "✓ skit 看懂了这个脚本自己的参数（共 %(count)s 项）。运行时会打开表单——不用背任何命令。"

#: src/skit/cli.py:369 src/skit/tui_add.py:347
#, python-format
msgid "This script parses its own arguments (%(names)s); skit couldn't model them statically, so the run form offers a passthrough-arguments field."
msgstr "这个脚本自己解析参数（%(names)s）；skit 无法静态读懂它们，运行表单会提供「额外参数（原样传给脚本）」栏。"

#: src/skit/cli.py:380
#, python-format
msgid "Found %(count)s parameter candidate (constants / input() calls):"
msgid_plural "Found %(count)s parameter candidates (constants / input() calls):"
msgstr[0] "找到 %(count)s 个候选参数(写死的常量 / input() 调用):"

#: src/skit/cli.py:389
msgid "Which ones should skit manage? (e.g. 1,3 / all / none)"
msgstr "哪些交给 skit 管理?(编号如 1,3 / all / none)"

#: src/skit/cli.py:429
msgid "Reference mode never touches the original file, so parameter setup was skipped."
msgstr "reference 模式绝不改动原文件;跳过参数设置。"

#: src/skit/cli.py:453
msgid "Writing a new script in an editor needs an interactive terminal."
msgstr "用编辑器新建脚本需要交互式终端。"

#: src/skit/cli.py:459 src/skit/store.py:563 src/skit/tui_add.py:175
msgid "A name is required."
msgstr "必须提供名称。"

#: src/skit/cli.py:466
msgid "Opening your editor…"
msgstr "正在打开编辑器…"

#: src/skit/cli.py:470
msgid "Nothing was written, so no script was added."
msgstr "没有写入任何内容,因此没有加入脚本。"

#: src/skit/cli.py:495
msgid "Reading the script from stdin needs an explicit --name."
msgstr "从 stdin 读脚本必须用 --name 指定名称。"

#: src/skit/cli.py:501
msgid "Nothing arrived on stdin, so there is nothing to add."
msgstr "stdin 没有收到任何内容，没有东西可添加。"

#: src/skit/cli.py:546
#, python-format
msgid "Unknown kind: %(kind)s. Choose from: %(kinds)s"
msgstr "未知类型：%(kind)s。可选：%(kinds)s"

#: src/skit/cli.py:552
msgid "Add a script, executable, or command to skit."
msgstr "把脚本、可执行文件或命令加入 skit。"

#: src/skit/cli.py:554
#, python-brace-format
msgid "Examples:  skit add tools/resize.py  ·  skit add --cmd 'ffmpeg -i {input}' -n convert  ·  pbpaste | skit add - -n clip"
msgstr "例：skit add tools/resize.py · skit add --cmd 'ffmpeg -i {input}' -n convert · pbpaste | skit add - -n clip"

#: src/skit/cli.py:559
msgid "Path to a script or executable, or '-' to read a script from stdin"
msgstr "脚本或可执行文件路径；「-」表示从 stdin 读脚本"

#: src/skit/cli.py:562
msgid "Name / alias (defaults to the file name)"
msgstr "名称 / alias(默认用文件名)"

#: src/skit/cli.py:568
msgid "Description (defaults to the first line of the docstring)"
msgstr "描述(默认取 docstring 首行)"

#: src/skit/cli.py:571
msgid "Write a brand-new script in your editor, then add it"
msgstr "在编辑器里新写一支脚本,再加入 skit"

#: src/skit/cli.py:576
msgid "Reference mode: link to the original file instead of copying it"
msgstr "reference 模式:不复制,链接原文件"

#: src/skit/cli.py:581
msgid "Force the executable kind (normally inferred from the file itself)"
msgstr "强制当作可执行文件（一般会自动判断）"

#: src/skit/cli.py:586
msgid "Force the language kind (e.g. shell, js) for an extensionless file"
msgstr "强制指定语言类型（如 shell、js），用于没有扩展名的文件"

#: src/skit/cli.py:589
#, python-brace-format
msgid "Register a command template, e.g. --cmd 'ffmpeg -i {input}'"
msgstr "登记命令模板,如 --cmd 'ffmpeg -i {input}'"

#: src/skit/cli.py:594
msgid "A dependency (repeat for more; skips the interactive question)"
msgstr "一项依赖（可重复；会跳过交互询问）"

#: src/skit/cli.py:597 src/skit/cli.py:2206
msgid "Python version constraint, e.g. \">=3.11\""
msgstr "Python 版本约束,如 \">=3.11\""

#: src/skit/cli.py:600
msgid "Never prompt; accept the detected suggestions"
msgstr "从不询问;直接采用检测到的建议"

#: src/skit/cli.py:608
msgid "--ref needs an existing file to reference — a script written in the editor or read from stdin has none."
msgstr "--ref 需要一个已存在的文件可供引用——在编辑器里写的或从 stdin 读入的脚本没有原始文件。"

#: src/skit/cli.py:614
msgid "Use --edit to write a new script, or pass a path to add an existing one — not both."
msgstr "用 --edit 新写脚本,或传入路径加入现有文件,两者不能同时使用。"

#: src/skit/cli.py:628
msgid "A --cmd entry needs a --name"
msgstr "--cmd 条目必须指定 --name"

#: src/skit/cli.py:635
#, python-format
msgid "Detected parameters: %(names)s (the run form asks for them; your last values are remembered)"
msgstr "检测到参数：%(names)s（运行表单会询问；会记住你上次的值）"

#: src/skit/cli.py:642
msgid "Provide a script path, or use --cmd to register a command template"
msgstr "请提供脚本路径,或用 --cmd 登记命令模板"

#: src/skit/cli.py:651
msgid "Use --kind or --exe, not both."
msgstr "--kind 与 --exe 只能择一。"

#: src/skit/cli.py:661 src/skit/tui_add.py:134
#, python-format
msgid "%(file)s isn't a script or an executable — pass --exe for a program, or --cmd for a command template."
msgstr "%(file)s 不是脚本也不是可执行文件——程序请加 --exe，命令模板请用 --cmd。"

#: src/skit/cli.py:692
#, python-format
msgid "Can't read %(path)s: %(error)s"
msgstr "无法读取 %(path)s:%(error)s"

#: src/skit/cli.py:715
msgid "Cancelled — nothing was added."
msgstr "已取消——没有添加任何东西。"

#: src/skit/cli.py:740
#, python-format
msgid "(%(mode)s mode)"
msgstr "(%(mode)s 模式)"

#: src/skit/cli.py:745
#, python-format
msgid "Added: %(name)s"
msgstr "已加入:%(name)s"

#: src/skit/cli.py:749
#, python-format
msgid "Description: %(desc)s"
msgstr "描述:%(desc)s"

#: src/skit/cli.py:753 src/skit/cli.py:885
#, python-format
msgid "Dependencies: %(deps)s"
msgstr "依赖:%(deps)s"

#: src/skit/cli.py:757
#, python-format
msgid "Managed parameters: %(names)s"
msgstr "管理中的参数:%(names)s"

#: src/skit/cli.py:759 src/skit/cli.py:914
#, python-format
msgid "Run it: skit run %(name)s"
msgstr "运行:skit run %(name)s"

#: src/skit/cli.py:762
#, python-format
msgid "Secret parameter values are never saved to disk: %(names)s"
msgstr "机密参数的值不会写入磁盘:%(names)s"

#: src/skit/cli.py:771
msgid "List every registered script."
msgstr "列出所有已登记的脚本。"

#: src/skit/cli.py:773 src/skit/cli.py:955 src/skit/cli.py:1397
#: src/skit/cli.py:2218 src/skit/cli.py:2433 src/skit/cli.py:2609
msgid "Output as JSON"
msgstr "以 JSON 输出"

#: src/skit/cli.py:796
msgid "No scripts yet. Add one with: skit add <path>"
msgstr "还没有任何脚本。用 skit add <path> 加一个。"

#: src/skit/cli.py:801 src/skit/tui.py:367 src/skit/tui.py:915
#: src/skit/tui_add.py:259
msgid "Name"
msgstr "名称"

#: src/skit/cli.py:802 src/skit/cli.py:1613 src/skit/tui.py:367
#: src/skit/tui.py:915
msgid "Kind"
msgstr "类型"

#: src/skit/cli.py:803 src/skit/tui_add.py:261
msgid "Description"
msgstr "说明"

#: src/skit/cli.py:828 src/skit/cli.py:829 src/skit/cli.py:940
#: src/skit/cli.py:1462 src/skit/cli.py:1463
msgid "yes"
msgstr "是"

#: src/skit/cli.py:875
#, python-format
msgid "Source: %(path)s"
msgstr "来源:%(path)s"

#: src/skit/cli.py:878
#, python-format
msgid "Working directory: %(dir)s"
msgstr "工作目录:%(dir)s"

#: src/skit/cli.py:889 src/skit/cli.py:2184
#, python-format
msgid "Python constraint: %(python)s"
msgstr "Python 版本约束:%(python)s"

#: src/skit/cli.py:893
#, python-format
msgid "Needs: %(needs)s"
msgstr "所需命令：%(needs)s"

#: src/skit/cli.py:897
#, python-format
msgid "Command template: %(template)s"
msgstr "命令模板:%(template)s"

#: src/skit/cli.py:902 src/skit/cli.py:1254
msgid "skit could not model this script's own arguments; pass them after -- instead."
msgstr "skit 无法读懂这个脚本自己的参数声明；请把参数放在 -- 之后直接传入。"

#: src/skit/cli.py:908
msgid "No form fields — arguments after -- pass straight through to the script."
msgstr "没有表单字段——接在 -- 之后的参数会透传给脚本。"

#: src/skit/cli.py:912
#, python-format
msgid "Presets: %(names)s"
msgstr "参数组合:%(names)s"

#: src/skit/cli.py:921 src/skit/cli.py:1501 src/skit/cli.py:1612
msgid "Parameter"
msgstr "参数"

#: src/skit/cli.py:922 src/skit/cli.py:1503 src/skit/cli.py:1614
msgid "Type"
msgstr "类型"

#: src/skit/cli.py:923
msgid "Required"
msgstr "必填"

#: src/skit/cli.py:924 src/skit/cli.py:1504 src/skit/cli.py:1615
msgid "Default"
msgstr "默认值"

#: src/skit/cli.py:925
msgid "Choices"
msgstr "可选值"

#: src/skit/cli.py:926 src/skit/cli.py:1505 src/skit/cli.py:1616
msgid "Secret"
msgstr "机密"

#: src/skit/cli.py:927 src/skit/tui.py:337 src/skit/tui.py:473
msgid "Help"
msgstr "帮助"

#: src/skit/cli.py:932 src/skit/cli.py:1469 src/skit/cli.py:1477
#: src/skit/cli.py:1487 src/skit/cli.py:1620 src/skit/cli.py:1624
msgid "•••"
msgstr "•••"

#: src/skit/cli.py:950
msgid "Show everything about one script: metadata, dependencies, parameters, presets."
msgstr "显示一个脚本的完整信息:元数据、依赖、参数、参数组合。"

#: src/skit/cli.py:951
msgid "Examples:  skit show resize  ·  skit show resize --json"
msgstr "例:skit show resize · skit show resize --json"

#: src/skit/cli.py:995
msgid "Remove a registered script (the original file is left untouched)."
msgstr "移除一个已登记的脚本(原文件不受影响)。"

#: src/skit/cli.py:998
msgid "Skip confirmation"
msgstr "跳过确认"

#: src/skit/cli.py:1008 src/skit/tui.py:151
#, python-format
msgid "Remove \"%(name)s\"?"
msgstr "移除「%(name)s」？"

#: src/skit/cli.py:1010
#, python-format
msgid "Remove \"%(name)s\"? Your original file will not be deleted."
msgstr "移除「%(name)s」？你的原始文件不会被删除。"

#: src/skit/cli.py:1015
#, python-format
msgid "Removed: %(name)s"
msgstr "已移除:%(name)s"

#: src/skit/cli.py:1022
#, python-format
msgid "No script named %(name)s."
msgstr "找不到名为 %(name)s 的脚本。"

#: src/skit/cli.py:1026
#, python-format
msgid "No script named \"%(name)s\". Create it now?"
msgstr "找不到名为“%(name)s”的脚本。要现在创建吗?"

#: src/skit/cli.py:1035
msgid "Open a script's source in your editor (offers to create it if the name is new)."
msgstr "用编辑器打开脚本源码(名称不存在时可新建)。"

#: src/skit/cli.py:1036
msgid "Example:  skit edit resize"
msgstr "例：skit edit resize"

#: src/skit/cli.py:1048 src/skit/tui.py:793
#, python-format
msgid "%(name)s has no editable source (programs and command templates run as-is)."
msgstr "%(name)s 没有可编辑的源码（程序和命令模板按原样运行）。"

#: src/skit/cli.py:1056
#, python-format
msgid "%(name)s: the referenced source file is gone: %(path)s"
msgstr "%(name)s:reference 原文件已消失:%(path)s"

#: src/skit/cli.py:1061
#, python-format
msgid "Editing the original file (reference mode): %(path)s"
msgstr "正在编辑原始文件(reference 模式):%(path)s"

#: src/skit/cli.py:1068 src/skit/cli.py:1917 src/skit/cli.py:2023
#, python-format
msgid "%(name)s has no stored copy to edit."
msgstr "%(name)s 没有可编辑的副本。"

#: src/skit/cli.py:1075
#, python-format
msgid "Saved %(name)s."
msgstr "已保存 %(name)s。"

#: src/skit/cli.py:1078
#, python-format
msgid "skit reconciles parameter drift at run time; review managed parameters with: skit params %(name)s"
msgstr "skit 会在运行时自动校对参数差异;可用 skit params %(name)s 查看管理中的参数"

#: src/skit/cli.py:1094 src/skit/cli.py:1439
#, python-format
msgid "Unknown preset \"%(preset)s\". Available: %(presets)s"
msgstr "没有名为“%(preset)s”的参数组合。现有:%(presets)s"

#: src/skit/cli.py:1124
#, python-format
msgid "Malformed --set (expected NAME=VALUE): %(items)s"
msgstr "--set 格式错误(应为 NAME=VALUE):%(items)s"

#: src/skit/cli.py:1134
#, python-format
msgid "Unknown parameter for --set: %(names)s. This script's parameters: %(valid)s"
msgstr "--set 指到不存在的参数:%(names)s。这个脚本的参数:%(valid)s"

#: src/skit/cli.py:1168
#, python-format
msgid "Parameters for %(name)s (press Enter to keep the value shown):"
msgstr "%(name)s 的参数(按 Enter 沿用显示的值):"

#: src/skit/cli.py:1180
msgid "Run a registered script or command in the terminal."
msgstr "在终端运行已登记的脚本或命令。"

#: src/skit/cli.py:1182
msgid "Examples:  skit run stitch  ·  skit run stitch -p web -- extra.png  ·  skit run stitch --set width=800 --no-input  ·  skit run stitch --dry-run"
msgstr "例:skit run stitch · skit run stitch -p web -- extra.png · skit run stitch --set width=800 --no-input · skit run stitch --dry-run"

#: src/skit/cli.py:1188
msgid "Arguments passed through to the script (after --)"
msgstr "透传给脚本的参数(接在 -- 之后)"

#: src/skit/cli.py:1191
msgid "Never prompt; reuse last values and defaults"
msgstr "从不询问;沿用上次的值 / 默认值"

#: src/skit/cli.py:1197
msgid "Named preset of parameter values to prefill the form with"
msgstr "用哪个参数组合(preset)预填表单"

#: src/skit/cli.py:1204
#, python-brace-format
msgid "Set a parameter value by name, as NAME=VALUE (repeatable; values may use tokens like {cwd} or {env:VAR}; the form no longer asks for a field you set)"
msgstr "直接以 NAME=VALUE 指定参数值(可重复;值可用 {cwd}、{env:VAR} 等占位符;已指定的字段表单不再询问)"

#: src/skit/cli.py:1208
msgid "Save this run's values as a named preset"
msgstr "把这次的值存成参数组合"

#: src/skit/cli.py:1211
msgid "Line-by-line prompts instead of the inline form"
msgstr "用逐行问答取代迷你表单"

#: src/skit/cli.py:1217
msgid "Skip the parameter form and injection and run the script as-is (escape hatch)"
msgstr "跳过参数表单与注入,原样运行脚本(逃生门)"

#: src/skit/cli.py:1224
msgid "Print the exact command that would run (tokens and globs expanded), then exit"
msgstr "打印实际会运行的完整命令（token 与通配符已展开）后退出"

#: src/skit/cli.py:1240
msgid "--raw runs the script as-is; --set, --preset, and --save-preset do not apply."
msgstr "--raw 会原样运行脚本;--set、--preset、--save-preset 都不适用。"

#: src/skit/cli.py:1246
msgid "Raw mode: skipping the parameter form and injection."
msgstr "raw 模式:已跳过参数表单与注入。"

#: src/skit/cli.py:1290
#, python-format
msgid "Reusing your last arguments: %(args)s"
msgstr "沿用上次的参数:%(args)s"

#: src/skit/cli.py:1304 src/skit/cli.py:1390
#, python-format
msgid "Preset \"%(preset)s\" saved for %(name)s."
msgstr "已为 %(name)s 保存参数组合“%(preset)s”。"

#: src/skit/cli.py:1327
#, python-format
msgid "Script exited with code %(code)s"
msgstr "脚本以 exit code %(code)s 结束"

#: src/skit/cli.py:1337
msgid "Manage named parameter presets for a script."
msgstr "管理脚本的参数组合(preset)。"

#: src/skit/cli.py:1342
msgid "Save a set of parameter values as a named preset."
msgstr "把一组参数值保存成参数组合(preset)。"

#: src/skit/cli.py:1345 src/skit/cli.py:1424 src/skit/tui_form.py:232
msgid "Preset name"
msgstr "组合名称"

#: src/skit/cli.py:1349
msgid "Save the last run's values without asking (automation-friendly)"
msgstr "直接存上次运行的值，不再询问（适合自动化）"

#: src/skit/cli.py:1361
#, python-format
msgid "%(name)s has no form fields, so there's nothing to save."
msgstr "%(name)s 没有表单字段，没有东西可存。"

#: src/skit/cli.py:1371
#, python-format
msgid "%(name)s has no remembered values yet — run it once first."
msgstr "%(name)s 还没有记住的值——先运行一次。"

#: src/skit/cli.py:1384
#, python-format
msgid "Secret values are never stored in presets; skipped: %(names)s"
msgstr "机密值不会存入参数组合;已跳过:%(names)s"

#: src/skit/cli.py:1394
msgid "List a script's saved presets."
msgstr "列出脚本已保存的参数组合(preset)。"

#: src/skit/cli.py:1411
#, python-format
msgid "No presets for %(name)s yet. Create one with: skit run %(name)s --save-preset <preset>"
msgstr "%(name)s 还没有参数组合。创建一个：skit run %(name)s --save-preset <组合名>"

#: src/skit/cli.py:1421
msgid "Delete a named preset from a script."
msgstr "从脚本删除一个参数组合(preset)。"

#: src/skit/cli.py:1433
#, python-format
msgid "Preset \"%(preset)s\" deleted from %(name)s."
msgstr "已从 %(name)s 删除参数组合“%(preset)s”。"

#: src/skit/cli.py:1488
#, python-format
msgid "default %(value)s"
msgstr "默认 %(value)s"

#: src/skit/cli.py:1490
msgid "optional"
msgstr "选填"

#: src/skit/cli.py:1492
msgid "secret"
msgstr "机密"

#: src/skit/cli.py:1502
msgid "Delivery"
msgstr "传递方式"

#: src/skit/cli.py:1506 src/skit/cli.py:1617
msgid "Last value"
msgstr "上次的值"

#: src/skit/cli.py:1529 src/skit/cli.py:1597
#, python-format
msgid "%(name)s has no managed parameters."
msgstr "%(name)s 没有纳管的参数。"

#: src/skit/cli.py:1533
msgid "Command template placeholders (the run form asks for them):"
msgstr "命令模板的占位符（运行表单会询问）："

#: src/skit/cli.py:1539
msgid "Declared environment variables (set on the run):"
msgstr "声明的环境变量（运行时设置）："

#: src/skit/cli.py:1603
#, python-format
msgid "%(name)s has no managed parameters. Use --manage to bring a detected candidate under management."
msgstr "%(name)s 没有纳管的参数。用 --manage 把检测到的候选纳入管理。"

#: src/skit/cli.py:1639
#, python-format
msgid "Detected but not yet managed: %(names)s (use --manage to manage them)"
msgstr "检测到但尚未纳管：%(names)s（用 --manage 纳管）"

#: src/skit/cli.py:1644
#, python-brace-format, python-format
msgid "This script locates itself ($0 / BASH_SOURCE). Injecting a constant runs it from a temporary copy, so it would see that copy path instead. `skit params %(name)s --normalize NAME` converts a constant into the ${NAME:-default} idiom, which is delivered through the environment and leaves the file untouched."
msgstr "这个脚本会定位自身（$0 / BASH_SOURCE）。注入常量会让它从临时副本运行，因此它看到的会是副本的路径。`skit params %(name)s --normalize NAME` 可以把常量改写成 ${NAME:-default} 惯用法——改用环境变量投递，原文件保持不动。"

#: src/skit/cli.py:1663
msgid "Show or edit a script's managed or declared parameters."
msgstr "查看或编辑脚本的受管或声明参数。"

#: src/skit/cli.py:1665
msgid "Examples:  skit params resize --manage WIDTH  ·  skit params conv --add size --type size=int --deliver size=flag --flag size=--size"
msgstr "例：skit params resize --manage WIDTH · skit params conv --add size --type size=int --deliver size=flag --flag size=--size"

#: src/skit/cli.py:1673
msgid "Prune definitions that no longer match the script and refresh changed types"
msgstr "修剪已对不上脚本的定义,并更新类型已变的项"

#: src/skit/cli.py:1678
msgid "Bring a currently detected candidate under management (repeatable)"
msgstr "把当前检测到的候选纳入管理(可重复)"

#: src/skit/cli.py:1681
msgid "Drop a managed parameter (repeatable)"
msgstr "移除一个受管理的参数(可重复)"

#: src/skit/cli.py:1686
msgid "Declare a new parameter on an exe/command entry, by name (repeatable)"
msgstr "为 exe/command 条目声明一个新参数，按名称指定(可重复)"

#: src/skit/cli.py:1689
msgid "Remove a declared parameter, by name (repeatable)"
msgstr "移除一个声明的参数，按名称指定(可重复)"

#: src/skit/cli.py:1694
msgid "Set a declared parameter's type, as NAME=str|int|float|bool|choice"
msgstr "设置声明参数的类型，格式 NAME=str|int|float|bool|choice"

#: src/skit/cli.py:1697
msgid "Set a declared parameter's default, as NAME=VALUE"
msgstr "设置声明参数的默认值，格式 NAME=VALUE"

#: src/skit/cli.py:1702
msgid "Set a declared parameter's choices, as NAME=a,b,c (comma separated)"
msgstr "设置声明参数的可选值，格式 NAME=a,b,c(逗号分隔)"

#: src/skit/cli.py:1708
msgid "Set how a declared parameter reaches the program, as NAME=env|flag|placeholder"
msgstr "设置声明参数如何传递给程序，格式 NAME=env|flag|placeholder"

#: src/skit/cli.py:1714
msgid "Set a declared flag parameter's option, as NAME=--out (empty = positional)"
msgstr "设置声明的 flag 参数选项，格式 NAME=--out(留空为位置参数)"

#: src/skit/cli.py:1717
msgid "Mark a declared parameter as required (repeatable)"
msgstr "把某个声明参数标为必填(可重复)"

#: src/skit/cli.py:1720
msgid "Mark a declared parameter as optional (repeatable)"
msgstr "把某个声明参数标为选填(可重复)"

#: src/skit/cli.py:1723
msgid "Set a declared parameter's help text, as NAME=text"
msgstr "设置声明参数的帮助文字，格式 NAME=text"

#: src/skit/cli.py:1726
msgid "Mark a managed parameter as secret (repeatable)"
msgstr "把某个受管参数标为机密(可重复)"

#: src/skit/cli.py:1731
msgid "Remove the secret mark from a managed parameter (repeatable)"
msgstr "取消某个受管参数的机密标记(可重复)"

#: src/skit/cli.py:1734
msgid "Set a parameter's form prompt, as NAME=text (repeatable)"
msgstr "以 NAME=text 设定参数的表单提示(可重复)"

#: src/skit/cli.py:1740
msgid "Read a secret parameter from an environment variable at run time, as NAME=ENVVAR (empty ENVVAR clears it; repeatable)"
msgstr "运行时从环境变量读取机密参数，格式 NAME=ENVVAR（ENVVAR 留空表示清除；可重复）"

#: src/skit/cli.py:1747
#, python-brace-format
msgid "Shell only: rewrite a constant into the ${NAME:-default} idiom in the stored copy, so its value is delivered as an environment variable instead of a rewritten temporary copy (repeatable)"
msgstr "仅限 Shell:把常量改写成 ${NAME:-default} 写法(改的是仓库副本),之后它的值就用环境变量传递,不必再改写临时副本(可重复)"

#: src/skit/cli.py:1750
msgid "Output the read view as JSON"
msgstr "读取视图以 JSON 输出"

#: src/skit/cli.py:1804
#, python-format
msgid "%(name)s manages its parameters from the script itself — use --manage / --unmanage, or edit the [tool.skit] block."
msgstr "%(name)s 从脚本自身管理参数——请使用 --manage / --unmanage，或直接编辑 [tool.skit] 区块。"

#: src/skit/cli.py:1870
#, python-format
msgid "%(name)s isn't a managed parameter; --env-source skipped."
msgstr "%(name)s 不是纳管的参数；--env-source 已略过。"

#: src/skit/cli.py:1877
#, python-format
msgid "%(name)s isn't secret; --env-source only applies to secret parameters (mark it with --secret first)."
msgstr "%(name)s 不是机密参数；--env-source 只适用于机密参数（先用 --secret 标记）。"

#: src/skit/cli.py:1902
#, python-format
msgid "%(name)s isn't a Python script; only Python entries have managed parameters."
msgstr "%(name)s 不是 Python 脚本;只有 Python 条目有受管理的参数。"

#: src/skit/cli.py:1909
#, python-format
msgid "%(name)s is in reference mode, and skit never writes the original file. Edit the [tool.skit] block in the source directly."
msgstr "%(name)s 是 reference 模式;skit 绝不写原文件。请直接改原文件的 [tool.skit] 区块。"

#: src/skit/cli.py:1922
#, python-format
msgid "Ignored a malformed value: %(item)s (expected NAME=text)."
msgstr "已忽略格式错误的值：%(item)s（应为 NAME=text）。"

#: src/skit/cli.py:1947 src/skit/cli.py:2142
#, python-format
msgid "Removed previously stored plaintext value(s) for now-secret parameter(s): %(names)s"
msgstr "已移除下列刚设为机密的参数先前以明文存储的值:%(names)s"

#: src/skit/cli.py:1954
#, python-format
msgid "Updated %(name)s. Managed parameters: %(names)s"
msgstr "已更新 %(name)s。受管理的参数:%(names)s"

#: src/skit/cli.py:1965
#, python-format
msgid "%(name)s isn't a plain constant with a literal value, so there's nothing to normalize; skipped."
msgstr "%(name)s 不是带字面值的普通常量,没有可以规范化的东西;已跳过。"

#: src/skit/cli.py:1968
#, python-format
msgid "%(name)s is assigned more than once at the top level; normalizing it would change which value wins. Skipped."
msgstr "%(name)s 在顶层被赋值多次;规范化会改变最终生效的值。已跳过。"

#: src/skit/cli.py:1971
#, python-format
msgid "%(name)s is readonly, so the script could never take a value from the environment; skipped."
msgstr "%(name)s 是 readonly,脚本永远不可能从环境变量取值;已跳过。"

#: src/skit/cli.py:1973
#, python-format
msgid "%(name)s already reads from the environment; nothing to do."
msgstr "%(name)s 已经从环境变量读取了;无需处理。"

#: src/skit/cli.py:1975
#, python-format
msgid "%(name)s's value contains a character that can't be moved into ${...:-...} safely (one of } \" ` $ \\ or a newline); skipped — it keeps being injected into a temporary copy."
msgstr "%(name)s 的值里有无法安全放进 ${...:-...} 的字符(} \" ` $ \\ 或换行);已跳过——它会继续用临时副本注入。"

#: src/skit/cli.py:1979
msgid "Could not parse the script (syntax error); nothing was normalized."
msgstr "无法解析脚本(语法错误);没有做任何规范化。"

#: src/skit/cli.py:2007
#, python-brace-format, python-format
msgid "%(name)s has no --normalize: it is a shell idiom (VAR=value -> VAR=\"${VAR:-value}\")."
msgstr "%(name)s 没有 --normalize:那是 shell 的写法(VAR=value -> VAR=\"${VAR:-value}\")。"

#: src/skit/cli.py:2015
#, python-brace-format, python-format
msgid "%(name)s is in reference mode, and skit never writes the original file. Change the line to VAR=\"${VAR:-value}\" in the source directly."
msgstr "%(name)s 是 reference 模式;skit 绝不写原文件。请直接把原文件里那行改成 VAR=\"${VAR:-value}\"。"

#: src/skit/cli.py:2050
#, python-format
msgid "Normalized %(names)s in %(name)s: delivered as environment variables from now on (no temporary copy, and $0 stays your real file)."
msgstr "已规范化 %(name)s 中的 %(names)s:今后用环境变量传值(不再写临时副本,$0 也仍指向你的真实文件)。"

#: src/skit/cli.py:2060
#, python-format
msgid "%(name)s isn't a declared parameter; skipped."
msgstr "%(name)s 不是已声明的参数，已跳过。"

#: src/skit/cli.py:2061
#, python-format
msgid "%(name)s is already declared; skipped."
msgstr "%(name)s 已经声明过，已跳过。"

#: src/skit/cli.py:2062
#, python-format
msgid "%(name)s: that delivery isn't available for this kind; skipped."
msgstr "%(name)s：该传递方式不适用于此类型，已跳过。"

#: src/skit/cli.py:2064
#, python-format
msgid "%(name)s isn't a template placeholder, so it can't use placeholder delivery; skipped."
msgstr "%(name)s 不是模板占位符，无法使用 placeholder 传递方式，已跳过。"

#: src/skit/cli.py:2067
#, python-format
msgid "%(name)s: unknown type; skipped (use str, int, float, bool, or choice)."
msgstr "%(name)s：未知类型，已跳过(可用 str、int、float、bool 或 choice)。"

#: src/skit/cli.py:2069
#, python-format
msgid "%(name)s: the default doesn't fit its type; skipped."
msgstr "%(name)s：默认值与其类型不符，已跳过。"

#: src/skit/cli.py:2071
#, python-format
msgid "%(name)s: a choice parameter needs choices; set --choices %(name)s=a,b,c."
msgstr "%(name)s：choice 参数需要可选值，请设置 --choices %(name)s=a,b,c。"

#: src/skit/cli.py:2113
#, python-format
msgid "Ignored a malformed value: %(item)s (expected NAME=VALUE)."
msgstr "已忽略格式错误的值：%(item)s（应为 NAME=VALUE）。"

#: src/skit/cli.py:2149
#, python-format
msgid "Updated %(name)s. Declared parameters: %(names)s"
msgstr "已更新 %(name)s。已声明的参数:%(names)s"

#: src/skit/cli.py:2176
#, python-format
msgid "Dependencies of %(name)s: %(deps)s"
msgstr "%(name)s 的依赖:%(deps)s"

#: src/skit/cli.py:2188
#, python-format
msgid "External commands needed by %(name)s: %(needs)s"
msgstr "%(name)s 所需的外部命令：%(needs)s"

#: src/skit/cli.py:2194
msgid "View or update a script's dependencies, Python constraint, and needed commands."
msgstr "查看或更新脚本的依赖、Python 版本约束，以及所需的外部命令。"

#: src/skit/cli.py:2196
msgid "Examples:  skit deps tool --dep \"requests>=2,<3\" --dep rich  ·  skit deps clip --need jq"
msgstr "示例：skit deps tool --dep \"requests>=2,<3\" --dep rich  ·  skit deps clip --need jq"

#: src/skit/cli.py:2202
msgid "A dependency (repeat for more; replaces the whole list)"
msgstr "一项依赖（可重复；整组取代原列表）"

#: src/skit/cli.py:2204
msgid "Remove every dependency"
msgstr "清空所有依赖"

#: src/skit/cli.py:2212
msgid "An external command the script needs on PATH (repeat; replaces the whole list)"
msgstr "脚本在 PATH 上所需的一个外部命令（可重复；整组取代原列表）"

#: src/skit/cli.py:2216
msgid "Remove every needed external command"
msgstr "清空所有所需的外部命令"

#: src/skit/cli.py:2234
#, python-format
msgid "%(name)s doesn't take package dependencies — only --need applies here."
msgstr "%(name)s 不接受包依赖——这里只能用 --need。"

#: src/skit/cli.py:2240
msgid "Use --dep to set the list or --clear to empty it — not both."
msgstr "--dep 用来设置列表、--clear 用来清空——两者择一。"

#: src/skit/cli.py:2245
msgid "Use --need to set the list or --clear-needs to empty it — not both."
msgstr "--need 用来设置列表、--clear-needs 用来清空——两者择一。"

#: src/skit/cli.py:2255
#, python-format
msgid "Needs of %(name)s updated: %(needs)s"
msgstr "%(name)s 所需的命令已更新：%(needs)s"

#: src/skit/cli.py:2269
#, python-format
msgid "Dependencies of %(name)s updated: %(deps)s"
msgstr "%(name)s 的依赖已更新:%(deps)s"

#: src/skit/cli.py:2278
msgid "Connect skit to AI agents: install the official Agent Skill."
msgstr "把 skit 接上 AI agent:安装官方 Agent Skill。"

#: src/skit/cli.py:2293
#, python-format
msgid "Could not write the skill there: %(error)s"
msgstr "无法把 skill 写到那里:%(error)s"

#: src/skit/cli.py:2296
#, python-format
msgid "Installed the skit Agent Skill: %(path)s"
msgstr "已安装 skit Agent Skill:%(path)s"

#: src/skit/cli.py:2302
msgid "user"
msgstr "用户"

#: src/skit/cli.py:2302
msgid "project"
msgstr "项目"

#: src/skit/cli.py:2303
msgid "Agent directories on this machine:"
msgstr "这台机器上的 agent 目录:"

#: src/skit/cli.py:2307
msgid "Install where?"
msgstr "要装到哪里?"

#: src/skit/cli.py:2314
#, python-format
msgid "Write the skill into %(path)s?"
msgstr "把 skill 写入 %(path)s?"

#: src/skit/cli.py:2324
msgid "Install skit's Agent Skill into an AI agent's skills directory."
msgstr "把 skit 的 Agent Skill 安装到 AI agent 的 skills 目录。"

#: src/skit/cli.py:2326
msgid "Examples:  skit agent install  ·  skit agent install claude  ·  skit agent install codex --project  ·  skit agent install --to ~/.claude/skills"
msgstr "例:skit agent install · skit agent install claude · skit agent install codex --project · skit agent install --to ~/.claude/skills"

#: src/skit/cli.py:2333
msgid "Where to install: claude, codex, or agents (the cross-agent ./.agents directory)"
msgstr "安装目标:claude、codex,或 agents(跨 agent 的 ./.agents 目录)"

#: src/skit/cli.py:2339
msgid "Install into this skills directory instead of a named target"
msgstr "安装到这个 skills 目录,而不是具名目标"

#: src/skit/cli.py:2345
msgid "Install into the current project (./.claude, ./.codex) instead of your home directory"
msgstr "安装到当前项目(./.claude、./.codex),而不是主目录"

#: src/skit/cli.py:2354
msgid "Use a named target (with optional --project) or --to — not both."
msgstr "具名目标(可搭配 --project)和 --to 二选一,不能同时。"

#: src/skit/cli.py:2366
#, python-format
msgid "Unknown target %(name)s. Valid targets: claude, codex, agents."
msgstr "没有 %(name)s 这个目标。可用目标:claude、codex、agents。"

#: src/skit/cli.py:2375
msgid "Nothing installed: name a target (claude, codex, agents) or pass --to DIR."
msgstr "没有安装任何东西:请指定目标(claude、codex、agents)或改用 --to DIR。"

#: src/skit/cli.py:2382
msgid "No agent directories detected (~/.claude, ~/.codex, ./.agents, …). Pass --to DIR to choose one yourself."
msgstr "没有检测到 agent 目录(~/.claude、~/.codex、./.agents 等)。可用 --to DIR 自行指定。"

#: src/skit/cli.py:2388
msgid "Cancelled — nothing was written."
msgstr "已取消——没有写入任何东西。"

#: src/skit/cli.py:2428
msgid "Check that uv is available and the script store is intact."
msgstr "检查 uv 是否可用以及脚本仓库是否完好。"

#: src/skit/cli.py:2431
msgid "Rebuild the index from each script's meta.toml"
msgstr "从各脚本的 meta.toml 重建索引"

#: src/skit/cli.py:2442 src/skit/tui_health.py:159
#, python-format
msgid "Index rebuilt: %(count)s entry"
msgid_plural "Index rebuilt: %(count)s entries"
msgstr[0] "索引已重建:%(count)s 条"

#: src/skit/cli.py:2471 src/skit/tui_health.py:59
#, python-format
msgid "uv: %(path)s"
msgstr "uv:%(path)s"

#: src/skit/cli.py:2474 src/skit/tui_health.py:62
msgid "uv: not found. Install it from https://docs.astral.sh/uv/getting-started/installation/"
msgstr "uv:未找到。安装方式:https://docs.astral.sh/uv/getting-started/installation/"

#: src/skit/cli.py:2478 src/skit/tui_health.py:69
#, python-format
msgid "%(count)s script registered"
msgid_plural "%(count)s scripts registered"
msgstr[0] "已登记 %(count)s 个脚本"

#: src/skit/cli.py:2483
