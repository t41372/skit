#: src/skit/tui_add.py:624 src/skit/tui_add.py:835 src/skit/tui_add.py:1306
msgid "Name"
msgstr "名称"

#: src/skit/cli.py:2274 src/skit/cli.py:3879 src/skit/tui.py:370
