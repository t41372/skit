msgstr "解释器:%(program)s"

#: src/skit/cli.py:2371 src/skit/cli.py:4814
#, python-format
msgid "Python constraint: %(python)s"
msgstr "Python 版本约束:%(python)s"

#: src/skit/cli.py:2375
#, python-format
msgid "Needs: %(needs)s"
msgstr "所需命令：%(needs)s"

#: src/skit/cli.py:2379
#, python-format
msgid "Command template: %(template)s"
msgstr "命令模板:%(template)s"

#: src/skit/cli.py:2383
#, python-format
