#: src/skit/tui.py:193
msgid "No parameter candidates were detected in this script."
msgstr "这个脚本检测不到任何参数候选。"

#: src/skit/tui.py:241
#, python-format
msgid "Form prompt for %(name)s (Enter to apply, Esc to cancel)"
msgstr "%(name)s 的表单提示(Enter 应用,Esc 取消)"

#: src/skit/tui.py:272
msgid "resync: on — definitions that no longer match the script will be pruned when you save"
msgstr "对账:开 — 保存时会剔除已对不上脚本的定义"

#: src/skit/tui.py:299
#, python-format
msgid "Updated %(name)s. Managed: %(names)s"
msgstr "已更新 %(name)s。受管理的参数:%(names)s"

#: src/skit/tui.py:350 src/skit/tui.py:351
msgid "Quit"
msgstr "退出"

#: src/skit/tui.py:352
msgid "Remove"
msgstr "删除"

#: src/skit/tui.py:355
msgid "Params"
msgstr "参数"

#: src/skit/tui.py:356
msgid "Run"
msgstr "运行"

#: src/skit/tui.py:376
msgid "Press Ctrl+C again to quit"
msgstr "再按一次 Ctrl+C 退出"

#: src/skit/tui.py:382
msgid "Type to search… (Enter to run, Ctrl+C twice to quit, Del to remove)"
msgstr "打字搜索…(Enter 运行,Ctrl+C 按两次退出,Del 删除)"

#: src/skit/tui.py:413
msgid "No scripts yet. Quit and add one with: skit add <path>"
msgstr "还没有任何脚本。退出后用 skit add <path> 加一个。"

#: src/skit/tui.py:417
#, python-format
msgid "%(shown)s/%(total)s script"
msgid_plural "%(shown)s/%(total)s scripts"
msgstr[0] "%(shown)s/%(total)s 个脚本"

#: src/skit/tui.py:459
#, python-format
msgid "── Running %(name)s ──"
msgstr "── 运行 %(name)s ──"

#: src/skit/tui.py:476
#, python-format
msgid "Error: %(error)s"
msgstr "错误:%(error)s"

#: src/skit/tui.py:482
#, python-format
msgid "── Finished (exit code %(code)s) — press Enter to return ──"
msgstr "── 结束(exit code %(code)s),按 Enter 返回菜单 ──"

#: src/skit/tui.py:557
#, python-format
msgid "%(name)s: only Python copy-mode entries have editable parameter definitions."
msgstr "%(name)s:只有 copy 模式的 Python 条目可以编辑参数定义。"

#: src/skit/uvman.py:51
#, python-format
msgid "skit needs Astral's uv to run Python scripts, but it wasn't found on this system. Download uv %(version)s into skit's private directory (%(path)s)? This won't touch your PATH or global environment. [Y/n]"
msgstr "skit 需要 Astral uv 才能运行 Python 脚本,但系统上找不到。要下载 uv %(version)s 到 skit 的私有目录(%(path)s)吗?不会动到你的 PATH 或全局环境。[Y/n]"

#: src/skit/uvman.py:75
#, python-format
msgid "Unsupported platform: %(platform)s"
msgstr "不支持的平台:%(platform)s"

#: src/skit/uvman.py:106
#, python-format
msgid "No uv binary found inside the archive: %(path)s"
msgstr "压缩包内找不到 uv 可执行文件:%(path)s"

#: src/skit/uvman.py:124
msgid "Download declined. Install uv yourself (https://docs.astral.sh/uv/getting-started/installation/) and skit will pick it up automatically."
msgstr "已取消下载。你可以自行安装 uv(https://docs.astral.sh/uv/getting-started/installation/),skit 会自动检测并使用。"

#: src/skit/uvman.py:131
#, python-format
msgid "First run — downloading uv %(version)s…"
msgstr "首次运行:正在下载 uv %(version)s…"

#: src/skit/uvman.py:147
#, python-format
msgid "Failed to download uv: %(error)s"
msgstr "uv 下载失败:%(error)s"

#: src/skit/uvman.py:151
#, python-format
msgid "uv installed at: %(path)s"
msgstr "uv 已安装:%(path)s"

