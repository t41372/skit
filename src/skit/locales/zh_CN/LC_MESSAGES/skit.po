#: src/skit/cli.py:56
msgid ""
"skit — a script launcher and parameter manager. Run it without a "
"subcommand to open the main menu."
msgstr "skit — 脚本启动器 + 参数管家。不带子命令运行即进入主菜单。"

#: src/skit/cli.py:113
msgid "Script name or slug"
msgstr "脚本名称或 slug"

#: src/skit/cli.py:120
msgid "Show version"
msgstr "显示版本"

#: src/skit/cli.py:152
#, python-format
msgid "The script declares its own dependencies (PEP 723): %(deps)s"
msgstr "脚本已用 PEP 723 语法声明依赖：%(deps)s"

#: src/skit/cli.py:164
msgid "Dependencies to install (Enter to accept, edit the list, or '-' for none)"
msgstr "要安装的依赖(Enter 采用,可自行编辑,或输入 - 表示不需要)"

#: src/skit/cli.py:173
msgid "Python version (leave empty for automatic)"
msgstr "Python 版本(留空 = 自动)"

#: src/skit/cli.py:185 src/skit/cli.py:381
msgid "Name in skit"
msgstr "在 skit 里的名称"

#: src/skit/cli.py:188
msgid "Description (optional)"
msgstr "描述(可留空)"

#: src/skit/cli.py:197 src/skit/store.py:228 src/skit/store.py:289
#: src/skit/tui_add.py:87
#, python-format
msgid "File not found: %(path)s"
msgstr "找不到文件：%(path)s"

#: src/skit/cli.py:226
msgid " (secret)"
msgstr " (机密)"

#: src/skit/cli.py:230
#, python-format
msgid "%(num)s. %(name)s (%(type)s) = %(value)s%(secret)s"
msgstr "%(num)s. %(name)s(%(type)s)= %(value)s%(secret)s"

#: src/skit/cli.py:242
#, python-format
msgid "%(num)s. input() #%(ordinal)s: %(prompt)s%(secret)s"
msgstr "%(num)s. input() 第 %(ordinal)s 个:%(prompt)s%(secret)s"

#: src/skit/cli.py:247
msgid "⚠ looks like a loop accumulator — probably not a parameter"
msgstr "⚠ 看起来是循环的累加变量，多半不是参数"

#: src/skit/cli.py:257 src/skit/tui_add.py:332
msgid ""
"This script reads command-line arguments; the run form has an extra-"
"arguments field for them."
msgstr "这个脚本会吃命令行参数；运行表单里有「额外参数」栏可以填。"

#: src/skit/cli.py:266
#, python-format
msgid ""
"💡 %(names)s are written directly inside the code, so skit can't turn them"
" into form fields. To manage one, first give it a name at the top of the "
"script, e.g. OUTPUT = '…' (skit edit %(script)s)."
msgstr ""
"💡 %(names)s 直接写在代码里，skit 没法把它们变成表单字段。想管理其中一个，先在脚本开头给它取个名字，例如 OUTPUT = "
"'…'（skit edit %(script)s）。"

#: src/skit/cli.py:288 src/skit/tui_add.py:286
#, python-format
msgid ""
"✓ skit read this script's own arguments (%(count)s fields). Running it "
"opens a form — nothing to memorize."
msgstr "✓ skit 看懂了这个脚本自己的参数（共 %(count)s 项）。运行时会打开表单——不用背任何命令。"

#: src/skit/cli.py:296 src/skit/tui_add.py:294
#, python-format
msgid ""
"This script parses its own arguments (%(names)s); skit couldn't model "
"them statically, so the run form offers a passthrough-arguments field."
msgstr "这个脚本自己解析参数（%(names)s）；skit 无法静态读懂它们，运行表单会提供「额外参数（原样传给脚本）」栏。"

#: src/skit/cli.py:307
#, python-format
msgid "Found %(count)s parameter candidate (constants / input() calls):"
msgid_plural "Found %(count)s parameter candidates (constants / input() calls):"
msgstr[0] "找到 %(count)s 个候选参数(写死的常量 / input() 调用):"

#: src/skit/cli.py:316
msgid "Which ones should skit manage? (e.g. 1,3 / all / none)"
msgstr "哪些交给 skit 管理?(编号如 1,3 / all / none)"

#: src/skit/cli.py:356
msgid ""
"Reference mode never touches the original file, so parameter setup was "
"skipped."
msgstr "reference 模式绝不改动原文件;跳过参数设置。"

#: src/skit/cli.py:377
msgid "Writing a new script in an editor needs an interactive terminal."
msgstr "用编辑器新建脚本需要交互式终端。"

#: src/skit/cli.py:383 src/skit/store.py:454 src/skit/tui_add.py:125
msgid "A name is required."
msgstr "必须提供名称。"

#: src/skit/cli.py:390
msgid "Opening your editor…"
msgstr "正在打开编辑器…"

#: src/skit/cli.py:394
msgid "Nothing was written, so no script was added."
msgstr "没有写入任何内容,因此没有加入脚本。"

#: src/skit/cli.py:412
msgid "Reading the script from stdin needs an explicit --name."
msgstr "从 stdin 读脚本必须用 --name 指定名称。"

#: src/skit/cli.py:418
msgid "Nothing arrived on stdin, so there is nothing to add."
msgstr "stdin 没有收到任何内容，没有东西可添加。"

#: src/skit/cli.py:443
msgid "Add a script, executable, or command to skit."
msgstr "把脚本、可执行文件或命令加入 skit。"

#: src/skit/cli.py:445
#, python-brace-format
msgid ""
"Examples:  skit add tools/resize.py  ·  skit add --cmd 'ffmpeg -i "
"{input}' -n convert  ·  pbpaste | skit add - -n clip"
msgstr ""
"例：skit add tools/resize.py · skit add --cmd 'ffmpeg -i {input}' -n "
"convert · pbpaste | skit add - -n clip"

#: src/skit/cli.py:450
msgid "Path to a script or executable, or '-' to read a script from stdin"
msgstr "脚本或可执行文件路径；「-」表示从 stdin 读脚本"

#: src/skit/cli.py:453
msgid "Name / alias (defaults to the file name)"
msgstr "名称 / alias(默认用文件名)"

#: src/skit/cli.py:459
msgid "Description (defaults to the first line of the docstring)"
msgstr "描述(默认取 docstring 首行)"

#: src/skit/cli.py:462
msgid "Write a brand-new script in your editor, then add it"
msgstr "在编辑器里新写一支脚本,再加入 skit"

#: src/skit/cli.py:467
msgid "Reference mode: link to the original file instead of copying it"
msgstr "reference 模式:不复制,链接原文件"

#: src/skit/cli.py:472
msgid "Force the executable kind (normally inferred from the file itself)"
msgstr "强制当作可执行文件（一般会自动判断）"

#: src/skit/cli.py:475
#, python-brace-format
msgid "Register a command template, e.g. --cmd 'ffmpeg -i {input}'"
msgstr "登记命令模板,如 --cmd 'ffmpeg -i {input}'"

#: src/skit/cli.py:480
msgid "A dependency (repeat for more; skips the interactive question)"
msgstr "一项依赖（可重复；会跳过交互询问）"

#: src/skit/cli.py:483 src/skit/cli.py:1546
msgid "Python version constraint, e.g. \">=3.11\""
msgstr "Python 版本约束,如 \">=3.11\""

#: src/skit/cli.py:486
msgid "Never prompt; accept the detected suggestions"
msgstr "从不询问;直接采用检测到的建议"

#: src/skit/cli.py:493
msgid ""
"Use --edit to write a new script, or pass a path to add an existing one —"
" not both."
msgstr "用 --edit 新写脚本,或传入路径加入现有文件,两者不能同时使用。"

#: src/skit/cli.py:507
msgid "A --cmd entry needs a --name"
msgstr "--cmd 条目必须指定 --name"

#: src/skit/cli.py:513
#, python-format
msgid ""
"Detected parameters: %(names)s (the run form asks for them; your last "
"values are remembered)"
msgstr "检测到参数：%(names)s（运行表单会询问；会记住你上次的值）"

#: src/skit/cli.py:520
msgid "Provide a script path, or use --cmd to register a command template"
msgstr "请提供脚本路径,或用 --cmd 登记命令模板"

#: src/skit/cli.py:529 src/skit/tui_add.py:95
#, python-format
msgid ""
"%(file)s isn't a .py file or an executable — pass --exe for a program, or"
" --cmd for a command template."
msgstr "%(file)s 不是 .py 文件也不是可执行文件——程序请加 --exe，命令模板请用 --cmd。"

#: src/skit/cli.py:538
#, python-format
msgid "Can't read %(path)s: %(error)s"
msgstr "无法读取 %(path)s:%(error)s"

#: src/skit/cli.py:561
msgid "Cancelled — nothing was added."
msgstr "已取消——没有添加任何东西。"

#: src/skit/cli.py:585
#, python-format
msgid "(%(mode)s mode)"
msgstr "(%(mode)s 模式)"

#: src/skit/cli.py:590
#, python-format
msgid "Added: %(name)s"
msgstr "已加入:%(name)s"

#: src/skit/cli.py:594
#, python-format
msgid "Description: %(desc)s"
msgstr "描述:%(desc)s"

#: src/skit/cli.py:598 src/skit/cli.py:715
#, python-format
msgid "Dependencies: %(deps)s"
msgstr "依赖:%(deps)s"

#: src/skit/cli.py:602
#, python-format
msgid "Managed parameters: %(names)s"
msgstr "管理中的参数:%(names)s"

#: src/skit/cli.py:604 src/skit/cli.py:740
#, python-format
msgid "Run it: skit run %(name)s"
msgstr "运行:skit run %(name)s"

#: src/skit/cli.py:607
#, python-format
msgid "Secret parameter values are never saved to disk: %(names)s"
msgstr "机密参数的值不会写入磁盘:%(names)s"

#: src/skit/cli.py:616
msgid "List every registered script."
msgstr "列出所有已登记的脚本。"

#: src/skit/cli.py:618 src/skit/cli.py:781 src/skit/cli.py:1198
#: src/skit/cli.py:1548 src/skit/cli.py:1732 src/skit/cli.py:1871
msgid "Output as JSON"
msgstr "以 JSON 输出"

#: src/skit/cli.py:641
msgid "No scripts yet. Add one with: skit add <path>"
msgstr "还没有任何脚本。用 skit add <path> 加一个。"

#: src/skit/cli.py:646 src/skit/tui.py:292 src/skit/tui.py:828
#: src/skit/tui_add.py:208
msgid "Name"
msgstr "名称"

#: src/skit/cli.py:647 src/skit/cli.py:1313 src/skit/tui.py:292
#: src/skit/tui.py:828
msgid "Kind"
msgstr "类型"

#: src/skit/cli.py:648 src/skit/tui_add.py:210
msgid "Description"
msgstr "说明"

#: src/skit/cli.py:673 src/skit/cli.py:674 src/skit/cli.py:766
#: src/skit/cli.py:1263 src/skit/cli.py:1264
msgid "yes"
msgstr "是"

#: src/skit/cli.py:705
#, python-format
msgid "Source: %(path)s"
msgstr "来源:%(path)s"

#: src/skit/cli.py:708
#, python-format
msgid "Working directory: %(dir)s"
msgstr "工作目录:%(dir)s"

#: src/skit/cli.py:719 src/skit/cli.py:1583
#, python-format
msgid "Python constraint: %(python)s"
msgstr "Python 版本约束:%(python)s"

#: src/skit/cli.py:723
#, python-format
msgid "Command template: %(template)s"
msgstr "命令模板:%(template)s"

#: src/skit/cli.py:728 src/skit/cli.py:1067
msgid ""
"skit could not model this script's own arguments; pass them after -- "
"instead."
msgstr "skit 无法读懂这个脚本自己的参数声明；请把参数放在 -- 之后直接传入。"

#: src/skit/cli.py:734
msgid "No form fields — arguments after -- pass straight through to the script."
msgstr "没有表单字段——接在 -- 之后的参数会透传给脚本。"

#: src/skit/cli.py:738
#, python-format
msgid "Presets: %(names)s"
msgstr "参数组合:%(names)s"

#: src/skit/cli.py:747 src/skit/cli.py:1312
msgid "Parameter"
msgstr "参数"

#: src/skit/cli.py:748 src/skit/cli.py:1314
msgid "Type"
msgstr "类型"

#: src/skit/cli.py:749
msgid "Required"
msgstr "必填"

#: src/skit/cli.py:750 src/skit/cli.py:1315
msgid "Default"
msgstr "默认值"

#: src/skit/cli.py:751
msgid "Choices"
msgstr "可选值"

#: src/skit/cli.py:752 src/skit/cli.py:1316
msgid "Secret"
msgstr "机密"

#: src/skit/cli.py:753 src/skit/tui.py:258 src/skit/tui.py:393
msgid "Help"
msgstr "帮助"

#: src/skit/cli.py:758 src/skit/cli.py:1320 src/skit/cli.py:1324
msgid "•••"
msgstr "•••"

#: src/skit/cli.py:776
msgid ""
"Show everything about one script: metadata, dependencies, parameters, "
"presets."
msgstr "显示一个脚本的完整信息:元数据、依赖、参数、参数组合。"

#: src/skit/cli.py:777
msgid "Examples:  skit show resize  ·  skit show resize --json"
msgstr "例:skit show resize · skit show resize --json"

#: src/skit/cli.py:819
msgid "Remove a registered script (the original file is left untouched)."
msgstr "移除一个已登记的脚本(原文件不受影响)。"

#: src/skit/cli.py:822
msgid "Skip confirmation"
msgstr "跳过确认"

#: src/skit/cli.py:831 src/skit/tui.py:121
#, python-format
msgid "Remove \"%(name)s\"?"
msgstr "移除「%(name)s」？"

#: src/skit/cli.py:833
#, python-format
msgid "Remove \"%(name)s\"? Your original file will not be deleted."
msgstr "移除「%(name)s」？你的原始文件不会被删除。"

#: src/skit/cli.py:838
#, python-format
msgid "Removed: %(name)s"
msgstr "已移除:%(name)s"

#: src/skit/cli.py:845
#, python-format
msgid "No script named %(name)s."
msgstr "找不到名为 %(name)s 的脚本。"

#: src/skit/cli.py:849
#, python-format
msgid "No script named \"%(name)s\". Create it now?"
msgstr "找不到名为“%(name)s”的脚本。要现在创建吗?"

#: src/skit/cli.py:858
msgid ""
"Open a script's source in your editor (offers to create it if the name is"
" new)."
msgstr "用编辑器打开脚本源码(名称不存在时可新建)。"

#: src/skit/cli.py:859
msgid "Example:  skit edit resize"
msgstr "例：skit edit resize"

#: src/skit/cli.py:870
#, python-format
msgid "%(name)s isn't a Python script, so it has no source to edit."
msgstr "%(name)s 不是 Python 脚本,没有可编辑的源码。"

#: src/skit/cli.py:878
#, python-format
msgid "%(name)s: the referenced source file is gone: %(path)s"
msgstr "%(name)s:reference 原文件已消失:%(path)s"

#: src/skit/cli.py:883
#, python-format
msgid "Editing the original file (reference mode): %(path)s"
msgstr "正在编辑原始文件(reference 模式):%(path)s"

#: src/skit/cli.py:890 src/skit/cli.py:1488
#, python-format
msgid "%(name)s has no stored copy to edit."
msgstr "%(name)s 没有可编辑的副本。"

#: src/skit/cli.py:897
#, python-format
msgid "Saved %(name)s."
msgstr "已保存 %(name)s。"

#: src/skit/cli.py:900
#, python-format
msgid ""
"skit reconciles parameter drift at run time; review managed parameters "
"with: skit params %(name)s"
msgstr "skit 会在运行时自动校对参数差异;可用 skit params %(name)s 查看管理中的参数"

#: src/skit/cli.py:916 src/skit/cli.py:1240
#, python-format
msgid "Unknown preset \"%(preset)s\". Available: %(presets)s"
msgstr "没有名为“%(preset)s”的参数组合。现有:%(presets)s"

#: src/skit/cli.py:946
#, python-format
msgid "Malformed --set (expected NAME=VALUE): %(items)s"
msgstr "--set 格式错误(应为 NAME=VALUE):%(items)s"

#: src/skit/cli.py:956
#, python-format
msgid ""
"Unknown parameter for --set: %(names)s. This script's parameters: "
"%(valid)s"
msgstr "--set 指到不存在的参数:%(names)s。这个脚本的参数:%(valid)s"

#: src/skit/cli.py:990
#, python-format
msgid "Parameters for %(name)s (press Enter to keep the value shown):"
msgstr "%(name)s 的参数(按 Enter 沿用显示的值):"

#: src/skit/cli.py:1002
msgid "Run a registered script or command in the terminal."
msgstr "在终端运行已登记的脚本或命令。"

#: src/skit/cli.py:1004
msgid ""
"Examples:  skit run stitch  ·  skit run stitch -p web -- extra.png  ·  "
"skit run stitch --set width=800 --no-input  ·  skit run stitch --dry-run"
msgstr ""
"例:skit run stitch · skit run stitch -p web -- extra.png · skit run stitch"
" --set width=800 --no-input · skit run stitch --dry-run"

#: src/skit/cli.py:1010
msgid "Arguments passed through to the script (after --)"
msgstr "透传给脚本的参数(接在 -- 之后)"

#: src/skit/cli.py:1013
msgid "Never prompt; reuse last values and defaults"
msgstr "从不询问;沿用上次的值 / 默认值"

#: src/skit/cli.py:1019
msgid "Named preset of parameter values to prefill the form with"
msgstr "用哪个参数组合(preset)预填表单"

#: src/skit/cli.py:1026
#, python-brace-format
msgid ""
"Set a parameter value by name, as NAME=VALUE (repeatable; values may use "
"tokens like {cwd} or {env:VAR}; the form no longer asks for a field you "
"set)"
msgstr "直接以 NAME=VALUE 指定参数值(可重复;值可用 {cwd}、{env:VAR} 等占位符;已指定的字段表单不再询问)"

#: src/skit/cli.py:1030
msgid "Save this run's values as a named preset"
msgstr "把这次的值存成参数组合"

#: src/skit/cli.py:1033
msgid "Line-by-line prompts instead of the inline form"
msgstr "用逐行问答取代迷你表单"

#: src/skit/cli.py:1039
msgid ""
"Skip the parameter form and injection and run the script as-is (escape "
"hatch)"
msgstr "跳过参数表单与注入,原样运行脚本(逃生门)"

#: src/skit/cli.py:1046
msgid ""
"Print the exact command that would run (tokens and globs expanded), then "
"exit"
msgstr "打印实际会运行的完整命令（token 与通配符已展开）后退出"

#: src/skit/cli.py:1059
msgid "Raw mode: skipping the parameter form and injection."
msgstr "raw 模式:已跳过参数表单与注入。"

#: src/skit/cli.py:1097
#, python-format
msgid "Reusing your last arguments: %(args)s"
msgstr "沿用上次的参数:%(args)s"

#: src/skit/cli.py:1111 src/skit/cli.py:1191
#, python-format
msgid "Preset \"%(preset)s\" saved for %(name)s."
msgstr "已为 %(name)s 保存参数组合“%(preset)s”。"

#: src/skit/cli.py:1128
#, python-format
msgid "Script exited with code %(code)s"
msgstr "脚本以 exit code %(code)s 结束"

#: src/skit/cli.py:1138
msgid "Manage named parameter presets for a script."
msgstr "管理脚本的参数组合(preset)。"

#: src/skit/cli.py:1143
msgid "Save a set of parameter values as a named preset."
msgstr "把一组参数值保存成参数组合(preset)。"

#: src/skit/cli.py:1146 src/skit/cli.py:1225 src/skit/tui_form.py:232
msgid "Preset name"
msgstr "组合名称"

#: src/skit/cli.py:1150
msgid "Save the last run's values without asking (automation-friendly)"
msgstr "直接存上次运行的值，不再询问（适合自动化）"

#: src/skit/cli.py:1162
#, python-format
msgid "%(name)s has no form fields, so there's nothing to save."
msgstr "%(name)s 没有表单字段，没有东西可存。"

#: src/skit/cli.py:1172
#, python-format
msgid "%(name)s has no remembered values yet — run it once first."
msgstr "%(name)s 还没有记住的值——先运行一次。"

#: src/skit/cli.py:1185
#, python-format
msgid "Secret values are never stored in presets; skipped: %(names)s"
msgstr "机密值不会存入参数组合;已跳过:%(names)s"

#: src/skit/cli.py:1195
msgid "List a script's saved presets."
msgstr "列出脚本已保存的参数组合(preset)。"

#: src/skit/cli.py:1212
#, python-format
msgid ""
"No presets for %(name)s yet. Create one with: skit run %(name)s --save-"
"preset <preset>"
msgstr "%(name)s 还没有参数组合。创建一个：skit run %(name)s --save-preset <组合名>"

#: src/skit/cli.py:1222
msgid "Delete a named preset from a script."
msgstr "从脚本删除一个参数组合(preset)。"

#: src/skit/cli.py:1234
#, python-format
msgid "Preset \"%(preset)s\" deleted from %(name)s."
msgstr "已从 %(name)s 删除参数组合“%(preset)s”。"

#: src/skit/cli.py:1291
#, python-format
msgid "%(name)s has no managed parameters."
msgstr "%(name)s 没有纳管的参数。"

#: src/skit/cli.py:1294
msgid "Command template placeholders (the run form asks for them):"
msgstr "命令模板的占位符（运行表单会询问）："

#: src/skit/cli.py:1303
#, python-format
msgid ""
"%(name)s has no managed parameters. Use --manage to bring a detected "
"candidate under management."
msgstr "%(name)s 没有纳管的参数。用 --manage 把检测到的候选纳入管理。"

#: src/skit/cli.py:1317
