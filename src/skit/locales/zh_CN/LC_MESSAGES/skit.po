#, python-format
msgid "Reusing your last arguments: %(args)s"
msgstr "沿用上次的参数:%(args)s"

#: src/skit/cli.py:542
#, python-format
msgid "Script exited with code %(code)s"
msgstr "脚本以 exit code %(code)s 结束"

#: src/skit/cli.py:548
msgid "Manage named parameter presets for a script."
msgstr "管理脚本的具名参数 preset。"

#: src/skit/cli.py:556 src/skit/cli.py:630
msgid "Preset name"
msgstr "preset 名称"

#: src/skit/cli.py:570 src/skit/cli.py:585
#, python-format
msgid "%(name)s has no managed parameters or placeholders, so there's nothing to save."
msgstr "%(name)s 没有受管理的参数或占位符;没东西可存 preset。"

#: src/skit/cli.py:580 src/skit/cli.py:599
#, python-format
msgid "Preset \"%(preset)s\" saved for %(name)s."
msgstr "已为 %(name)s 保存 preset“%(preset)s”。"

#: src/skit/cli.py:593
#, python-format
msgid "Secret values are never stored in presets; skipped: %(names)s"
msgstr "secret 值永不存入 preset;已跳过:%(names)s"

#: src/skit/cli.py:617
#, python-format
msgid "No presets for %(name)s yet. Create one with: skit preset save %(name)s <preset>"
msgstr "%(name)s 没有任何 preset。创建:skit preset save %(name)s <preset>"

#: src/skit/cli.py:640
#, python-format
msgid "Preset \"%(preset)s\" deleted from %(name)s."
msgstr "已从 %(name)s 删除 preset“%(preset)s”。"

#: src/skit/cli.py:673 src/skit/cli.py:691 src/skit/cli.py:812
#, python-format
msgid "%(name)s has no managed parameters. Re-add the script or edit its [tool.skit] block to define some."
msgstr "%(name)s 没有受管理的参数。重新 add 或手动编辑其 [tool.skit] 区块即可定义。"

#: src/skit/cli.py:678
msgid "Command template placeholders (you'll be asked on each run):"
msgstr "命令模板占位符(每次运行时询问):"

