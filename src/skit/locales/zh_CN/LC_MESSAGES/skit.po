#: src/skit/analysis.py:116
#, python-format
msgid "The parameter definitions for %(name)s have drifted from the script:"
msgstr "%(name)s 的参数定义与脚本内容已漂移:"

#: src/skit/analysis.py:125
#, python-brace-format, python-format
msgid "%(name)s is no longer read from the environment (its ${...:-default} was removed or overridden by a plain assignment) — your value would be silently ignored. Re-add or resync."
msgstr "%(name)s 不再从环境变量读取(其 ${...:-default} 已被删除,或被普通赋值覆盖)——你设置的值会被悄悄忽略。请重新添加或执行 resync。"

#: src/skit/analysis.py:135
#, python-format
msgid "%(name)s: injection target no longer exists (dropped from this run's form)"
msgstr "%(name)s:找不到注入目标(已从本次表单剔除)"

#: src/skit/analysis.py:143
#, python-format
msgid "%(name)s: type changed from %(old)s to %(new)s in the source (still injected — double-check the value)"
msgstr "%(name)s:源码中的类型已从 %(old)s 变为 %(new)s(仍会注入,请确认值)"

#: src/skit/analysis.py:151
#, python-format
msgid "%(name)s: its prompt no longer matches a unique input/read call; falling back to position (still injected — double-check this lands on the right question, especially if it's a secret)"
msgstr "%(name)s:其提示文字已无法对应到唯一的 input/read 调用;改以位置对应(仍会注入——请再次确认其对应到正确的问题,尤其是机密参数)"

#: src/skit/analysis.py:159
#, python-format
msgid "To refresh the definitions, run: skit params %(name)s --resync"
msgstr "若要更新定义,请运行:skit params %(name)s --resync"

#: src/skit/analysis.py:173
#, python-format
msgid "%(name)s isn't a managed parameter; skipped."
msgstr "%(name)s 不是受管理的参数;已跳过。"

#: src/skit/analysis.py:174
#, python-format
msgid "Dropped %(name)s: it no longer exists in the script."
msgstr "已剔除 %(name)s:脚本中已找不到。"

#: src/skit/analysis.py:175
#, python-format
msgid "%(name)s is already managed; skipped."
msgstr "%(name)s 已在管理中;已跳过。"

#: src/skit/analysis.py:177
#, python-format
msgid "%(name)s isn't a detectable parameter in the current script; skipped."
msgstr "%(name)s 在当前脚本中检测不到;已跳过。"

#: src/skit/analysis.py:180
msgid "Could not parse the script (syntax error); resync skipped. Parameter definitions are unchanged."
msgstr "无法解析脚本(语法错误);已跳过重新同步。参数定义保持不变。"

#: src/skit/analysis.py:184
#, python-format
msgid "%(name)s: re-anchored to its current position after its prompt stopped matching uniquely; double-check the prompt/secret assignment is still correct."
msgstr "%(name)s:因提示文字无法唯一对应,已重新锚定到其当前位置;请再次确认提示文字/机密设置仍然正确。"

#: src/skit/cli.py:65
msgid "skit — a script launcher and parameter manager. Run it without a subcommand to open the main menu."
msgstr "skit — 脚本启动器 + 参数管家。不带子命令运行即进入主菜单。"

#: src/skit/cli.py:130
msgid "Script name or slug"
msgstr "脚本名称或 slug"

#: src/skit/cli.py:137
msgid "Show version"
msgstr "显示版本"

#: src/skit/cli.py:169
#, python-format
msgid "The script declares its own dependencies (PEP 723): %(deps)s"
msgstr "脚本已用 PEP 723 语法声明依赖：%(deps)s"

#: src/skit/cli.py:202 src/skit/cli.py:267
msgid "Dependencies to install (Enter to accept, edit the list, or '-' for none)"
msgstr "要安装的依赖(Enter 采用,可自行编辑,或输入 - 表示不需要)"

#: src/skit/cli.py:216
msgid "Python version (Enter accepts the #! pin, '-' for automatic)"
msgstr "Python 版本(Enter 采用 #! 指定的版本,'-' = 自动)"

#: src/skit/cli.py:218
msgid "Python version (leave empty for automatic)"
msgstr "Python 版本(留空 = 自动)"

#: src/skit/cli.py:232
#, python-format
msgid "The #! line pins a python version — recording requires-python %(pin)s (change it with --python)."
msgstr "#! 行指定了 python 版本——记录 requires-python %(pin)s（可用 --python 更改）。"

#: src/skit/cli.py:293
msgid "Reference-mode entries take no managed dependencies — they run from their own project. Add it as a copy, or drop --dep."
msgstr "reference 模式条目不受理依赖管理——它从自己的项目运行。以复制模式加入，或去掉 --dep。"

#: src/skit/cli.py:296
#, python-format
msgid "%(kind)s entries don't take package dependencies — drop --dep."
msgstr "%(kind)s 条目不接受依赖包——去掉 --dep。"

#: src/skit/cli.py:303 src/skit/store.py:687
#, python-format
msgid "A Python constraint doesn't apply to %(kind)s scripts."
msgstr "Python 约束不适用于 %(kind)s 脚本。"

#: src/skit/cli.py:315 src/skit/cli.py:669 src/skit/cli.py:1069
#: src/skit/cli.py:1546
msgid "Name in skit"
msgstr "在 skit 里的名称"

#: src/skit/cli.py:318 src/skit/cli.py:1552
msgid "Description (optional)"
msgstr "描述(可留空)"

#: src/skit/cli.py:338 src/skit/cli.py:344 src/skit/store.py:222
#: src/skit/store.py:323 src/skit/store.py:386 src/skit/store.py:522
#: src/skit/tui_add.py:301
#, python-format
msgid "File not found: %(path)s"
msgstr "找不到文件：%(path)s"

#: src/skit/cli.py:373 src/skit/cli.py:987 src/skit/tui_add.py:1194
msgid " (secret)"
msgstr " (机密)"

#: src/skit/cli.py:377
#, python-format
msgid "%(num)s. %(name)s (%(type)s) = %(value)s%(secret)s"
msgstr "%(num)s. %(name)s(%(type)s)= %(value)s%(secret)s"

#: src/skit/cli.py:389
#, python-format
msgid "%(num)s. input() #%(ordinal)s: %(prompt)s%(secret)s"
msgstr "%(num)s. input() 第 %(ordinal)s 个:%(prompt)s%(secret)s"

#: src/skit/cli.py:394
msgid "⚠ looks like a loop accumulator — probably not a parameter"
msgstr "⚠ 看起来是循环的累加变量，多半不是参数"

#: src/skit/cli.py:407 src/skit/tui_add.py:901
msgid "This script reads command-line arguments; the run form has an extra-arguments field for them."
msgstr "这个脚本会吃命令行参数；运行表单里有「额外参数」栏可以填。"

#: src/skit/cli.py:416
#, python-format
msgid "💡 %(names)s are written directly inside the code, so skit can't turn them into form fields. To manage one, first give it a name at the top of the script, e.g. OUTPUT = '…' (skit edit %(script)s)."
msgstr "💡 %(names)s 直接写在代码里，skit 没法把它们变成表单字段。想管理其中一个，先在脚本开头给它取个名字，例如 OUTPUT = '…'（skit edit %(script)s）。"

#: src/skit/cli.py:437 src/skit/tui_add.py:847
#, python-format
msgid "✓ skit read this script's own arguments (%(count)s field). Running it opens a form — nothing to memorize."
msgid_plural "✓ skit read this script's own arguments (%(count)s fields). Running it opens a form — nothing to memorize."
msgstr[0] "✓ skit 看懂了这个脚本自己的参数（共 %(count)s 项）。运行时会打开表单——不用背任何命令。"

#: src/skit/cli.py:447 src/skit/tui_add.py:862
#, python-format
msgid "This script parses its own arguments (%(names)s); skit couldn't model them statically, so the run form offers an extra-arguments field."
msgstr "这个脚本自己解析参数（%(names)s）；skit 无法静态读懂它们，运行表单会提供「额外参数（原样传给脚本）」栏。"

#: src/skit/cli.py:473 src/skit/cli.py:531
#, python-format
msgid "Found %(count)s parameter candidate (constants / input() calls):"
msgid_plural "Found %(count)s parameter candidates (constants / input() calls):"
msgstr[0] "找到 %(count)s 个候选参数(写死的常量 / input() 调用):"

#: src/skit/cli.py:482 src/skit/cli.py:540
msgid "Which ones should skit manage? (e.g. 1,3 / all / none)"
msgstr "哪些交给 skit 管理?(编号如 1,3 / all / none)"

#: src/skit/cli.py:501
msgid "Reference mode never touches the original file, so parameter setup was skipped."
msgstr "reference 模式绝不改动原文件;跳过参数设置。"

#: src/skit/cli.py:616
#, python-format
msgid "The draft's #! names no interpreter skit knows — add it with: skit add %(path)s --kind <language>"
msgstr "草稿的 #! 指定了 skit 不认识的解释器——请用以下命令添加:skit add %(path)s --kind <语言>"

#: src/skit/cli.py:629
#, python-format
msgid "--dep/--python are python flags, but the draft's shebang names %(kind)s — drop them, or keep the python shebang."
msgstr "--dep/--python 是 python 专用标志，但草稿的 shebang 指定的是 %(kind)s——去掉它们，或改回 python shebang。"

#: src/skit/cli.py:657
msgid "--edit opens your editor, which --no-input forbids — pipe the script in instead: skit add - -n NAME"
msgstr "--edit 会打开你的编辑器，而 --no-input 禁止这么做——请改用管道把脚本传进来：skit add - -n NAME"

#: src/skit/cli.py:665
msgid "Writing a new script in an editor needs an interactive terminal."
msgstr "用编辑器新建脚本需要交互式终端。"

#: src/skit/cli.py:671 src/skit/cli.py:1071 src/skit/store.py:777
#: src/skit/tui_add.py:373 src/skit/tui_runner.py:125
msgid "A name is required."
msgstr "必须提供名称。"

#: src/skit/cli.py:682 src/skit/cli.py:1080 src/skit/store.py:595
#, python-format
msgid "The name %(name)s is already taken — pick another name."
msgstr "名称 %(name)s 已被占用——请换一个名称。"

#: src/skit/cli.py:694 src/skit/cli.py:1093
msgid "Opening your editor…"
msgstr "正在打开编辑器…"

#: src/skit/cli.py:699 src/skit/cli.py:1098 src/skit/tui_add.py:446
msgid "Nothing was written, so no script was added."
msgstr "没有写入任何内容,因此没有加入脚本。"

#: src/skit/cli.py:769 src/skit/cli.py:819 src/skit/cli.py:1133
msgid "Reading the script from stdin needs an explicit --name."
msgstr "从 stdin 读脚本必须用 --name 指定名称。"

#: src/skit/cli.py:776 src/skit/cli.py:826 src/skit/cli.py:1142
msgid "Nothing arrived on stdin, so there is nothing to add."
msgstr "stdin 没有收到任何内容，没有东西可添加。"

#: src/skit/cli.py:871
msgid ""
"# New prompt\n"
"\n"
"Describe the task for the agent. Mark the parts that change per run as {{placeholders}} — each becomes a form field. Everything else travels to the agent exactly as written."
msgstr ""
"# 新提示词\n"
"\n"
"描述要交给 agent 的任务。把每次运行会变动的部分写成 {{占位符}}——每个都会成为表单字段。其余内容会原封不动送达 agent。"

#: src/skit/cli.py:893
msgid "Custom agents: skit runner add NAME COMMAND… (see skit runner --help)"
msgstr "自定义 agent:skit runner add 名称 命令…(详见 skit runner --help)"

#: src/skit/cli.py:906 src/skit/cli.py:2678
#, python-format
msgid "Unknown runner: %(runner)s. Configured runners: %(names)s"
msgstr "未知的执行器:%(runner)s。已配置的执行器:%(names)s"

#: src/skit/cli.py:920
#, python-format
msgid "Your draft was kept at %(path)s — fix the problem and add it with: skit add %(path)s"
msgstr "你的草稿保留在 %(path)s——修正问题后用以下命令加入:skit add %(path)s"

#: src/skit/cli.py:924 src/skit/tui_add.py:453 src/skit/tui_add.py:472
#, python-format
msgid "Your draft was kept at %(path)s"
msgstr "你的草稿保留在 %(path)s"

#: src/skit/cli.py:942
msgid "- = no pin (the run form asks each time)"
msgstr "- = 不固定(每次在运行表单选择)"

#: src/skit/cli.py:945 src/skit/cli.py:2262
msgid "Run this prompt with which agent?"
msgstr "用哪个执行器运行这个提示词?"

#: src/skit/cli.py:975 src/skit/cli.py:1675 src/skit/langs/launch.py:559
#, python-format
msgid "Can't read %(path)s: %(error)s"
msgstr "无法读取 %(path)s:%(error)s"

#: src/skit/cli.py:985
msgid "Detected placeholders (each becomes a form field):"
msgstr "检测到的占位符(每个都会成为表单字段):"

#: src/skit/cli.py:992 src/skit/tui_add.py:243
#, python-format
msgid "…and %(count)s more"
msgstr "……还有 %(count)s 个"

#: src/skit/cli.py:996
msgid "Manage which? (all / none / off / numbers like 1,3)"
msgstr "要纳管哪些?(all / none / off / 或编号如 1,3)"

#: src/skit/cli.py:1025
#, python-format
msgid "Variable insertion is off — the body travels to the agent exactly as written (turn it on with: skit params %(name)s --interpolate)"
msgstr "变量插入已关闭——正文会原封不动送达 agent(开启:skit params %(name)s --interpolate)"

#: src/skit/cli.py:1030
#, python-format
msgid "Detected %(count)s placeholders — too many to manage automatically, so none were. Manage the ones you need with: skit params %(name)s --add NAME, or turn insertion off with --no-interpolate."
msgstr "检测到 %(count)s 个占位符——数量太多,未自动纳管任何一个。需要的请用 skit params %(name)s --add 名称 纳管,或用 --no-interpolate 关闭插值。"

#: src/skit/cli.py:1034
#, python-format
msgid "Runs with %(runner)s (change it with: skit params %(name)s --runner NAME)"
msgstr "以 %(runner)s 运行(更改:skit params %(name)s --runner NAME)"

#: src/skit/cli.py:1062
msgid "--prompt with no path opens your editor, which --no-input forbids — pipe the body in instead: skit add - --prompt -n NAME"
msgstr "--prompt 未带路径时会打开你的编辑器，而 --no-input 禁止这么做——请改用管道把正文传进来：skit add - --prompt -n NAME"

#: src/skit/cli.py:1193
#, python-format
msgid "Unknown kind: %(kind)s. Choose from: %(kinds)s"
msgstr "未知类型：%(kind)s。可选：%(kinds)s"

#: src/skit/cli.py:1199
msgid "Add a script, executable, or command to skit."
msgstr "把脚本、可执行文件或命令加入 skit。"

#: src/skit/cli.py:1201
#, python-brace-format
msgid "Examples:  skit add tools/resize.py  ·  skit add --cmd 'ffmpeg -i {input}' -n convert  ·  pbpaste | skit add - -n clip"
msgstr "例：skit add tools/resize.py · skit add --cmd 'ffmpeg -i {input}' -n convert · pbpaste | skit add - -n clip"

#: src/skit/cli.py:1206
msgid "Path to a script or executable, or '-' to read a script from stdin"
msgstr "脚本或可执行文件路径；「-」表示从 stdin 读脚本"

#: src/skit/cli.py:1209
msgid "Name / alias (defaults to the file name)"
msgstr "名称 / alias(默认用文件名)"

#: src/skit/cli.py:1215
msgid "Description (defaults to the first line of the docstring)"
msgstr "描述(默认取 docstring 首行)"

#: src/skit/cli.py:1218
msgid "Write a brand-new script in your editor, then add it"
msgstr "在编辑器里新写一支脚本,再加入 skit"

#: src/skit/cli.py:1223
msgid "Reference mode: link to the original file instead of copying it"
msgstr "reference 模式:不复制,链接原文件"

#: src/skit/cli.py:1228
msgid "Force the executable kind (normally inferred from the file itself)"
msgstr "强制当作可执行文件（一般会自动判断）"

#: src/skit/cli.py:1233
msgid "Force the language kind (e.g. shell, js) for an extensionless file"
msgstr "强制指定语言类型（如 shell、js），用于没有扩展名的文件"

#: src/skit/cli.py:1236
#, python-brace-format
msgid "Register a command template, e.g. --cmd 'ffmpeg -i {input}'"
msgstr "登记命令模板,如 --cmd 'ffmpeg -i {input}'"

#: src/skit/cli.py:1242
msgid "Add the file as a prompt for an AI agent (with no path: draft one in your editor)"
msgstr "将文件添加为 AI agent 的提示词(不给路径则在编辑器中撰写新的)"

#: src/skit/cli.py:1248
msgid "Pin the agent a prompt entry runs with (see skit runner list)"
msgstr "固定提示词条目使用的执行器(见 skit runner list)"

#: src/skit/cli.py:1254
msgid "Prompt only: no variable insertion at all — the body travels exactly as written"
msgstr "仅提示词:完全不做变量插入——正文原封不动送达"

#: src/skit/cli.py:1260
msgid "A dependency (repeat for more; skips the interactive question)"
msgstr "一项依赖（可重复；会跳过交互询问）"

#: src/skit/cli.py:1263 src/skit/cli.py:3940
msgid "Python version constraint, e.g. \">=3.11\""
msgstr "Python 版本约束,如 \">=3.11\""

#: src/skit/cli.py:1266
msgid "Never prompt; accept the detected suggestions"
msgstr "从不询问;直接采用检测到的建议"

#: src/skit/cli.py:1276
msgid "--prompt names the kind outright — drop --edit/--exe/--kind/--cmd."
msgstr "--prompt 已直接指定类型——请去掉 --edit/--exe/--kind/--cmd。"

#: src/skit/cli.py:1289
msgid "stdin ('-')"
msgstr "stdin（'-'）"

#: src/skit/cli.py:1290
msgid "a file path"
msgstr "文件路径"

#: src/skit/cli.py:1298
#, python-format
msgid "%(flags)s each pick a different way to add — use exactly one (nothing was added)."
msgstr "%(flags)s 各自代表一种不同的添加方式——请只用其中一种（未添加任何内容）。"

#: src/skit/cli.py:1339
msgid "a --cmd template takes only --name/--description"
msgstr "--cmd 模板只接受 --name/--description"

#: src/skit/cli.py:1342
msgid "stdin authors a brand-new copy, and --ref/--exe need an existing file"
msgstr "stdin 会撰写一份全新副本，而 --ref/--exe 需要现成的文件"

#: src/skit/cli.py:1344
msgid "--edit drafts a fresh script: its kind comes from the shebang you write (e.g. #!/usr/bin/env bash), --ref/--exe need an existing file, and a prompt is drafted with skit add --prompt"
msgstr "--edit 会起草一个全新脚本：它的类型取自你写的 shebang（例如 #!/usr/bin/env bash），--ref/--exe 需要现成的文件，而提示词要用 skit add --prompt 起草"

#: src/skit/cli.py:1349
msgid "a drafted prompt takes only --name/--description/--runner/--no-interpolate"
msgstr "草稿提示词只接受 --name/--description/--runner/--no-interpolate"

#: src/skit/cli.py:1357
#, python-format
msgid "%(flags)s can't apply here — %(hint)s (nothing was added)."
msgstr "%(flags)s 在这里无法应用——%(hint)s(未添加任何内容)。"

#: src/skit/cli.py:1370 src/skit/cli.py:1531
msgid "--no-interpolate only applies to prompt entries — add one with --prompt."
msgstr "--no-interpolate 只适用于提示词条目——用 --prompt 添加一个。"

#: src/skit/cli.py:1375 src/skit/cli.py:1526
msgid "--runner only applies to prompt entries — add one with --prompt."
msgstr "--runner 只适用于提示词条目——用 --prompt 添加一个。"

#: src/skit/cli.py:1389
msgid "--dep/--python are script flags — a prompt has no dependencies."
msgstr "--dep/--python 是脚本标志——提示词没有依赖。"

#: src/skit/cli.py:1398
msgid "--runner/--no-interpolate only apply to prompt entries — pipe one with --prompt."
msgstr "--runner/--no-interpolate 只适用于提示词条目——用 --prompt 以管道传入一个。"

#: src/skit/cli.py:1406
msgid "--exe needs an existing program on disk — stdin and the editor author scripts."
msgstr "--exe 需要磁盘上既有的程序——stdin 与编辑器用来编写脚本。"

#: src/skit/cli.py:1423
msgid "The piped text's #! names no interpreter skit knows — pass --kind <language> to choose one."
msgstr "管道文本的 #! 指定了 skit 不认识的解释器——请用 --kind <语言> 指定一个。"

#: src/skit/cli.py:1436
#, python-format
msgid "--dep/--python don't apply to a %(kind)s entry (piped text's kind)."
msgstr "--dep/--python 不适用于 %(kind)s 条目(管道文本的种类)。"

#: src/skit/cli.py:1456
msgid "A --cmd entry needs a --name"
msgstr "--cmd 条目必须指定 --name"

#: src/skit/cli.py:1463
#, python-format
msgid "Detected parameters: %(names)s (the run form asks for them; your last values are remembered)"
msgstr "检测到参数：%(names)s（运行表单会询问；会记住你上次的值）"

#: src/skit/cli.py:1470
msgid "Provide a script path, or use --cmd to register a command template"
msgstr "请提供脚本路径,或用 --cmd 登记命令模板"

#: src/skit/cli.py:1485
#, python-format
msgid "%(file)s is one of skit's own kept drafts — a resumed draft is always added as a copy (and consumed on success). Drop --ref."
msgstr "%(file)s 是 skit 自己保留的草稿——恢复草稿一律以副本加入(成功后即消耗),请去掉 --ref。"

#: src/skit/cli.py:1499
msgid "Use --kind or --exe, not both."
msgstr "--kind 与 --exe 只能择一。"

