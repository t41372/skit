#: src/skit/cli.py:35
msgid "skit — a script launcher and parameter manager. Run it without a subcommand to open the main menu."
msgstr "skit — 脚本启动器 + 参数管家。不带子命令运行即进入主菜单。"

#: src/skit/cli.py:47
msgid "Show version"
msgstr "显示版本"

#: src/skit/cli.py:72
#, python-format
msgid "PEP 723 metadata found: %(deps)s"
msgstr "检测到 PEP 723 metadata:%(deps)s"

#: src/skit/cli.py:83
msgid "Dependencies (comma separated; leave empty for none)"
msgstr "依赖(逗号分隔,留空表示不需要)"

#: src/skit/cli.py:89
msgid "Python version (leave empty for automatic)"
msgstr "Python 版本(留空 = 自动)"

#: src/skit/cli.py:138
#, python-format
msgid "This script already parses its own arguments (%(names)s). Pass them straight through instead: skit run %(name)s -- <args>"
msgstr "这个脚本已自带参数解析(%(names)s)。直接透传参数即可:skit run %(name)s -- <args>"

#: src/skit/cli.py:148
#, python-format
msgid "Found %(count)s parameter candidate (constants / input() calls):"
msgid_plural "Found %(count)s parameter candidates (constants / input() calls):"
msgstr[0] "找到 %(count)s 个候选参数(写死常量 / input() 调用):"

#: src/skit/cli.py:154
msgid " (secret)"
msgstr " (secret)"

#: src/skit/cli.py:160
#, python-format
msgid "%(num)s. %(name)s (%(type)s) = %(value)s%(secret)s"
msgstr "%(num)s. %(name)s(%(type)s)= %(value)s%(secret)s"

#: src/skit/cli.py:172
#, python-format
msgid "%(num)s. input() #%(ordinal)s: %(prompt)s%(secret)s"
msgstr "%(num)s. input() 第 %(ordinal)s 个:%(prompt)s%(secret)s"

#: src/skit/cli.py:176
msgid "Which ones should skit manage? (e.g. 1,3 / all / none)"
msgstr "哪些交给 skit 管理?(编号如 1,3 / all / none)"

#: src/skit/cli.py:186
msgid "Path to a Python script or executable"
msgstr "Python 脚本或可执行文件路径"

#: src/skit/cli.py:188
msgid "Name / alias (defaults to the file name)"
msgstr "名称 / alias(默认用文件名)"

#: src/skit/cli.py:194
msgid "Description (defaults to the first line of the docstring)"
msgstr "描述(默认取 docstring 首行)"

#: src/skit/cli.py:199
msgid "Reference mode: link to the original file instead of copying it"
msgstr "reference 模式:不复制,链接原文件"

#: src/skit/cli.py:201
msgid "Register as an executable entry"
msgstr "登记为可执行文件条目"

#: src/skit/cli.py:203
#, python-brace-format
msgid "Register a command template, e.g. --cmd 'ffmpeg -i {input}'"
msgstr "登记命令模板,如 --cmd 'ffmpeg -i {input}'"

#: src/skit/cli.py:208
msgid "Dependencies, comma separated (skips the interactive question)"
msgstr "依赖列表,逗号分隔(跳过交互询问)"

