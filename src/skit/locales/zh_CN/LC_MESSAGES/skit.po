#, python-format
msgid "Presets: %(names)s"
msgstr "参数组合:%(names)s"

#: src/skit/cli.py:2415 src/skit/cli.py:3673 src/skit/cli.py:3878
msgid "Parameter"
msgstr "参数"

#: src/skit/cli.py:2416 src/skit/cli.py:3675 src/skit/cli.py:3880
msgid "Type"
msgstr "类型"

#: src/skit/cli.py:2417
msgid "Required"
msgstr "必填"

#: src/skit/cli.py:2418 src/skit/cli.py:3676 src/skit/cli.py:3881
