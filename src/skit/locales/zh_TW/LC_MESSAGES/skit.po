msgstr "沒有表單欄位——接在 -- 之後的參數會附加到指令末尾。"

#: src/skit/cli.py:2414
msgid "No form fields — arguments after -- pass straight through to the script."
msgstr "沒有表單欄位——接在 -- 之後的參數會透傳給腳本。"

#: src/skit/cli.py:2419
#, python-format
msgid "Presets: %(names)s"
msgstr "參數組合:%(names)s"

#: src/skit/cli.py:2428 src/skit/cli.py:3716 src/skit/cli.py:3929
msgid "Parameter"
msgstr "參數"

#: src/skit/cli.py:2429 src/skit/cli.py:3718 src/skit/cli.py:3931
msgid "Type"
msgstr "型別"

#: src/skit/cli.py:2430
msgid "Required"
msgstr "必填"

#: src/skit/cli.py:2431 src/skit/cli.py:3719 src/skit/cli.py:3932
msgid "Default"
msgstr "預設值"

#: src/skit/cli.py:2432
msgid "Choices"
msgstr "可選值"

#: src/skit/cli.py:2433 src/skit/cli.py:3720 src/skit/cli.py:3933
msgid "Secret"
msgstr "機密"

