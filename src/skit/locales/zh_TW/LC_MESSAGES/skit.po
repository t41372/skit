msgstr "--set 指定了未知參數：%(names)s。此條目的參數：%(valid)s"

#: src/skit/cli.py:2826
#, python-format
msgid "Parameters for %(name)s (press Enter to keep the value shown):"
msgstr "%(name)s 的參數(按 Enter 沿用顯示的值):"

#: src/skit/cli.py:2869 src/skit/cli.py:4366
msgid "--runner only applies to prompt entries."
msgstr "--runner 只適用於提示詞項目。"

#: src/skit/cli.py:2889 src/skit/cli.py:3268 src/skit/cli.py:3300
#: src/skit/langs/launch.py:586
msgid "No agents are configured. Add one with: skit runner add mycli -- mycli run {{prompt}}"
msgstr "尚未設定任何執行器。請新增一個：skit runner add mycli -- mycli run {{prompt}}"

#: src/skit/cli.py:2897 src/skit/langs/launch.py:592
#, python-format
msgid "No runner selected for %(name)s. Pass --runner NAME, or pin one with: skit params %(name)s --runner NAME"
msgstr "%(name)s 尚未選擇執行器。請帶上 --runner NAME,或釘選一個:skit params %(name)s --runner NAME"

#: src/skit/cli.py:2907 src/skit/cli.py:3099 src/skit/cli.py:4373
#: src/skit/langs/launch.py:601
#, python-format
msgid "The runner %(runner)s isn't configured (known: %(names)s). Manage runners with: skit runner list"
msgstr "執行器 %(runner)s 未設定(已知:%(names)s)。管理執行器:skit runner list"

#: src/skit/cli.py:2919
msgid "Run a registered entry in the terminal."
msgstr "在終端機執行已登記的項目。"

#: src/skit/cli.py:2921
msgid "Examples:  skit run stitch  ·  skit run stitch -p web -- extra.png  ·  skit run stitch --set width=800 --no-input  ·  skit run stitch --dry-run"
msgstr "例:skit run stitch · skit run stitch -p web -- extra.png · skit run stitch --set width=800 --no-input · skit run stitch --dry-run"

#: src/skit/cli.py:2926
msgid "Arguments passed through after --"
msgstr "接在 -- 之後傳入的參數"

#: src/skit/cli.py:2928
msgid "Never prompt; reuse last values and defaults"
msgstr "永不詢問;沿用上次的值 / 預設值"

#: src/skit/cli.py:2934
msgid "Named preset of parameter values to prefill the form with"
msgstr "用哪個參數組合(preset)預填表單"

#: src/skit/cli.py:2941
#, python-brace-format
msgid "Set a parameter value by name, as NAME=VALUE (repeatable; values may use tokens like {cwd} or {env:VAR}; the form no longer asks for a field you set)"
msgstr "直接以 NAME=VALUE 指定參數值(可重複;值可用 {cwd}、{env:VAR} 等代換符;已指定的欄位表單不再詢問)"

#: src/skit/cli.py:2945
msgid "Save this run's values as a named preset"
msgstr "把這次的值存成參數組合"

#: src/skit/cli.py:2948
msgid "Line-by-line prompts instead of the inline form"
msgstr "用逐行問答取代迷你表單"

#: src/skit/cli.py:2954
msgid "Skip the parameter form and injection and run the script as-is (escape hatch)"
msgstr "跳過參數表單與注入,原樣執行腳本(逃生門)"

#: src/skit/cli.py:2961
msgid "Print the exact command that would run (tokens and globs expanded), then exit"
msgstr "印出實際會執行的完整命令（token 與萬用字元已展開）後結束"

#: src/skit/cli.py:2967
msgid "Run a prompt entry with this agent (overrides its pin for one run)"
msgstr "以此執行器執行提示詞項目(僅本次執行,覆蓋其釘選)"

#: src/skit/cli.py:2974
msgid "Forget the remembered extra arguments before this run (they are otherwise reused when you pass none)"
msgstr "在本次執行前忘掉記住的額外參數(未傳入任何參數時,原本會沿用它們)"

#: src/skit/cli.py:2991
msgid "--raw runs the script as-is; --set, --preset, and --save-preset do not apply."
msgstr "--raw 會原樣執行腳本;--set、--preset、--save-preset 都不適用。"

#: src/skit/cli.py:3006
msgid "--raw doesn't apply to a prompt entry: its {{placeholders}} are the artifact itself — there is no as-is without them."
msgstr "--raw 不適用於 prompt 條目:它的 {{placeholders}} 本身就是產出物——沒有它們就沒有「原樣」可言。"

#: src/skit/cli.py:3011
#, python-brace-format, python-format
msgid "--raw doesn't apply to a %(kind)s entry: its {placeholders} are the artifact itself — there is no as-is without them."
msgstr "--raw 不適用於 %(kind)s 條目：它的 {placeholders} 本身就是產出物——沒有它們就沒有「原樣」可言。"

#: src/skit/cli.py:3038
msgid "Raw mode: skipping the parameter form and injection."
msgstr "raw 模式:已跳過參數表單與注入。"

#: src/skit/cli.py:3052 src/skit/cli.py:3550 src/skit/tui_form.py:935
#, python-format
msgid "%(name)s has no form fields, so there's nothing to save."
msgstr "%(name)s 沒有表單欄位，沒有東西可存。"

#: src/skit/cli.py:3132
#, python-format
msgid "Reusing your last arguments: %(args)s"
msgstr "沿用上次的參數:%(args)s"

#: src/skit/cli.py:3159 src/skit/cli.py:3605
#, python-format
msgid "Preset \"%(preset)s\" saved for %(name)s."
msgstr "已為 %(name)s 儲存參數組合「%(preset)s」。"

#: src/skit/cli.py:3215
#, python-format
msgid "Run exited with code %(code)s"
msgstr "本次執行以結束碼 %(code)s 結束"

#: src/skit/cli.py:3225
msgid "Manage the agents (runners) that prompt entries run with."
msgstr "管理提示詞項目使用的執行器(AI agent)。"

#: src/skit/cli.py:3232
msgid "List the configured runners (seeds them into config on first use)."
msgstr "列出已設定的執行器(首次使用時會寫入設定檔)。"

#: src/skit/cli.py:3239
msgid "Include malformed raw rows and their repair indexes"
msgstr "包含格式錯誤的原始列及其修復索引"

#: src/skit/cli.py:3276
msgid "Row"
msgstr "列"

#: src/skit/cli.py:3277 src/skit/cli.py:3308
msgid "Runner"
msgstr "執行器"

#: src/skit/cli.py:3278 src/skit/cli.py:3309 src/skit/kindnames.py:29
msgid "Command"
msgstr "指令"

#: src/skit/cli.py:3279
msgid "Status"
msgstr "狀態"

#: src/skit/cli.py:3282
msgid "container"
msgstr "容器"

#: src/skit/cli.py:3316
msgid "The built-in amp preset uses amp -x and runs the prompt once; it does not open an interactive session."
msgstr "內建 amp 預設使用 amp -x，只執行提示詞一次；它不會開啟互動工作階段。"

#: src/skit/cli.py:3333
msgid "A runner needs a command — e.g. skit runner add mycli mycli run {{prompt}}"
msgstr "執行器需要一條命令——例如 skit runner add mycli mycli run {{prompt}}"

#: src/skit/cli.py:3336
msgid "A runner command must contain the {{prompt}} slot exactly once — that's where the rendered prompt lands."
msgstr "執行器命令必須恰好包含一個 {{prompt}} 槽位——渲染後的提示詞就放在那裡。"

#: src/skit/cli.py:3340 src/skit/config.py:614 src/skit/tui_runner.py:42
msgid "{{prompt}} can't be the command itself — the first word must be the program to run."
msgstr "{{prompt}} 不能是命令本身——第一個詞必須是要執行的程式。"

#: src/skit/cli.py:3343 src/skit/config.py:617 src/skit/tui_runner.py:45
msgid "Runner commands take only the {{prompt}} slot — single-brace text is literal, and other {{holes}} aren't supported."
msgstr "執行器命令只接受 {{prompt}} 槽位——單大括號是字面文字,其他 {{佔位符}} 不支援。"

#: src/skit/cli.py:3352
msgid "Register a runner: skit runner add NAME COMMAND… ({{prompt}} marks where the rendered prompt goes; each shell word becomes one argument, no shell involved)"
msgstr "註冊執行器:skit runner add 名稱 命令…({{prompt}} 標記渲染後提示詞的位置;每個 shell 詞就是一個參數,不經過 shell)"

#: src/skit/cli.py:3361
msgid "Runner name (e.g. claude)"
msgstr "執行器名稱(例如 claude)"

#: src/skit/cli.py:3363
msgid "The command, word by word, with one {{prompt}} slot"
msgstr "命令,逐詞給出,含一個 {{prompt}} 槽位"

#: src/skit/cli.py:3368
msgid "Replace the runner if the name already exists (the edit path)"
msgstr "名稱已存在時取代該執行器(編輯路徑)"

#: src/skit/cli.py:3383
#, python-format
msgid "The runner %(name)s already exists — pass --force to replace its command."
msgstr "執行器 %(name)s 已存在——加上 --force 以取代其命令。"

#: src/skit/cli.py:3391
#, python-format
msgid "Runner %(name)s updated: %(command)s"
msgstr "已更新執行器 %(name)s：%(command)s"

#: src/skit/cli.py:3395
#, python-format
msgid "Runner %(name)s added: %(command)s"
msgstr "已新增執行器 %(name)s:%(command)s"

#: src/skit/cli.py:3399
msgid "Remove a configured runner."
msgstr "移除已設定的執行器。"

#: src/skit/cli.py:3402
msgid "Runner name"
msgstr "執行器名稱"

#: src/skit/cli.py:3407
msgid "Remove one raw row index from 'runner list --all' (or 'container')"
msgstr "移除「runner list --all」中的一個原始列索引（或「container」）"

#: src/skit/cli.py:3410
msgid "Never prompt"
msgstr "絕不提示"

#: src/skit/cli.py:3413
msgid "Pass exactly one runner name or --row INDEX."
msgstr "請只傳一個執行器名稱或 --row INDEX。"

#: src/skit/cli.py:3433 src/skit/cli.py:3437
msgid "--row must be a non-negative index or 'container'."
msgstr "--row 必須是非負索引或「container」。"

#: src/skit/cli.py:3442
#, python-format
msgid "Unknown runner row: %(row)s. Inspect with: skit runner list --all"
msgstr "未知執行器列：%(row)s。請用 skit runner list --all 檢查"

#: src/skit/cli.py:3450
#, python-format
msgid "Runner row %(row)s is valid. Remove the agent by name instead: skit runner remove \"%(name)s\""
msgstr "執行器第 %(row)s 列有效。請改用名稱移除代理：skit runner remove \"%(name)s\""

#: src/skit/cli.py:3459 src/skit/tui_runner.py:315
msgid "Remove the malformed prompt runner container?"
msgstr "要移除格式錯誤的提示詞執行器容器嗎？"

#: src/skit/cli.py:3461
#, python-format
msgid "Remove runner row %(row)d (\"%(name)s\")?"
msgstr "要移除執行器列 %(row)d（「%(name)s」）嗎？"

#: src/skit/cli.py:3474 src/skit/tui_runner.py:321
#, python-format
msgid "Remove the agent \"%(name)s\"?"
msgstr "要移除 agent「%(name)s」嗎？"

#: src/skit/cli.py:3484 src/skit/tui_runner.py:326
#, python-format
msgid "%(count)d prompt pins this runner and will need another runner before it can run again."
msgid_plural "%(count)d prompts pin this runner and will need another runner before they can run again."
msgstr[0] "有 %(count)d 個提示詞釘選此執行器；再次執行前需要選擇另一個執行器。"

#: src/skit/cli.py:3493
msgid "Confirmation is required; pass --yes to remove the runner."
msgstr "需要確認；請傳 --yes 以移除執行器。"

#: src/skit/cli.py:3508
msgid "The runner row changed before it could be removed; inspect again."
msgstr "執行器列在移除前已發生變更；請重新檢查。"

#: src/skit/cli.py:3511
#, python-format
msgid "Runner %(name)s removed."
msgstr "已移除執行器 %(name)s。"

#: src/skit/cli.py:3514
msgid "Malformed prompt runner container removed."
msgstr "已移除格式錯誤的提示詞執行器容器。"

#: src/skit/cli.py:3517
#, python-format
msgid "Malformed runner row %(row)d removed."
msgstr "已移除格式錯誤的執行器第 %(row)d 列。"

#: src/skit/cli.py:3526
msgid "Manage named parameter presets for an entry."
msgstr "管理條目的具名參數組合（preset）。"

#: src/skit/cli.py:3531
msgid "Save a set of parameter values as a named preset."
msgstr "把一組參數值儲存成參數組合(preset)。"

#: src/skit/cli.py:3534 src/skit/cli.py:3639 src/skit/tui_form.py:343
msgid "Preset name"
msgstr "組合名稱"

#: src/skit/cli.py:3538
msgid "Save the last run's values without asking (automation-friendly)"
msgstr "直接存上次執行的值，不再詢問（適合自動化）"

#: src/skit/cli.py:3558 src/skit/cli.py:3574
#, python-format
msgid "%(name)s has no remembered values yet — run it once first."
msgstr "%(name)s 還沒有記住的值——先執行一次。"

#: src/skit/cli.py:3592
#, python-format
msgid "Secret values are never stored in presets; skipped: %(names)s"
msgstr "機密值不會存入參數組合;已略過:%(names)s"

#: src/skit/cli.py:3609
msgid "List an entry's saved presets."
msgstr "列出條目已儲存的參數組合（preset）。"

#: src/skit/cli.py:3626
#, python-format
msgid "No presets for %(name)s yet. Create one with: skit run %(name)s --save-preset <preset>"
msgstr "%(name)s 還沒有參數組合。建立一個：skit run %(name)s --save-preset <組合名>"

#: src/skit/cli.py:3636
msgid "Delete a named preset from an entry."
msgstr "從條目刪除一個具名參數組合（preset）。"

#: src/skit/cli.py:3648
#, python-format
msgid "Preset \"%(preset)s\" deleted from %(name)s."
msgstr "已從 %(name)s 刪除參數組合「%(preset)s」。"

#: src/skit/cli.py:3703
#, python-format
msgid "default %(value)s"
msgstr "預設 %(value)s"

#: src/skit/cli.py:3705
msgid "optional"
msgstr "選填"

#: src/skit/cli.py:3707
msgid "secret"
msgstr "機密"

#: src/skit/cli.py:3717
msgid "Delivery"
msgstr "傳遞方式"

#: src/skit/cli.py:3721 src/skit/cli.py:3934
msgid "Last value"
msgstr "上次的值"

#: src/skit/cli.py:3765
#, python-format
msgid "Variable insertion is off — the body travels to the agent exactly as written. Turn it on with: skit params %(name)s --interpolate"
msgstr "變量插入已關閉——內文會原封不動送達 agent。開啟:skit params %(name)s --interpolate"

#: src/skit/cli.py:3776 src/skit/cli.py:3905 src/skit/cli.py:3914
#, python-format
msgid "%(name)s has no managed parameters."
msgstr "%(name)s 沒有管理的參數。"

#: src/skit/cli.py:3781
msgid "Prompt placeholders (the run form asks for them):"
msgstr "提示詞的佔位符(執行表單會詢問):"

#: src/skit/cli.py:3783
msgid "Command template placeholders (the run form asks for them):"
msgstr "命令模板的佔位符（執行表單會詢問）："

#: src/skit/cli.py:3790
msgid "Declared environment variables (set on the run):"
msgstr "宣告的環境變數（執行時設定）："

#: src/skit/cli.py:3813
#, python-format
msgid "No longer in the prompt (the value would be ignored): %(names)s — remove with --rm, or edit the body."
msgstr "提示詞中已不存在(其值會被忽略):%(names)s——用 --rm 移除,或編輯內文。"

#: src/skit/cli.py:3920
#, python-format
msgid "%(name)s has no managed parameters. Use --manage to bring a detected candidate under management."
msgstr "%(name)s 沒有管理的參數。用 --manage 把偵測到的候選納入管理。"

#: src/skit/cli.py:3958
#, python-format
msgid "Detected but not yet managed: %(names)s"
msgstr "偵測到但尚未管理：%(names)s"

#: src/skit/cli.py:3965
msgid "Reference mode: skit never writes the original file — manage parameters by editing its [tool.skit] block in the source directly."
msgstr "參照模式：skit 絕不寫入原始檔案——請直接編輯原始碼中的 [tool.skit] 區塊來管理參數。"

#: src/skit/cli.py:3973
#, python-format
msgid "Detected but not yet managed: %(names)s (use --manage to manage them)"
msgstr "偵測到但尚未管理：%(names)s（用 --manage 管理）"

#: src/skit/cli.py:3978
#, python-brace-format, python-format
msgid "This script locates itself ($0 / BASH_SOURCE). Injecting a constant runs it from a temporary copy, so it would see that copy path instead. Rewriting the constant as NAME=\"${NAME:-value}\" delivers the value through the environment with no copy at all — `skit params %(name)s --normalize NAME` does the rewrite for you on the stored copy."
msgstr "這個腳本會讀取自己的位置($0 / BASH_SOURCE)。注入常數時它會從臨時副本執行,因此看到的是那個副本的路徑。把常數改寫成 NAME=\"${NAME:-value}\",值就會改由環境變數傳遞,完全不產生副本——`skit params %(name)s --normalize NAME` 會在儲存的副本上幫你完成改寫。"

#: src/skit/cli.py:3997
msgid "Show or edit an entry's managed or declared parameters."
msgstr "檢視或編輯條目的管理參數或宣告參數。"

#: src/skit/cli.py:3999
msgid "Examples:  skit params resize --manage WIDTH  ·  skit params conv --add size --type size=int --deliver size=flag --flag size=--size"
msgstr "例：skit params resize --manage WIDTH · skit params conv --add size --type size=int --deliver size=flag --flag size=--size"

#: src/skit/cli.py:4007
msgid "Prune definitions that no longer match the script and refresh changed types"
msgstr "修剪已對不上腳本的定義,並更新型別已變的項"

#: src/skit/cli.py:4012
msgid "Bring a currently detected candidate under management (repeatable)"
msgstr "把當前偵測到的候選納入管理(可重複)"

#: src/skit/cli.py:4015
msgid "Drop a managed parameter (repeatable)"
msgstr "移除一個受管理的參數(可重複)"

#: src/skit/cli.py:4020
msgid "Declare a new parameter on an exe/command entry, by name (repeatable)"
msgstr "為 exe/command 條目宣告一個新參數，依名稱指定(可重複)"

#: src/skit/cli.py:4023
msgid "Remove a declared parameter, by name (repeatable)"
msgstr "移除一個宣告的參數，依名稱指定(可重複)"

#: src/skit/cli.py:4028
msgid "Set a declared parameter's type, as NAME=str|int|float|bool|choice|path"
msgstr "設定宣告參數的類型，格式 NAME=str|int|float|bool|choice|path"

#: src/skit/cli.py:4031
msgid "Set a declared parameter's default, as NAME=VALUE"
msgstr "設定宣告參數的預設值，格式 NAME=VALUE"

#: src/skit/cli.py:4036
msgid "Set a declared parameter's choices, as NAME=a,b,c (comma separated)"
msgstr "設定宣告參數的可選值，格式 NAME=a,b,c(逗號分隔)"

#: src/skit/cli.py:4042
msgid "Set how a declared parameter reaches the program, as NAME=env|flag|placeholder"
msgstr "設定宣告參數如何傳遞給程式，格式 NAME=env|flag|placeholder"

#: src/skit/cli.py:4048
msgid "Set a declared flag parameter's option, as NAME=--out (empty = positional)"
msgstr "設定宣告的 flag 參數選項，格式 NAME=--out(留空為位置參數)"

#: src/skit/cli.py:4051
msgid "Mark a declared parameter as required (repeatable)"
msgstr "把某個宣告參數標為必填(可重複)"

#: src/skit/cli.py:4054
msgid "Mark a declared parameter as optional (repeatable)"
msgstr "把某個宣告參數標為選填(可重複)"

#: src/skit/cli.py:4057
msgid "Set a declared parameter's help text, as NAME=text"
msgstr "設定宣告參數的說明文字，格式 NAME=text"

#: src/skit/cli.py:4060
msgid "Mark a managed parameter as secret (repeatable)"
msgstr "把某個受管參數標為機密(可重複)"

#: src/skit/cli.py:4065
msgid "Remove the secret mark from a managed parameter (repeatable)"
msgstr "取消某個受管參數的機密標記(可重複)"

#: src/skit/cli.py:4068
msgid "Set a parameter's form prompt, as NAME=text (repeatable)"
msgstr "以 NAME=text 設定參數的表單提示(可重複)"

#: src/skit/cli.py:4074
msgid "Read a secret parameter from an environment variable at run time, as NAME=ENVVAR (empty ENVVAR clears it; repeatable)"
msgstr "執行時從環境變數讀取機密參數，格式 NAME=ENVVAR（ENVVAR 留空表示清除；可重複）"

#: src/skit/cli.py:4081
#, python-brace-format
msgid "Shell only: rewrite a constant into the ${NAME:-default} idiom in the stored copy, so its value is delivered as an environment variable instead of a rewritten temporary copy (repeatable)"
msgstr "僅限 Shell:把常數改寫成 ${NAME:-default} 寫法(改的是倉庫副本),之後它的值就用環境變數傳遞,不必再改寫臨時副本(可重複)"

#: src/skit/cli.py:4088
msgid "Prompt only: pin the agent this prompt runs with (empty value clears the pin)"
msgstr "僅提示詞:釘選此提示詞使用的執行器(空值清除釘選)"

#: src/skit/cli.py:4096
msgid "Prompt only: turn variable insertion on/off for this prompt (off = the body travels exactly as written)"
msgstr "僅提示詞:開關此提示詞的變量插入(關閉 = 內文原封不動送達)"

#: src/skit/cli.py:4104
msgid "Set where the entry runs: origin (its own folder), store, invoke (where you run skit from), or an absolute path"
msgstr "設定項目的執行位置:origin(它自己的資料夾)、store、invoke(你執行 skit 的位置),或一個絕對路徑"

#: src/skit/cli.py:4111
#, python-brace-format
msgid "Command only: rewrite the template ({placeholders} are re-read from it)"
msgstr "僅限 command:改寫模板({placeholders} 會從中重新讀取)"

#: src/skit/cli.py:4117
msgid "Pin the interpreter/runtime an interpreted entry runs with (e.g. zsh, bun; empty value returns to automatic)"
msgstr "釘選直譯型項目使用的直譯器/執行環境(例如 zsh、bun;留空即回到自動偵測)"

#: src/skit/cli.py:4121
msgid "Output the read view as JSON"
msgstr "讀取檢視以 JSON 輸出"

#: src/skit/cli.py:4183
#, python-format
msgid "%(op)s is its own operation — run it in a separate skit params call (nothing was changed)."
msgstr "%(op)s 是獨立的操作——請在另一次 skit params 呼叫中執行（這次未變更任何內容）。"

#: src/skit/cli.py:4253
#, python-format
msgid "%(name)s manages its parameters from the script itself — use --manage / --unmanage, or edit the [tool.skit] block."
msgstr "%(name)s 由腳本自身管理參數——請使用 --manage / --unmanage，或直接編輯 [tool.skit] 區塊。"

#: src/skit/cli.py:4341
#, python-format
msgid "Template updated. Placeholders: %(names)s"
msgstr "模板已更新。佔位符:%(names)s"

#: src/skit/cli.py:4345
#, python-format
msgid "%(name)s now runs in: %(dir)s"
msgstr "%(name)s 現在於此執行:%(dir)s"

#: src/skit/cli.py:4350
#, python-format
msgid "%(name)s now runs with: %(program)s"
msgstr "%(name)s 現在以此執行:%(program)s"

#: src/skit/cli.py:4354
#, python-format
msgid "%(name)s is back to automatic interpreter detection."
msgstr "%(name)s 已回到自動偵測直譯器。"

#: src/skit/cli.py:4385
#, python-format
msgid "%(name)s now runs with %(runner)s."
msgstr "%(name)s 現在以 %(runner)s 執行。"

#: src/skit/cli.py:4389
#, python-format
msgid "Cleared the runner pin — %(name)s asks at run time."
msgstr "已清除執行器釘選——%(name)s 會在執行時詢問。"

#: src/skit/cli.py:4398
msgid "--interpolate only applies to prompt entries."
msgstr "--interpolate 只適用於提示詞項目。"

#: src/skit/cli.py:4405
#, python-format
msgid "Variable insertion is on — %(name)s fills its managed placeholders again."
msgstr "變量插入已開啟——%(name)s 會再次填入已管理的佔位符。"

#: src/skit/cli.py:4409
#, python-format
msgid "Variable insertion is off — %(name)s travels to the agent exactly as written."
msgstr "變量插入已關閉——%(name)s 會原封不動送達 agent。"

#: src/skit/cli.py:4421
#, python-format
msgid "%(name)s isn't a managed parameter; --env-source skipped."
msgstr "%(name)s 不是管理的參數；--env-source 已略過。"

#: src/skit/cli.py:4428 src/skit/cli.py:4704
#, python-format
msgid "%(name)s isn't secret; --env-source only applies to secret parameters (mark it with --secret first)."
msgstr "%(name)s 不是機密參數；--env-source 只適用於機密參數（先用 --secret 標記）。"

#: src/skit/cli.py:4477
#, python-format
msgid "%(name)s has no managed parameters — its kind has no analyzer to read them from."
msgstr "%(name)s 沒有管理的參數——它的種類沒有分析器可以讀取參數。"

#: src/skit/cli.py:4485
#, python-format
msgid "%(name)s is in reference mode, and skit never writes the original file. Edit the [tool.skit] block in the source directly."
msgstr "%(name)s 是 reference 模式;skit 絕不寫原檔。請直接改原檔的 [tool.skit] 區塊。"

#: src/skit/cli.py:4506
#, python-format
msgid "Ignored a malformed value: %(item)s (expected NAME=text)."
msgstr "已忽略格式錯誤的值：%(item)s（應為 NAME=text）。"

#: src/skit/cli.py:4545 src/skit/cli.py:4824
#, python-format
msgid "Removed previously stored plaintext value(s) for now-secret parameter(s): %(names)s"
msgstr "已移除下列剛設為機密的參數先前以明文儲存的值:%(names)s"

#: src/skit/cli.py:4552
#, python-format
msgid "Updated %(name)s. Managed parameters: %(names)s"
msgstr "已更新 %(name)s。受管理的參數:%(names)s"

#: src/skit/cli.py:4558
#, python-format
msgid "The run form now asks for the managed parameters — the script's own command-line form (%(frameworks)s) is set aside until they are removed (--unmanage)."
msgstr "執行表單現在會詢問這些管理的參數——腳本自己的命令列表單（%(frameworks)s）會先擱置，直到它們被移除（--unmanage）為止。"

#: src/skit/cli.py:4574
#, python-format
msgid "%(name)s isn't a plain constant with a literal value, so there's nothing to normalize; skipped."
msgstr "%(name)s 不是帶字面值的普通常數,沒有可以正規化的東西;已略過。"

#: src/skit/cli.py:4577
#, python-format
msgid "%(name)s is assigned more than once at the top level; normalizing it would change which value wins. Skipped."
msgstr "%(name)s 在頂層被賦值多次;正規化會改變最終生效的值。已略過。"

#: src/skit/cli.py:4580
#, python-format
msgid "%(name)s is readonly, so the script could never take a value from the environment; skipped."
msgstr "%(name)s 是 readonly,腳本永遠不可能從環境變數取值;已略過。"

#: src/skit/cli.py:4582
#, python-format
msgid "%(name)s already reads from the environment; nothing to do."
msgstr "%(name)s 已經從環境變數讀取了;無需處理。"

#: src/skit/cli.py:4584
#, python-format
msgid "%(name)s's value contains a character that can't be moved into ${...:-...} safely (one of } \" ` $ \\ or a newline); skipped — it keeps being injected into a temporary copy."
msgstr "%(name)s 的值裡有無法安全放進 ${...:-...} 的字元(} \" ` $ \\ 或換行);已略過——它會繼續用臨時副本注入。"

#: src/skit/cli.py:4588
msgid "Could not parse the script (syntax error); nothing was normalized."
msgstr "無法解析腳本(語法錯誤);沒有做任何正規化。"

#: src/skit/cli.py:4619
#, python-brace-format, python-format
msgid "%(name)s has no --normalize: it is a shell idiom (VAR=value -> VAR=\"${VAR:-value}\")."
msgstr "%(name)s 沒有 --normalize:那是 shell 的寫法(VAR=value -> VAR=\"${VAR:-value}\")。"

#: src/skit/cli.py:4627
#, python-brace-format, python-format
msgid "%(name)s is in reference mode, and skit never writes the original file. Change the line to VAR=\"${VAR:-value}\" in the source directly."
msgstr "%(name)s 是 reference 模式;skit 絕不寫原檔案。請直接把原檔案裡那行改成 VAR=\"${VAR:-value}\"。"

#: src/skit/cli.py:4646
#, python-format
msgid "%(name)s isn't valid UTF-8, so --normalize can't rewrite it safely; nothing was changed — its constants keep being injected into a temporary copy."
msgstr "%(name)s 不是有效的 UTF-8，--normalize 無法安全改寫；什麼都沒改——它的常數會繼續用臨時副本注入。"

#: src/skit/cli.py:4683
#, python-format
msgid "Normalized %(names)s in %(name)s: delivered as environment variables from now on (no temporary copy, and $0 stays your real file)."
msgstr "已正規化 %(name)s 中的 %(names)s:今後用環境變數傳值(不再寫臨時副本,$0 也仍指向你的真實檔案)。"

#: src/skit/cli.py:4693
#, python-format
msgid "%(name)s isn't a declared parameter; skipped."
msgstr "%(name)s 不是已宣告的參數，已跳過。"

#: src/skit/cli.py:4694
#, python-format
msgid "%(name)s is already declared; skipped."
msgstr "%(name)s 已經宣告過，已跳過。"

#: src/skit/cli.py:4695
#, python-format
msgid "%(name)s: that delivery isn't available for this kind; skipped."
msgstr "%(name)s：該傳遞方式不適用於此類型，已跳過。"

#: src/skit/cli.py:4697
#, python-format
msgid "%(name)s isn't a template placeholder, so it can't use placeholder delivery; skipped."
msgstr "%(name)s 不是模板佔位符，無法使用 placeholder 傳遞方式，已跳過。"

#: src/skit/cli.py:4700
#, python-format
msgid "%(name)s: unknown type; skipped (use str, int, float, bool, choice, or path)."
msgstr "%(name)s：未知類型，已跳過(可用 str、int、float、bool、choice 或 path)。"

#: src/skit/cli.py:4702
#, python-format
msgid "%(name)s: the default doesn't fit its type; skipped."
msgstr "%(name)s：預設值與其類型不符，已跳過。"

#: src/skit/cli.py:4707
#, python-format
msgid "%(name)s: a choice parameter needs choices; set --choices %(name)s=a,b,c."
msgstr "%(name)s：choice 參數需要可選值，請設定 --choices %(name)s=a,b,c。"

#: src/skit/cli.py:4761
#, python-format
msgid "Variable insertion is off for %(name)s — turn it on first with: skit params %(name)s --interpolate"
msgstr "%(name)s 的變量插入已關閉——請先開啟:skit params %(name)s --interpolate"

#: src/skit/cli.py:4775
#, python-format
msgid "Ignored a malformed value: %(item)s (expected NAME=VALUE)."
msgstr "已忽略格式錯誤的值：%(item)s（應為 NAME=VALUE）。"

#: src/skit/cli.py:4831
#, python-format
msgid "Updated %(name)s. Declared parameters: %(names)s"
msgstr "已更新 %(name)s。已宣告的參數:%(names)s"

