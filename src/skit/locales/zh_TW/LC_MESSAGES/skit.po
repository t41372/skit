msgstr "已清除語言覆寫,恢復自動偵測。"

#: src/skit/cli.py:958 src/skit/cli.py:1047
#, python-format
msgid "Unknown language: %(tag)s. Available: %(locales)s"
msgstr "未知語言:%(tag)s。可用語言:%(locales)s"

#: src/skit/cli.py:962
#, python-format
msgid "Language set to %(locale)s"
msgstr "語言已設為 %(locale)s"

#: src/skit/cli.py:971
#, python-format
msgid "Mirror: on (%(pypi)s)"
msgstr "鏡像:已開啟(%(pypi)s)"

#: src/skit/cli.py:973
msgid "Mirror: off"
msgstr "鏡像:已關閉"

#: src/skit/cli.py:974
msgid "Current settings:"
msgstr "目前設定:"

#: src/skit/cli.py:975
#, python-format
msgid "Language: %(locale)s"
msgstr "語言:%(locale)s"

#: src/skit/cli.py:986
msgid "uv binary mirror URL"
msgstr "uv 二進位下載鏡像網址"

#: src/skit/cli.py:992
#, python-format
msgid "The uv binary is downloaded and executed, so its mirror URL must use https:// (got: %(url)s)."
msgstr "uv 二進位檔會被下載並執行,因此其鏡像網址必須使用 https://(目前為:%(url)s)。"

#: src/skit/cli.py:1006
msgid "Mirror for faster installs in mainland China"
msgstr "中國大陸下載加速鏡像"

#: src/skit/cli.py:1018
msgid "PyPI index URL"
msgstr "PyPI 索引網址"

#: src/skit/cli.py:1023
msgid "Python-install mirror URL"
msgstr "Python 下載鏡像網址"

#: src/skit/cli.py:1036
msgid "Interface language"
msgstr "介面語言"

#: src/skit/cli.py:1061
#, python-format
msgid "Unknown mirror: %(name)s. Choose from: %(names)s"
msgstr "未知鏡像:%(name)s。可選:%(names)s"

#: src/skit/cli.py:1066
msgid "Configure skit's language and download mirrors."
msgstr "設定 skit 的語言與下載鏡像。"

#: src/skit/cli.py:1068
msgid "Show the current settings and exit"
msgstr "顯示目前設定後結束"

#: src/skit/cli.py:1072
msgid "Set the language non-interactively (a tag like zh-CN, or \"auto\")"
msgstr "非互動式設定語言(語言標籤,如 zh-CN,或 \"auto\")"

#: src/skit/cli.py:1077
msgid "Set the mirror non-interactively: tsinghua / aliyun / ustc / off"
msgstr "非互動式設定鏡像:tsinghua / aliyun / ustc / off"

#: src/skit/cli.py:1100
msgid "Saved."
msgstr "已儲存"

#: src/skit/cli.py:1117
msgid "Network to PyPI / GitHub looks slow or blocked."
msgstr "偵測到存取 PyPI / GitHub 緩慢或受阻。"

#: src/skit/cli.py:1119
msgid "Configure mirrors for faster installs (mainland China)?"
msgstr "是否設定鏡像以加速下載(中國大陸)?"

#: src/skit/launcher.py:57
msgid "uv not found. Install it (https://docs.astral.sh/uv/) or run skit doctor for guidance."
msgstr "找不到 uv。請先安裝 uv(https://docs.astral.sh/uv/),或執行 skit doctor 取得安裝指引。"

#: src/skit/launcher.py:78
