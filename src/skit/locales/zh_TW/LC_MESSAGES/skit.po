msgstr "偵測到但未納管:%(names)s(用 --add 納入管理)"

#: src/skit/cli.py:822
msgid "Use --resync, --add, --remove, --secret/--no-secret, or --prompt NAME=text to make changes."
msgstr "用 --resync、--add、--remove、--secret/--no-secret 或 --prompt NAME=text 來編輯。"

