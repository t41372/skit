#: src/skit/cli.py:36
msgid "skit — a script launcher and parameter manager. Run it without a subcommand to open the main menu."
msgstr "skit — 腳本啟動器 + 參數管家。不帶子命令執行即進入主選單。"

#: src/skit/cli.py:48
msgid "Show version"
msgstr "顯示版本"

#: src/skit/cli.py:74
#, python-format
msgid "PEP 723 metadata found: %(deps)s"
msgstr "偵測到 PEP 723 metadata:%(deps)s"

#: src/skit/cli.py:85
msgid "Dependencies (comma separated; leave empty for none)"
msgstr "依賴(逗號分隔,留空表示不需要)"

#: src/skit/cli.py:91
msgid "Python version (leave empty for automatic)"
msgstr "Python 版本(留空 = 自動)"

#: src/skit/cli.py:140
#, python-format
msgid "This script already parses its own arguments (%(names)s). Pass them straight through instead: skit run %(name)s -- <args>"
msgstr "這個腳本已自帶參數解析(%(names)s)。直接透傳參數即可:skit run %(name)s -- <args>"

#: src/skit/cli.py:150
#, python-format
msgid "Found %(count)s parameter candidate (constants / input() calls):"
msgid_plural "Found %(count)s parameter candidates (constants / input() calls):"
msgstr[0] "找到 %(count)s 個候選參數(寫死常量 / input() 呼叫):"

#: src/skit/cli.py:156
msgid " (secret)"
msgstr " (secret)"

#: src/skit/cli.py:162
#, python-format
msgid "%(num)s. %(name)s (%(type)s) = %(value)s%(secret)s"
msgstr "%(num)s. %(name)s(%(type)s)= %(value)s%(secret)s"

#: src/skit/cli.py:174
#, python-format
msgid "%(num)s. input() #%(ordinal)s: %(prompt)s%(secret)s"
msgstr "%(num)s. input() 第 %(ordinal)s 個:%(prompt)s%(secret)s"

#: src/skit/cli.py:178
msgid "Which ones should skit manage? (e.g. 1,3 / all / none)"
msgstr "哪些交給 skit 管理?(編號如 1,3 / all / none)"

#: src/skit/cli.py:186
msgid "Add a script, executable, or command to skit."
msgstr "把腳本、可執行檔或命令加入 skit。"

#: src/skit/cli.py:188
msgid "Path to a Python script or executable"
msgstr "Python 腳本或可執行檔路徑"

#: src/skit/cli.py:190
msgid "Name / alias (defaults to the file name)"
msgstr "名稱 / alias(預設用檔名)"

#: src/skit/cli.py:196
msgid "Description (defaults to the first line of the docstring)"
msgstr "描述(預設抓 docstring 首行)"

#: src/skit/cli.py:201
msgid "Reference mode: link to the original file instead of copying it"
msgstr "reference 模式:不複製,連結原檔"

#: src/skit/cli.py:203
msgid "Register as an executable entry"
msgstr "登記為可執行檔條目"

#: src/skit/cli.py:205
#, python-brace-format
msgid "Register a command template, e.g. --cmd 'ffmpeg -i {input}'"
msgstr "登記命令模板,如 --cmd 'ffmpeg -i {input}'"

#: src/skit/cli.py:210
msgid "Dependencies, comma separated (skips the interactive question)"
msgstr "依賴清單,逗號分隔(跳過互動詢問)"

#: src/skit/cli.py:213 src/skit/cli.py:858
msgid "Python version constraint, e.g. \">=3.11\""
msgstr "Python 版本約束,如 \">=3.11\""

#: src/skit/cli.py:216
msgid "Never prompt; accept the detected suggestions"
msgstr "永不詢問;直接採用偵測到的建議"

#: src/skit/cli.py:223
msgid "A --cmd entry needs a --name"
msgstr "--cmd 條目必須指定 --name"

#: src/skit/cli.py:229
#, python-format
msgid "Detected parameters: %(names)s (you'll be prompted on each run; your last values are remembered)"
msgstr "偵測到參數:%(names)s(每次執行時會詢問;會記住上次的值)"

#: src/skit/cli.py:235
msgid "--exe requires a path"
msgstr "--exe 需要提供路徑"

#: src/skit/cli.py:241
msgid "Provide a script path, or use --cmd to register a command template"
msgstr "請提供腳本路徑,或用 --cmd 登記命令模板"

#: src/skit/cli.py:247
#, python-format
msgid "%(file)s isn't a .py file — pass --exe if it's an executable"
msgstr "%(file)s 不是 .py 檔;若是可執行檔請加 --exe"

#: src/skit/cli.py:262
#, python-format
msgid "Dependencies recorded: %(deps)s"
msgstr "依賴已記錄:%(deps)s"

#: src/skit/cli.py:269
msgid "Reference mode never touches the original file, so parameter setup was skipped."
msgstr "reference 模式絕不改動原檔;略過參數設定。"

#: src/skit/cli.py:282
#, python-format
msgid "Parameter definitions written to the script's [tool.skit] block: %(names)s"
msgstr "參數定義已寫入腳本的 [tool.skit] 區塊:%(names)s"

#: src/skit/cli.py:290
#, python-format
msgid "Secret parameter values are never saved to disk: %(names)s"
msgstr "secret 參數的值永不落地:%(names)s"

#: src/skit/cli.py:296
#, python-format
msgid "(%(mode)s mode)"
msgstr "(%(mode)s 模式)"

#: src/skit/cli.py:301
#, python-format
msgid "Added: %(name)s"
msgstr "已加入:%(name)s"

#: src/skit/cli.py:304
#, python-format
msgid "Description: %(desc)s"
msgstr "描述:%(desc)s"

#: src/skit/cli.py:305
#, python-format
msgid "Run it: skit run %(name)s"
msgstr "執行:skit run %(name)s"

#: src/skit/cli.py:308
msgid "List every registered script."
msgstr "列出所有已登記的腳本。"

#: src/skit/cli.py:310
msgid "Output as JSON"
msgstr "以 JSON 輸出"

#: src/skit/cli.py:334
msgid "No scripts yet. Add one with: skit add <path>"
msgstr "還沒有任何腳本。用 skit add <path> 加一個。"

#: src/skit/cli.py:337 src/skit/tui.py:393
msgid "Name"
msgstr "名稱"

#: src/skit/cli.py:338 src/skit/cli.py:700 src/skit/tui.py:184
#: src/skit/tui.py:393
msgid "Kind"
msgstr "類型"

#: src/skit/cli.py:339 src/skit/tui.py:393
msgid "Description"
msgstr "描述"

#: src/skit/cli.py:345
msgid "Remove a registered script (the original file is left untouched)."
msgstr "移除一個已登記的腳本(原檔不受影響)。"

#: src/skit/cli.py:347 src/skit/cli.py:459 src/skit/cli.py:557
#: src/skit/cli.py:607 src/skit/cli.py:631 src/skit/cli.py:660
#: src/skit/cli.py:742 src/skit/cli.py:851
msgid "Script name or slug"
msgstr "腳本名稱或 slug"

#: src/skit/cli.py:348
msgid "Skip confirmation"
msgstr "跳過確認"

#: src/skit/cli.py:357 src/skit/tui.py:72
#, python-format
msgid "Remove \"%(name)s\"?"
msgstr "確定移除「%(name)s」?"

#: src/skit/cli.py:359
#, python-format
msgid "Removed: %(name)s"
msgstr "已移除:%(name)s"

#: src/skit/cli.py:412 src/skit/tui.py:517
#, python-format
msgid "Parameters for %(name)s (press Enter to keep the value shown):"
msgstr "%(name)s 的參數(按 Enter 沿用顯示的值):"

#: src/skit/cli.py:450 src/skit/cli.py:648
#, python-format
msgid "Unknown preset \"%(preset)s\". Available: %(presets)s"
msgstr "沒有名為「%(preset)s」的 preset。現有:%(presets)s"

#: src/skit/cli.py:457
msgid "Run a registered script or command in the terminal."
msgstr "在終端機執行已登記的腳本或命令。"

#: src/skit/cli.py:461
msgid "Arguments passed through to the script (after --)"
msgstr "透傳給腳本的參數(接在 -- 之後)"

#: src/skit/cli.py:464
msgid "Never prompt; reuse last values and defaults"
msgstr "永不詢問;沿用上次的值 / 預設值"

#: src/skit/cli.py:470
msgid "Named preset of parameter values to prefill the form with"
msgstr "用哪組具名 preset 預填表單"

#: src/skit/cli.py:476
msgid "Skip the parameter form and injection and run the script as-is (escape hatch)"
msgstr "跳過參數表單與注入,原樣執行腳本(逃生門)"

#: src/skit/cli.py:493
msgid "Raw mode: skipping the parameter form and injection."
msgstr "raw 模式:已跳過參數表單與注入。"

#: src/skit/cli.py:508 src/skit/tui.py:538
#, python-format
msgid "Can't inject parameters into %(name)s: targets not found (%(detail)s). The script may have drifted from its [tool.skit] definitions — re-add it or edit the block."
msgstr "無法把參數注入 %(name)s:找不到目標(%(detail)s)。腳本內容可能已偏離其 [tool.skit] 定義——請重新 add 或編輯該區塊。"

#: src/skit/cli.py:513
msgid "Values are injected at run time; the stored copy of your script is never modified."
msgstr "值在執行時注入;倉庫中的腳本副本永不改動。"

#: src/skit/cli.py:524
#, python-format
msgid "Reusing your last arguments: %(args)s"
msgstr "沿用上次的參數:%(args)s"

#: src/skit/cli.py:544
#, python-format
msgid "Script exited with code %(code)s"
msgstr "腳本以 exit code %(code)s 結束"

#: src/skit/cli.py:550
msgid "Manage named parameter presets for a script."
msgstr "管理腳本的具名參數 preset。"

#: src/skit/cli.py:555
msgid "Save a set of parameter values as a named preset."
msgstr "把一組參數值儲存為具名 preset。"

#: src/skit/cli.py:558 src/skit/cli.py:632
msgid "Preset name"
msgstr "preset 名稱"

#: src/skit/cli.py:572 src/skit/cli.py:587
#, python-format
msgid "%(name)s has no managed parameters or placeholders, so there's nothing to save."
msgstr "%(name)s 沒有受管理的參數或佔位符;沒東西可存 preset。"

#: src/skit/cli.py:582 src/skit/cli.py:601
#, python-format
msgid "Preset \"%(preset)s\" saved for %(name)s."
msgstr "已為 %(name)s 儲存 preset「%(preset)s」。"

#: src/skit/cli.py:595
#, python-format
msgid "Secret values are never stored in presets; skipped: %(names)s"
msgstr "secret 值永不存入 preset;已略過:%(names)s"

#: src/skit/cli.py:605
msgid "List a script's saved presets."
msgstr "列出腳本已儲存的 preset。"

#: src/skit/cli.py:619
#, python-format
msgid "No presets for %(name)s yet. Create one with: skit preset save %(name)s <preset>"
msgstr "%(name)s 沒有任何 preset。建立:skit preset save %(name)s <preset>"

#: src/skit/cli.py:629
msgid "Delete a named preset from a script."
msgstr "從腳本刪除一個具名 preset。"

#: src/skit/cli.py:642
#, python-format
msgid "Preset \"%(preset)s\" deleted from %(name)s."
msgstr "已從 %(name)s 刪除 preset「%(preset)s」。"

#: src/skit/cli.py:658
msgid "Show a script's managed parameters and their last-used values."
msgstr "顯示腳本受管理的參數及其上次使用的值。"

#: src/skit/cli.py:675 src/skit/cli.py:693 src/skit/cli.py:814
#, python-format
msgid "%(name)s has no managed parameters. Re-add the script or edit its [tool.skit] block to define some."
msgstr "%(name)s 沒有受管理的參數。重新 add 或手動編輯其 [tool.skit] 區塊即可定義。"

#: src/skit/cli.py:680
msgid "Command template placeholders (you'll be asked on each run):"
msgstr "命令模板佔位符(每次執行時詢問):"

#: src/skit/cli.py:699 src/skit/tui.py:183
msgid "Parameter"
msgstr "參數"

#: src/skit/cli.py:701 src/skit/tui.py:185
msgid "Type"
msgstr "型別"

#: src/skit/cli.py:702
msgid "Default"
msgstr "預設值"

#: src/skit/cli.py:703 src/skit/cli.py:810 src/skit/tui.py:116
#: src/skit/tui.py:187
msgid "Secret"
msgstr "Secret"

#: src/skit/cli.py:704
msgid "Last value"
msgstr "上次的值"

#: src/skit/cli.py:707 src/skit/cli.py:711
msgid "•••"
msgstr "•••"

#: src/skit/cli.py:720 src/skit/tui.py:206 src/skit/tui.py:207
msgid "yes"
msgstr "是"

#: src/skit/cli.py:740
msgid "Edit a script's managed parameter definitions."
msgstr "編輯腳本受管理的參數定義。"

#: src/skit/cli.py:746
msgid "Prune definitions that no longer match the script and refresh changed types"
msgstr "修剪已對不上腳本的定義,並更新型別已變的項"

#: src/skit/cli.py:751
msgid "Bring a currently detected candidate under management (repeatable)"
msgstr "把當前偵測到的候選納入管理(可重複)"

#: src/skit/cli.py:754
msgid "Drop a managed parameter (repeatable)"
msgstr "移除一個受管理的參數(可重複)"

#: src/skit/cli.py:757
msgid "Mark a managed parameter as secret (repeatable)"
msgstr "把某受管理參數標為 secret(可重複)"

#: src/skit/cli.py:762
msgid "Remove the secret mark from a managed parameter (repeatable)"
msgstr "取消某受管理參數的 secret 標記(可重複)"

#: src/skit/cli.py:765
msgid "Set a parameter's form prompt, as NAME=text (repeatable)"
msgstr "以 NAME=text 設定參數的表單提示(可重複)"

#: src/skit/cli.py:777
#, python-format
msgid "%(name)s isn't a Python script; only Python entries have managed parameters."
msgstr "%(name)s 不是 Python 腳本;只有 Python 條目有受管理的參數。"

#: src/skit/cli.py:784
#, python-format
msgid "%(name)s is in reference mode, and skit never writes the original file. Edit the [tool.skit] block in the source directly."
msgstr "%(name)s 是 reference 模式;skit 絕不寫原檔。請直接改原檔的 [tool.skit] 區塊。"

#: src/skit/cli.py:790
#, python-format
msgid "%(name)s has no stored copy to edit."
msgstr "%(name)s 沒有可編輯的副本。"

#: src/skit/cli.py:799
#, python-format
msgid "Ignored a malformed --prompt value: %(item)s (expected NAME=text)."
msgstr "已忽略格式錯誤的 --prompt 值:%(item)s(應為 NAME=text)。"

#: src/skit/cli.py:807
#, python-format
msgid "Managed parameters for %(name)s:"
msgstr "%(name)s 受管理的參數:"

#: src/skit/cli.py:819
#, python-format
msgid "Detected but not yet managed: %(names)s (use --add to manage them)"
msgstr "偵測到但未納管:%(names)s(用 --add 納入管理)"

#: src/skit/cli.py:824
msgid "Use --resync, --add, --remove, --secret/--no-secret, or --prompt NAME=text to make changes."
msgstr "用 --resync、--add、--remove、--secret/--no-secret 或 --prompt NAME=text 來編輯。"

#: src/skit/cli.py:845
#, python-format
msgid "Updated %(name)s. Managed parameters: %(names)s"
msgstr "已更新 %(name)s。受管理的參數:%(names)s"

#: src/skit/cli.py:849
msgid "View or update a script's dependencies and Python constraint."
msgstr "查看或更新腳本的依賴與 Python 版本約束。"

#: src/skit/cli.py:855
msgid "New dependency list, comma separated (an empty string clears it)"
msgstr "新依賴清單,逗號分隔(空字串清空)"

#: src/skit/cli.py:870
#, python-format
msgid "%(name)s is not a Python script entry."
msgstr "%(name)s 不是 Python 腳本條目。"

#: src/skit/cli.py:876
#, python-format
msgid "Dependencies of %(name)s: %(deps)s"
msgstr "%(name)s 的依賴:%(deps)s"

#: src/skit/cli.py:881
#, python-format
msgid "Python constraint: %(python)s"
msgstr "Python 版本約束:%(python)s"

#: src/skit/cli.py:895
#, python-format
msgid "Dependencies of %(name)s updated: %(deps)s"
msgstr "%(name)s 的依賴已更新:%(deps)s"

#: src/skit/cli.py:899
msgid "Check that uv is available and the script store is intact."
msgstr "檢查 uv 是否可用以及腳本倉庫是否完好。"

#: src/skit/cli.py:902
msgid "Rebuild the index from each script's meta.toml"
msgstr "從各腳本的 meta.toml 重建索引"

#: src/skit/cli.py:911
#, python-format
msgid "uv: %(path)s"
msgstr "uv:%(path)s"

#: src/skit/cli.py:914
msgid "uv: not found. Install it from https://docs.astral.sh/uv/getting-started/installation/"
msgstr "uv:未找到。安裝方式:https://docs.astral.sh/uv/getting-started/installation/"

#: src/skit/cli.py:919
#, python-format
msgid "Index rebuilt: %(count)s entry"
msgid_plural "Index rebuilt: %(count)s entries"
msgstr[0] "索引已重建:%(count)s 條"

#: src/skit/cli.py:925
#, python-format
msgid "Registered scripts: %(count)s"
msgstr "已登記腳本:%(count)s 條"

#: src/skit/cli.py:933
#, python-format
msgid "%(name)s: reference source file is gone"
msgstr "%(name)s:reference 原檔已消失"

#: src/skit/cli.py:938
msgid "Show or set the interface language."
msgstr "顯示或設定介面語言。"

#: src/skit/cli.py:942
msgid "A language tag such as en / zh-TW / zh-CN, or \"auto\" to clear the override"
msgstr "語言標籤,如 en / zh-TW / zh-CN;填 \"auto\" 清除覆寫"

#: src/skit/cli.py:948 src/skit/cli.py:954
#, python-format
msgid "Active language: %(locale)s"
msgstr "目前語言:%(locale)s"

#: src/skit/cli.py:949
#, python-format
msgid "Available: %(locales)s"
msgstr "可用語言:%(locales)s"

#: src/skit/cli.py:953
