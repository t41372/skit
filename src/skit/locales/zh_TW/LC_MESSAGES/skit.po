#: src/skit/cli.py:3702 src/skit/cli.py:3937 src/skit/cli.py:3942
msgid "•••"
msgstr "•••"

#: src/skit/cli.py:2457
msgid "Show everything about one entry: metadata, dependencies, parameters, presets."
msgstr "顯示一個條目的全部資訊：中繼資料、依賴、參數和參數組合。"

#: src/skit/cli.py:2458
msgid "Examples:  skit show resize  ·  skit show resize --json"
msgstr "例:skit show resize · skit show resize --json"

#: src/skit/cli.py:2519
msgid "Remove a registered entry (an original source file is left untouched)."
msgstr "移除一個已登記的條目（原始來源檔案不受影響）。"

#: src/skit/cli.py:2522 src/skit/cli.py:3409
msgid "Skip confirmation"
msgstr "跳過確認"

#: src/skit/cli.py:2532 src/skit/tui.py:149
#, python-format
msgid "Remove \"%(name)s\"?"
msgstr "移除「%(name)s」？"

#: src/skit/cli.py:2534
#, python-format
msgid "Remove \"%(name)s\"? Your original file will not be deleted."
msgstr "移除「%(name)s」？你的原始檔不會被刪除。"

#: src/skit/cli.py:2539
#, python-format
msgid "Removed: %(name)s"
msgstr "已移除:%(name)s"

#: src/skit/cli.py:2542
msgid "Rename an entry (presets, remembered values and history survive)."
msgstr "重新命名條目（參數組合、記住的值與歷史都會保留）。"

#: src/skit/cli.py:2545
msgid "The new name"
msgstr "新名稱"

#: src/skit/cli.py:2554
#, python-format
msgid "Renamed to %(name)s."
msgstr "已重新命名為 %(name)s。"

#: src/skit/cli.py:2558
msgid "Set an entry's description (shown in the Library and skit list)."
msgstr "設定條目的說明（顯示在工具庫和 skit list 中）。"

#: src/skit/cli.py:2561
msgid "The description (empty text clears it)"
msgstr "說明(留空即清除)"

#: src/skit/cli.py:2571
#, python-format
msgid "Description updated for %(name)s."
msgstr "已更新 %(name)s 的說明。"

#: src/skit/cli.py:2575
#, python-format
msgid "Description cleared for %(name)s."
msgstr "已清除 %(name)s 的說明。"

#: src/skit/cli.py:2583
#, python-format
msgid "No editable entry named %(name)s."
msgstr "找不到名為 %(name)s 的可編輯條目。"

#: src/skit/cli.py:2587
#, python-format
msgid "No editable entry named \"%(name)s\". Create a script now?"
msgstr "找不到名為「%(name)s」的可編輯條目。要現在建立腳本嗎？"

