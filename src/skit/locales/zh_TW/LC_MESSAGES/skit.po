#: src/skit/analysis.py:116
#, python-format
msgid "The parameter definitions for %(name)s have drifted from the script:"
msgstr "%(name)s 的參數定義與腳本內容已漂移:"

#: src/skit/analysis.py:125
#, python-brace-format, python-format
msgid "%(name)s is no longer read from the environment (its ${...:-default} was removed or overridden by a plain assignment) — your value would be silently ignored. Re-add or resync."
msgstr "%(name)s 不再從環境變數讀取(其 ${...:-default} 已被移除,或被普通賦值覆蓋)——你設定的值會被默默忽略。請重新加入或執行 resync。"

#: src/skit/analysis.py:135
#, python-format
msgid "%(name)s: injection target no longer exists (dropped from this run's form)"
msgstr "%(name)s:找不到注入目標(已從本次表單剔除)"

#: src/skit/analysis.py:143
#, python-format
msgid "%(name)s: type changed from %(old)s to %(new)s in the source (still injected — double-check the value)"
msgstr "%(name)s:原始碼中的型別已從 %(old)s 變為 %(new)s(仍會注入,請確認值)"

#: src/skit/analysis.py:151
#, python-format
msgid "%(name)s: its prompt no longer matches a unique input/read call; falling back to position (still injected — double-check this lands on the right question, especially if it's a secret)"
msgstr "%(name)s:其提示文字已無法對應到唯一的 input/read 呼叫;改以位置對應(仍會注入——請再次確認其對應到正確的問題,尤其是機密參數)"

#: src/skit/analysis.py:159
#, python-format
msgid "To refresh the definitions, run: skit params %(name)s --resync"
msgstr "若要更新定義,請執行:skit params %(name)s --resync"

#: src/skit/analysis.py:173
#, python-format
msgid "%(name)s isn't a managed parameter; skipped."
msgstr "%(name)s 不是受管理的參數;已略過。"

#: src/skit/analysis.py:174
#, python-format
msgid "Dropped %(name)s: it no longer exists in the script."
msgstr "已剔除 %(name)s:腳本中已找不到。"

#: src/skit/analysis.py:175
#, python-format
msgid "%(name)s is already managed; skipped."
msgstr "%(name)s 已在管理中;已略過。"

#: src/skit/analysis.py:177
#, python-format
msgid "%(name)s isn't a detectable parameter in the current script; skipped."
msgstr "%(name)s 在當前腳本中偵測不到;已略過。"

#: src/skit/analysis.py:180
msgid "Could not parse the script (syntax error); resync skipped. Parameter definitions are unchanged."
msgstr "無法解析腳本(語法錯誤);已略過重新同步。參數定義維持不變。"

#: src/skit/analysis.py:184
#, python-format
msgid "%(name)s: re-anchored to its current position after its prompt stopped matching uniquely; double-check the prompt/secret assignment is still correct."
msgstr "%(name)s:因提示文字無法唯一對應,已重新錨定到其目前位置;請再次確認提示文字/機密設定仍然正確。"

#: src/skit/cli.py:65
msgid "skit — a script launcher and parameter manager. Run it without a subcommand to open the main menu."
msgstr "skit — 腳本啟動器 + 參數管家。不帶子命令執行即進入主選單。"

#: src/skit/cli.py:130
msgid "Script name or slug"
msgstr "腳本名稱或 slug"

#: src/skit/cli.py:137
msgid "Show version"
msgstr "顯示版本"

#: src/skit/cli.py:169
#, python-format
msgid "The script declares its own dependencies (PEP 723): %(deps)s"
msgstr "腳本已用 PEP 723 語法聲明依賴：%(deps)s"

#: src/skit/cli.py:185 src/skit/cli.py:226
msgid "Dependencies to install (Enter to accept, edit the list, or '-' for none)"
msgstr "要安裝的依賴(Enter 採用,可自行編輯,或輸入 - 表示不需要)"

#: src/skit/cli.py:194
msgid "Python version (leave empty for automatic)"
msgstr "Python 版本(留空 = 自動)"

#: src/skit/cli.py:252
msgid "Reference-mode entries take no managed dependencies — they run from their own project. Add it as a copy, or drop --dep."
msgstr "reference 模式條目不受理依賴管理——它從自己的專案執行。以複製模式加入，或拿掉 --dep。"

#: src/skit/cli.py:255
#, python-format
msgid "%(kind)s entries don't take package dependencies — drop --dep."
msgstr "%(kind)s 條目不接受依賴套件——拿掉 --dep。"

#: src/skit/cli.py:262 src/skit/store.py:679
#, python-format
msgid "A Python constraint doesn't apply to %(kind)s scripts."
msgstr "Python 約束不適用於 %(kind)s 腳本。"

#: src/skit/cli.py:274 src/skit/cli.py:532 src/skit/cli.py:913
#: src/skit/cli.py:1349
msgid "Name in skit"
msgstr "在 skit 裡的名稱"

#: src/skit/cli.py:277 src/skit/cli.py:1355
msgid "Description (optional)"
msgstr "描述(可留空)"

#: src/skit/cli.py:297 src/skit/cli.py:303 src/skit/store.py:214
#: src/skit/store.py:315 src/skit/store.py:378 src/skit/store.py:514
#: src/skit/tui_add.py:225
#, python-format
msgid "File not found: %(path)s"
msgstr "找不到檔案：%(path)s"

#: src/skit/cli.py:332 src/skit/cli.py:845 src/skit/tui_add.py:1000
msgid " (secret)"
msgstr " (機密)"

#: src/skit/cli.py:336
#, python-format
msgid "%(num)s. %(name)s (%(type)s) = %(value)s%(secret)s"
msgstr "%(num)s. %(name)s(%(type)s)= %(value)s%(secret)s"

#: src/skit/cli.py:348
#, python-format
msgid "%(num)s. input() #%(ordinal)s: %(prompt)s%(secret)s"
msgstr "%(num)s. input() 第 %(ordinal)s 個:%(prompt)s%(secret)s"

#: src/skit/cli.py:353
msgid "⚠ looks like a loop accumulator — probably not a parameter"
msgstr "⚠ 看起來是迴圈的累加變數，多半不是參數"

#: src/skit/cli.py:363 src/skit/tui_add.py:725
msgid "This script reads command-line arguments; the run form has an extra-arguments field for them."
msgstr "這支腳本會吃命令列參數；執行表單裡有「額外參數」欄可以填。"

#: src/skit/cli.py:372
#, python-format
msgid "💡 %(names)s are written directly inside the code, so skit can't turn them into form fields. To manage one, first give it a name at the top of the script, e.g. OUTPUT = '…' (skit edit %(script)s)."
msgstr "💡 %(names)s 直接寫在程式碼裡，skit 沒辦法把它們變成表單欄位。想管理其中一個，先在腳本開頭給它取個名字，例如 OUTPUT = '…'（skit edit %(script)s）。"

#: src/skit/cli.py:394 src/skit/tui_add.py:679
#, python-format
msgid "✓ skit read this script's own arguments (%(count)s fields). Running it opens a form — nothing to memorize."
msgstr "✓ skit 看懂了這支腳本自己的參數（共 %(count)s 項）。執行時會開表單——不用背任何指令。"

#: src/skit/cli.py:402 src/skit/tui_add.py:687
#, python-format
msgid "This script parses its own arguments (%(names)s); skit couldn't model them statically, so the run form offers a passthrough-arguments field."
msgstr "這支腳本自己解析參數（%(names)s）；skit 無法靜態讀懂它們，執行表單會提供「額外參數（原樣傳給腳本）」欄。"

#: src/skit/cli.py:413 src/skit/cli.py:447
#, python-format
msgid "Found %(count)s parameter candidate (constants / input() calls):"
msgid_plural "Found %(count)s parameter candidates (constants / input() calls):"
msgstr[0] "找到 %(count)s 個候選參數(寫死的常數 / input() 呼叫):"

#: src/skit/cli.py:422 src/skit/cli.py:456
msgid "Which ones should skit manage? (e.g. 1,3 / all / none)"
msgstr "哪些交給 skit 管理?(編號如 1,3 / all / none)"

#: src/skit/cli.py:504
msgid "Reference mode never touches the original file, so parameter setup was skipped."
msgstr "reference 模式絕不改動原檔;略過參數設定。"

#: src/skit/cli.py:528
msgid "Writing a new script in an editor needs an interactive terminal."
msgstr "用編輯器新建腳本需要互動式終端機。"

#: src/skit/cli.py:534 src/skit/cli.py:915 src/skit/store.py:769
#: src/skit/tui_add.py:275 src/skit/tui_runner.py:125
msgid "A name is required."
msgstr "必須提供名稱。"

#: src/skit/cli.py:545 src/skit/cli.py:924 src/skit/store.py:587
#, python-format
msgid "The name %(name)s is already taken — pick another name."
msgstr "名稱 %(name)s 已被使用——請換一個名稱。"

#: src/skit/cli.py:557 src/skit/cli.py:937
msgid "Opening your editor…"
msgstr "正在開啟編輯器…"

#: src/skit/cli.py:562 src/skit/cli.py:942 src/skit/tui_add.py:328
msgid "Nothing was written, so no script was added."
msgstr "沒有寫入任何內容,因此沒有加入腳本。"

#: src/skit/cli.py:578
#, python-format
msgid "The draft's #! names no interpreter skit knows — add it with: skit add %(path)s --kind <language>"
msgstr "草稿的 #! 指定了 skit 不認識的直譯器——請用以下指令加入:skit add %(path)s --kind <語言>"

#: src/skit/cli.py:596
#, python-format
msgid "--dep/--python are python flags, but the draft's shebang names %(kind)s — drop them, or keep the python shebang."
msgstr "--dep/--python 是 python 專用旗標，但草稿的 shebang 指定的是 %(kind)s——拿掉它們，或改回 python shebang。"

#: src/skit/cli.py:629 src/skit/cli.py:678 src/skit/cli.py:742
#: src/skit/cli.py:957 src/skit/cli.py:1006
#, python-format
msgid "Your draft was kept at %(path)s — fix the problem and add it with: skit add %(path)s"
msgstr "你的草稿保留在 %(path)s——修正問題後用以下指令加入:skit add %(path)s"

#: src/skit/cli.py:650 src/skit/cli.py:702 src/skit/cli.py:977
msgid "Reading the script from stdin needs an explicit --name."
msgstr "從 stdin 讀腳本必須用 --name 指定名稱。"

#: src/skit/cli.py:657 src/skit/cli.py:709 src/skit/cli.py:983
msgid "Nothing arrived on stdin, so there is nothing to add."
msgstr "stdin 沒有收到任何內容，沒有東西可加入。"

#: src/skit/cli.py:754
msgid ""
"# New prompt\n"
"\n"
"Describe the task for the agent. Mark the parts that change per run as {{placeholders}} — each becomes a form field. Everything else travels to the agent exactly as written."
msgstr ""
"# 新提示詞\n"
"\n"
"描述要交給 agent 的任務。把每次執行會變動的部分寫成 {{佔位符}}——每個都會成為表單欄位。其餘內容會原封不動送達 agent。"

#: src/skit/cli.py:776
msgid "Custom agents: skit runner add NAME COMMAND… (see skit runner --help)"
msgstr "自訂 agent:skit runner add 名稱 命令…(詳見 skit runner --help)"

#: src/skit/cli.py:789 src/skit/cli.py:1383 src/skit/cli.py:2460
#, python-format
msgid "Unknown runner: %(runner)s. Configured runners: %(names)s"
msgstr "未知的執行器:%(runner)s。已設定的執行器:%(names)s"

#: src/skit/cli.py:800
msgid "- = no pin (the run form asks each time)"
msgstr "- = 不釘選(每次在執行表單選擇)"

#: src/skit/cli.py:803 src/skit/cli.py:2044
msgid "Run this prompt with which agent?"
msgstr "用哪個執行器執行這個提示詞?"

#: src/skit/cli.py:833 src/skit/cli.py:1468 src/skit/langs/launch.py:559
#, python-format
msgid "Can't read %(path)s: %(error)s"
msgstr "無法讀取 %(path)s:%(error)s"

#: src/skit/cli.py:843
msgid "Detected placeholders (each becomes a form field):"
msgstr "偵測到的佔位符(每個都會成為表單欄位):"

#: src/skit/cli.py:850
#, python-format
msgid "…and %(count)s more"
msgstr "……還有 %(count)s 個"

#: src/skit/cli.py:854
msgid "Manage which? (all / none / off / numbers like 1,3)"
msgstr "要納管哪些?(all / none / off / 或編號如 1,3)"

#: src/skit/cli.py:883
#, python-format
msgid "Variable insertion is off — the body travels to the agent exactly as written (turn it on with: skit params %(name)s --interpolate)"
msgstr "變量插入已關閉——內文會原封不動送達 agent(開啟:skit params %(name)s --interpolate)"

#: src/skit/cli.py:888
#, python-format
msgid "Detected %(count)s placeholders — too many to manage automatically, so none were. Manage the ones you need with: skit params %(name)s --add NAME, or turn insertion off with --no-interpolate."
msgstr "偵測到 %(count)s 個佔位符——數量太多,未自動納管任何一個。需要的請用 skit params %(name)s --add 名稱 納管,或用 --no-interpolate 關閉插值。"

#: src/skit/cli.py:892
#, python-format
msgid "Runs with %(runner)s (change it with: skit params %(name)s --runner NAME)"
msgstr "以 %(runner)s 執行(更改:skit params %(name)s --runner NAME)"

#: src/skit/cli.py:1034
#, python-format
msgid "Unknown kind: %(kind)s. Choose from: %(kinds)s"
msgstr "未知類型：%(kind)s。可選：%(kinds)s"

#: src/skit/cli.py:1040
msgid "Add a script, executable, or command to skit."
msgstr "把腳本、可執行檔或命令加入 skit。"

#: src/skit/cli.py:1042
#, python-brace-format
msgid "Examples:  skit add tools/resize.py  ·  skit add --cmd 'ffmpeg -i {input}' -n convert  ·  pbpaste | skit add - -n clip"
msgstr "例：skit add tools/resize.py · skit add --cmd 'ffmpeg -i {input}' -n convert · pbpaste | skit add - -n clip"

#: src/skit/cli.py:1047
msgid "Path to a script or executable, or '-' to read a script from stdin"
msgstr "腳本或可執行檔路徑；「-」表示從 stdin 讀腳本"

#: src/skit/cli.py:1050
msgid "Name / alias (defaults to the file name)"
msgstr "名稱 / alias(預設用檔名)"

#: src/skit/cli.py:1056
msgid "Description (defaults to the first line of the docstring)"
msgstr "描述(預設抓 docstring 首行)"

#: src/skit/cli.py:1059
msgid "Write a brand-new script in your editor, then add it"
msgstr "在編輯器裡新寫一支腳本,再加入 skit"

#: src/skit/cli.py:1064
msgid "Reference mode: link to the original file instead of copying it"
msgstr "reference 模式:不複製,連結原檔"

#: src/skit/cli.py:1069
msgid "Force the executable kind (normally inferred from the file itself)"
msgstr "強制當作可執行檔（一般會自動判斷）"

#: src/skit/cli.py:1074
msgid "Force the language kind (e.g. shell, js) for an extensionless file"
msgstr "強制指定語言類型（如 shell、js），用於沒有副檔名的檔案"

#: src/skit/cli.py:1077
#, python-brace-format
msgid "Register a command template, e.g. --cmd 'ffmpeg -i {input}'"
msgstr "登記命令模板,如 --cmd 'ffmpeg -i {input}'"

#: src/skit/cli.py:1083
msgid "Add the file as a prompt for an AI agent (with no path: draft one in your editor)"
msgstr "將檔案加入為 AI agent 的提示詞(不給路徑則在編輯器中撰寫新的)"

#: src/skit/cli.py:1089
msgid "Pin the agent a prompt entry runs with (see skit runner list)"
msgstr "釘選提示詞項目使用的執行器(見 skit runner list)"

#: src/skit/cli.py:1095
msgid "Prompt only: no variable insertion at all — the body travels exactly as written"
msgstr "僅提示詞:完全不做變量插入——內文原封不動送達"

#: src/skit/cli.py:1101
msgid "A dependency (repeat for more; skips the interactive question)"
msgstr "一項依賴（可重複；會跳過互動詢問）"

#: src/skit/cli.py:1104 src/skit/cli.py:3677
msgid "Python version constraint, e.g. \">=3.11\""
msgstr "Python 版本約束,如 \">=3.11\""

#: src/skit/cli.py:1107
msgid "Never prompt; accept the detected suggestions"
msgstr "永不詢問;直接採用偵測到的建議"

#: src/skit/cli.py:1117
msgid "--prompt names the kind outright — drop --edit/--exe/--kind/--cmd."
msgstr "--prompt 已直接指定類型——請去掉 --edit/--exe/--kind/--cmd。"

#: src/skit/cli.py:1152
msgid "a --cmd template takes only --name/--description"
msgstr "--cmd 樣板只接受 --name/--description"

#: src/skit/cli.py:1153
msgid "the stdin lane can't honor it"
msgstr "stdin 管道無法處理它"

#: src/skit/cli.py:1155
#, python-format
msgid "--edit reads the kind from your draft's shebang (write e.g. #!/usr/bin/env bash); other kinds can also be piped in via skit add - --kind NAME"
msgstr "--edit 會從你草稿的 shebang 判斷種類(例如寫入 #!/usr/bin/env bash);其他種類也可用管道傳入:skit add - --kind NAME"

#: src/skit/cli.py:1159
msgid "a drafted prompt takes only --name/--description/--runner"
msgstr "草稿提示詞只接受 --name/--description/--runner"

#: src/skit/cli.py:1166
#, python-format
msgid "%(flags)s can't apply here — %(hint)s (nothing was added)."
msgstr "%(flags)s 在這裡無法套用——%(hint)s(未加入任何內容)。"

#: src/skit/cli.py:1179
msgid "--ref needs an existing file to reference — a script written in the editor or read from stdin has none."
msgstr "--ref 需要一個既存檔案可供連結——在編輯器裡寫的或從 stdin 讀入的腳本沒有原檔。"

#: src/skit/cli.py:1187 src/skit/cli.py:1334
msgid "--no-interpolate only applies to prompt entries — add one with --prompt."
msgstr "--no-interpolate 只適用於提示詞項目——用 --prompt 加入一個。"

#: src/skit/cli.py:1192 src/skit/cli.py:1329
msgid "--runner only applies to prompt entries — add one with --prompt."
msgstr "--runner 只適用於提示詞項目——用 --prompt 加入一個。"

#: src/skit/cli.py:1197 src/skit/cli.py:1229
msgid "--exe needs an existing program on disk — stdin and the editor author scripts."
msgstr "--exe 需要磁碟上既有的程式——stdin 與編輯器用來撰寫腳本。"

#: src/skit/cli.py:1203
msgid "Use --edit to write a new script, or pass a path to add an existing one — not both."
msgstr "用 --edit 新寫腳本,或傳入路徑加入現有檔案,兩者不能同時使用。"

#: src/skit/cli.py:1212
msgid "--dep/--python are script flags — a prompt has no dependencies."
msgstr "--dep/--python 是腳本旗標——提示詞沒有依賴。"

#: src/skit/cli.py:1221
msgid "--runner/--no-interpolate only apply to prompt entries — pipe one with --prompt."
msgstr "--runner/--no-interpolate 只適用於提示詞項目——用 --prompt 以管道傳入一個。"

#: src/skit/cli.py:1246
msgid "The piped text's #! names no interpreter skit knows — pass --kind <language> to choose one."
msgstr "管道文字的 #! 指定了 skit 不認識的直譯器——請用 --kind <語言> 指定一個。"

#: src/skit/cli.py:1259
#, python-format
msgid "--dep/--python don't apply to a %(kind)s entry (piped text's kind)."
msgstr "--dep/--python 不適用於 %(kind)s 項目(管道文字的種類)。"

#: src/skit/cli.py:1277
msgid "A --cmd entry needs a --name"
msgstr "--cmd 條目必須指定 --name"

#: src/skit/cli.py:1284
#, python-format
msgid "Detected parameters: %(names)s (the run form asks for them; your last values are remembered)"
msgstr "偵測到參數：%(names)s（執行表單會詢問；會記住你上次的值）"

#: src/skit/cli.py:1291
msgid "Provide a script path, or use --cmd to register a command template"
msgstr "請提供腳本路徑,或用 --cmd 登記命令模板"

#: src/skit/cli.py:1302
msgid "Use --kind or --exe, not both."
msgstr "--kind 與 --exe 只能擇一。"

#: src/skit/cli.py:1316
#, python-format
msgid "%(file)s looks like a prompt. Add it as one?"
msgstr "%(file)s 看起來是提示詞。要當作提示詞加入嗎?"

#: src/skit/cli.py:1323 src/skit/cli.py:1399 src/skit/cli.py:1437
#: src/skit/cli.py:1491
msgid "Cancelled — nothing was added."
msgstr "已取消——沒有加入任何東西。"

#: src/skit/cli.py:1360
#, python-format
msgid "%(file)s isn't a script or an executable — pass --kind <language> for an extensionless script, --prompt for an AI-agent prompt, --exe for a program, or --cmd for a command template."
msgstr "%(file)s 不是腳本也不是可執行檔——沒有副檔名的腳本請加 --kind <language>,AI agent 提示詞請加 --prompt,程式請加 --exe,命令模板請用 --cmd。"

#: src/skit/cli.py:1516
#, python-format
msgid "(%(mode)s mode)"
msgstr "(%(mode)s 模式)"

