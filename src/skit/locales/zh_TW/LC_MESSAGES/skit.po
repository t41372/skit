msgstr "直譯器:%(program)s"

#: src/skit/cli.py:2384 src/skit/cli.py:4866
#, python-format
msgid "Python constraint: %(python)s"
msgstr "Python 版本約束:%(python)s"

#: src/skit/cli.py:2388
#, python-format
