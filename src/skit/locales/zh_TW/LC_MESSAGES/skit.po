msgid "Python version constraint, e.g. \">=3.11\""
msgstr "Python 版本約束,如 \">=3.11\""

#: src/skit/cli.py:214
msgid "Never prompt; accept the detected suggestions"
msgstr "永不詢問;直接採用偵測到的建議"

#: src/skit/cli.py:221
msgid "A --cmd entry needs a --name"
msgstr "--cmd 條目必須指定 --name"

#: src/skit/cli.py:227
#, python-format
msgid "Detected parameters: %(names)s (you'll be prompted on each run; your last values are remembered)"
msgstr "偵測到參數:%(names)s(每次執行時會詢問;會記住上次的值)"

#: src/skit/cli.py:233
msgid "--exe requires a path"
msgstr "--exe 需要提供路徑"

#: src/skit/cli.py:239
msgid "Provide a script path, or use --cmd to register a command template"
msgstr "請提供腳本路徑,或用 --cmd 登記命令模板"

#: src/skit/cli.py:245
#, python-format
msgid "%(file)s isn't a .py file — pass --exe if it's an executable"
msgstr "%(file)s 不是 .py 檔;若是可執行檔請加 --exe"

#: src/skit/cli.py:260
#, python-format
msgid "Dependencies recorded: %(deps)s"
msgstr "依賴已記錄:%(deps)s"

#: src/skit/cli.py:267
msgid "Reference mode never touches the original file, so parameter setup was skipped."
msgstr "reference 模式絕不改動原檔;略過參數設定。"

#: src/skit/cli.py:280
#, python-format
msgid "Parameter definitions written to the script's [tool.skit] block: %(names)s"
msgstr "參數定義已寫入腳本的 [tool.skit] 區塊:%(names)s"

#: src/skit/cli.py:288
#, python-format
msgid "Secret parameter values are never saved to disk: %(names)s"
msgstr "secret 參數的值永不落地:%(names)s"

#: src/skit/cli.py:294
#, python-format
msgid "(%(mode)s mode)"
msgstr "(%(mode)s 模式)"

#: src/skit/cli.py:299
#, python-format
msgid "Added: %(name)s"
msgstr "已加入:%(name)s"

#: src/skit/cli.py:302
#, python-format
msgid "Description: %(desc)s"
msgstr "描述:%(desc)s"

#: src/skit/cli.py:303
#, python-format
msgid "Run it: skit run %(name)s"
msgstr "執行:skit run %(name)s"

#: src/skit/cli.py:308
msgid "Output as JSON"
msgstr "以 JSON 輸出"

#: src/skit/cli.py:332
msgid "No scripts yet. Add one with: skit add <path>"
msgstr "還沒有任何腳本。用 skit add <path> 加一個。"

#: src/skit/cli.py:335 src/skit/tui.py:393
msgid "Name"
msgstr "名稱"

#: src/skit/cli.py:336 src/skit/cli.py:698 src/skit/tui.py:184
#: src/skit/tui.py:393
msgid "Kind"
msgstr "類型"

#: src/skit/cli.py:337 src/skit/tui.py:393
msgid "Description"
msgstr "描述"

#: src/skit/cli.py:345 src/skit/cli.py:457 src/skit/cli.py:555
#: src/skit/cli.py:605 src/skit/cli.py:629 src/skit/cli.py:658
#: src/skit/cli.py:740 src/skit/cli.py:849
msgid "Script name or slug"
msgstr "腳本名稱或 slug"

#: src/skit/cli.py:346
msgid "Skip confirmation"
msgstr "跳過確認"

#: src/skit/cli.py:355 src/skit/tui.py:72
#, python-format
msgid "Remove \"%(name)s\"?"
msgstr "確定移除「%(name)s」?"

#: src/skit/cli.py:357
#, python-format
msgid "Removed: %(name)s"
msgstr "已移除:%(name)s"

#: src/skit/cli.py:410 src/skit/tui.py:517
#, python-format
msgid "Parameters for %(name)s (press Enter to keep the value shown):"
msgstr "%(name)s 的參數(按 Enter 沿用顯示的值):"

#: src/skit/cli.py:448 src/skit/cli.py:646
#, python-format
msgid "Unknown preset \"%(preset)s\". Available: %(presets)s"
msgstr "沒有名為「%(preset)s」的 preset。現有:%(presets)s"

#: src/skit/cli.py:459
msgid "Arguments passed through to the script (after --)"
msgstr "透傳給腳本的參數(接在 -- 之後)"

#: src/skit/cli.py:462
msgid "Never prompt; reuse last values and defaults"
msgstr "永不詢問;沿用上次的值 / 預設值"

#: src/skit/cli.py:468
msgid "Named preset of parameter values to prefill the form with"
msgstr "用哪組具名 preset 預填表單"

#: src/skit/cli.py:474
msgid "Skip the parameter form and injection and run the script as-is (escape hatch)"
msgstr "跳過參數表單與注入,原樣執行腳本(逃生門)"

#: src/skit/cli.py:491
msgid "Raw mode: skipping the parameter form and injection."
msgstr "raw 模式:已跳過參數表單與注入。"

#: src/skit/cli.py:506 src/skit/tui.py:538
#, python-format
msgid "Can't inject parameters into %(name)s: targets not found (%(detail)s). The script may have drifted from its [tool.skit] definitions — re-add it or edit the block."
msgstr "無法把參數注入 %(name)s:找不到目標(%(detail)s)。腳本內容可能已偏離其 [tool.skit] 定義——請重新 add 或編輯該區塊。"

#: src/skit/cli.py:511
msgid "Values are injected at run time; the stored copy of your script is never modified."
msgstr "值在執行時注入;倉庫中的腳本副本永不改動。"

#: src/skit/cli.py:522
#, python-format
msgid "Reusing your last arguments: %(args)s"
msgstr "沿用上次的參數:%(args)s"

#: src/skit/cli.py:542
#, python-format
msgid "Script exited with code %(code)s"
msgstr "腳本以 exit code %(code)s 結束"

#: src/skit/cli.py:548
msgid "Manage named parameter presets for a script."
msgstr "管理腳本的具名參數 preset。"

#: src/skit/cli.py:556 src/skit/cli.py:630
msgid "Preset name"
msgstr "preset 名稱"

#: src/skit/cli.py:570 src/skit/cli.py:585
#, python-format
msgid "%(name)s has no managed parameters or placeholders, so there's nothing to save."
msgstr "%(name)s 沒有受管理的參數或佔位符;沒東西可存 preset。"

#: src/skit/cli.py:580 src/skit/cli.py:599
#, python-format
msgid "Preset \"%(preset)s\" saved for %(name)s."
msgstr "已為 %(name)s 儲存 preset「%(preset)s」。"

#: src/skit/cli.py:593
#, python-format
msgid "Secret values are never stored in presets; skipped: %(names)s"
msgstr "secret 值永不存入 preset;已略過:%(names)s"

#: src/skit/cli.py:617
#, python-format
msgid "No presets for %(name)s yet. Create one with: skit preset save %(name)s <preset>"
msgstr "%(name)s 沒有任何 preset。建立:skit preset save %(name)s <preset>"

#: src/skit/cli.py:640
#, python-format
msgid "Preset \"%(preset)s\" deleted from %(name)s."
msgstr "已從 %(name)s 刪除 preset「%(preset)s」。"

#: src/skit/cli.py:673 src/skit/cli.py:691 src/skit/cli.py:812
#, python-format
msgid "%(name)s has no managed parameters. Re-add the script or edit its [tool.skit] block to define some."
msgstr "%(name)s 沒有受管理的參數。重新 add 或手動編輯其 [tool.skit] 區塊即可定義。"

#: src/skit/cli.py:678
msgid "Command template placeholders (you'll be asked on each run):"
msgstr "命令模板佔位符(每次執行時詢問):"

#: src/skit/cli.py:697 src/skit/tui.py:183
msgid "Parameter"
msgstr "參數"

#: src/skit/cli.py:699 src/skit/tui.py:185
msgid "Type"
msgstr "型別"

#: src/skit/cli.py:700
msgid "Default"
msgstr "預設值"

#: src/skit/cli.py:701 src/skit/cli.py:808 src/skit/tui.py:116
#: src/skit/tui.py:187
msgid "Secret"
