#: src/skit/tui_settings.py:284
msgid "Basics"
msgstr "基本資料"

#: src/skit/tui_settings.py:287
msgid "Renaming keeps everything — remembered values, presets, the stored copy."
msgstr "改名不影響任何東西——記住的值、參數組合、保管的副本都會保留。"

#: src/skit/tui_settings.py:292
msgid "Description (shown in the Library)"
msgstr "說明（顯示在腳本庫）"

#: src/skit/tui_settings.py:320
#, python-format
msgid "Keep a copy — your original file is never modified. Source: %(path)s"
msgstr "複製一份——你的原始檔永遠不會被改動。來源：%(path)s"

#: src/skit/tui_settings.py:331
msgid "Parameters (the run form's fields)"
msgstr "參數（執行表單的欄位）"

#: src/skit/tui_settings.py:337
msgid "(programs have no managed parameters)"
msgstr "（程式沒有納管的參數）"

#: src/skit/tui_settings.py:342
msgid "skit doesn't write to this file — maintain the [tool.skit] definitions in the source directly."
msgstr "skit 不寫入這個檔案——請直接在原始碼裡維護 [tool.skit] 定義。"

#: src/skit/tui_settings.py:359
msgid "This script's run form comes from its own command-line arguments. Managing a hardcoded constant here would replace that form — leave it as is."
msgstr "這支腳本的執行表單來自它自己的命令列參數。在這裡納管一個寫死的常數會取代那張表單——維持原樣即可。"

#: src/skit/tui_settings.py:368
msgid "Detected but not yet managed — tick to manage:"
msgstr "偵測到但尚未納管——勾選即納管："

#: src/skit/tui_settings.py:378
msgid "Every input() is managed — this script can now run with --no-input."
msgstr "所有 input() 都已納管——這支腳本現在可以用 --no-input 自動化。"

#: src/skit/tui_settings.py:396
msgid "Add a parameter — type a name, then Save:"
msgstr "新增參數——輸入名稱後儲存："

#: src/skit/tui_settings.py:397
msgid "new parameter name"
msgstr "新參數名稱"

#: src/skit/tui_settings.py:436
#, python-format
msgid "%(name)s has an unknown type — use str, int, float, bool, or choice."
msgstr "%(name)s 的類型未知——請使用 str、int、float、bool 或 choice。"

#: src/skit/tui_settings.py:447
#, python-format
msgid "%(name)s: the default doesn't match its type."
msgstr "%(name)s：預設值與其類型不符。"

#: src/skit/tui_settings.py:455
#, python-format
msgid "%(name)s is a choice parameter but has no choices; add them with `skit params` on the command line."
msgstr "%(name)s 是 choice 參數但沒有可選值，請在命令列用 `skit params` 新增。"

#: src/skit/tui_settings.py:483
msgid "None yet — press Ctrl+S inside the run form to save one."
msgstr "還沒有——在執行表單裡按 Ctrl+S 就能存一組。"

#: src/skit/tui_settings.py:487
msgid "Untick a preset to delete it on save:"
msgstr "取消勾選的參數組合會在儲存時刪除："

#: src/skit/tui_settings.py:503
msgid "comma separated, e.g. chalk@^5, zod"
msgstr "逗號分隔，例如 chalk@^5, zod"

#: src/skit/tui_settings.py:509
msgid "Python constraint, e.g. \">=3.11\" (empty = automatic)"
msgstr "Python 約束，例如 \">=3.11\"（留空＝自動）"

#: src/skit/tui_settings.py:525
msgid "Needs (external commands)"
msgstr "所需命令（外部命令）"

#: src/skit/tui_settings.py:528
msgid "comma separated, e.g. ffmpeg, jq"
msgstr "逗號分隔，例如 ffmpeg, jq"

#: src/skit/tui_settings.py:533
#, python-format
msgid "Script settings · %(name)s"
msgstr "腳本設定 · %(name)s"

#: src/skit/tui_settings.py:570
msgid "Everything still matches the script."
msgstr "所有定義仍與腳本相符。"

#: src/skit/tui_settings.py:608 src/skit/tui_settings.py:619
#, python-format
msgid "Deleted previously remembered value(s): %(names)s"
msgstr "已刪除先前記住的值：%(names)s"

#: src/skit/uvman.py:76
#, python-format
msgid "skit needs Astral's uv to run Python scripts, but it wasn't found on this system. Download uv %(version)s into skit's private directory (%(path)s)? This won't touch your PATH or global environment. [Y/n]"
msgstr "skit 需要 Astral uv 才能執行 Python 腳本,但系統上找不到。要下載 uv %(version)s 到 skit 的私有目錄(%(path)s)嗎?不會動到你的 PATH 或全局環境。[Y/n]"

#: src/skit/uvman.py:118
#, python-format
msgid "Unsupported platform: %(platform)s"
msgstr "不支援的平台:%(platform)s"

#: src/skit/uvman.py:199
#, python-format
msgid "No uv binary found inside the archive: %(path)s"
msgstr "壓縮包內找不到 uv 執行檔:%(path)s"

#: src/skit/uvman.py:231
#, python-format
msgid "No pinned checksum for platform %(triple)s; refusing to run an unverified uv."
msgstr "沒有為平台 %(triple)s 預置校驗碼,拒絕執行未經校驗的 uv。"

#: src/skit/uvman.py:238
#, python-format
msgid "Downloaded uv failed its checksum (the mirror may be compromised or the file corrupt). Expected %(expected)s, got %(actual)s."
msgstr "下載的 uv 未通過校驗(鏡像可能遭竄改,或檔案已損毀)。預期 %(expected)s,實際為 %(actual)s。"

#: src/skit/uvman.py:254
msgid "Download declined. Install uv yourself (https://docs.astral.sh/uv/getting-started/installation/) and skit will pick it up automatically."
msgstr "已取消下載。你可以自行安裝 uv(https://docs.astral.sh/uv/getting-started/installation/),skit 會自動偵測並使用。"

#: src/skit/uvman.py:261
#, python-format
msgid "First run — downloading uv %(version)s…"
msgstr "首次執行:正在下載 uv %(version)s…"

#: src/skit/uvman.py:282
#, python-format
msgid "Failed to download uv: %(error)s"
msgstr "uv 下載失敗:%(error)s"

#: src/skit/uvman.py:286
#, python-format
msgid "uv installed at: %(path)s"
msgstr "uv 已安裝:%(path)s"

