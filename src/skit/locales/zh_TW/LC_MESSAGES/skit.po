#: src/skit/cli.py:702
msgid "Last value"
msgstr "上次的值"

#: src/skit/cli.py:705 src/skit/cli.py:709
msgid "•••"
msgstr "•••"

#: src/skit/cli.py:718 src/skit/tui.py:206 src/skit/tui.py:207
msgid "yes"
