#: src/skit/cli.py:54
msgid "skit — a script launcher and parameter manager. Run it without a subcommand to open the main menu."
msgstr "skit — 腳本啟動器 + 參數管家。不帶子命令執行即進入主選單。"

#: src/skit/cli.py:111
msgid "Script name or slug"
msgstr "腳本名稱或 slug"

#: src/skit/cli.py:118
msgid "Show version"
msgstr "顯示版本"

#: src/skit/cli.py:150
#, python-format
msgid "The script declares its own dependencies (PEP 723): %(deps)s"
msgstr "腳本已用 PEP 723 語法聲明依賴：%(deps)s"

#: src/skit/cli.py:162
msgid "Dependencies to install (Enter to accept, edit the list, or '-' for none)"
msgstr "要安裝的依賴(Enter 採用,可自行編輯,或輸入 - 表示不需要)"

#: src/skit/cli.py:171
msgid "Python version (leave empty for automatic)"
msgstr "Python 版本(留空 = 自動)"

#: src/skit/cli.py:183 src/skit/cli.py:379
msgid "Name in skit"
msgstr "在 skit 裡的名稱"

#: src/skit/cli.py:186
msgid "Description (optional)"
msgstr "描述(可留空)"

#: src/skit/cli.py:195 src/skit/store.py:228 src/skit/store.py:289
#: src/skit/tui_add.py:87
#, python-format
msgid "File not found: %(path)s"
msgstr "找不到檔案：%(path)s"

#: src/skit/cli.py:224
msgid " (secret)"
msgstr " (機密)"

#: src/skit/cli.py:228
#, python-format
msgid "%(num)s. %(name)s (%(type)s) = %(value)s%(secret)s"
msgstr "%(num)s. %(name)s(%(type)s)= %(value)s%(secret)s"

#: src/skit/cli.py:240
#, python-format
msgid "%(num)s. input() #%(ordinal)s: %(prompt)s%(secret)s"
msgstr "%(num)s. input() 第 %(ordinal)s 個:%(prompt)s%(secret)s"

#: src/skit/cli.py:245
msgid "⚠ looks like a loop accumulator — probably not a parameter"
msgstr "⚠ 看起來是迴圈的累加變數，多半不是參數"

#: src/skit/cli.py:255 src/skit/tui_add.py:332
msgid "This script reads command-line arguments; the run form has an extra-arguments field for them."
msgstr "這支腳本會吃命令列參數；執行表單裡有「額外參數」欄可以填。"

#: src/skit/cli.py:264
#, python-format
msgid "💡 %(names)s are written directly inside the code, so skit can't turn them into form fields. To manage one, first give it a name at the top of the script, e.g. OUTPUT = '…' (skit edit %(script)s)."
msgstr "💡 %(names)s 直接寫在程式碼裡，skit 沒辦法把它們變成表單欄位。想管理其中一個，先在腳本開頭給它取個名字，例如 OUTPUT = '…'（skit edit %(script)s）。"

#: src/skit/cli.py:286 src/skit/tui_add.py:286
#, python-format
msgid "✓ skit read this script's own arguments (%(count)s fields). Running it opens a form — nothing to memorize."
msgstr "✓ skit 看懂了這支腳本自己的參數（共 %(count)s 項）。執行時會開表單——不用背任何指令。"

#: src/skit/cli.py:294 src/skit/tui_add.py:294
#, python-format
msgid "This script parses its own arguments (%(names)s); skit couldn't model them statically, so the run form offers a passthrough-arguments field."
msgstr "這支腳本自己解析參數（%(names)s）；skit 無法靜態讀懂它們，執行表單會提供「額外參數（原樣傳給腳本）」欄。"

#: src/skit/cli.py:305
#, python-format
msgid "Found %(count)s parameter candidate (constants / input() calls):"
msgid_plural "Found %(count)s parameter candidates (constants / input() calls):"
msgstr[0] "找到 %(count)s 個候選參數(寫死的常數 / input() 呼叫):"

#: src/skit/cli.py:314
msgid "Which ones should skit manage? (e.g. 1,3 / all / none)"
msgstr "哪些交給 skit 管理?(編號如 1,3 / all / none)"

#: src/skit/cli.py:354
msgid "Reference mode never touches the original file, so parameter setup was skipped."
msgstr "reference 模式絕不改動原檔;略過參數設定。"

#: src/skit/cli.py:375
msgid "Writing a new script in an editor needs an interactive terminal."
msgstr "用編輯器新建腳本需要互動式終端機。"

#: src/skit/cli.py:381 src/skit/store.py:454 src/skit/tui_add.py:125
msgid "A name is required."
msgstr "必須提供名稱。"

#: src/skit/cli.py:388
msgid "Opening your editor…"
msgstr "正在開啟編輯器…"

#: src/skit/cli.py:392
msgid "Nothing was written, so no script was added."
msgstr "沒有寫入任何內容,因此沒有加入腳本。"

#: src/skit/cli.py:410
msgid "Reading the script from stdin needs an explicit --name."
msgstr "從 stdin 讀腳本必須用 --name 指定名稱。"

#: src/skit/cli.py:416
msgid "Nothing arrived on stdin, so there is nothing to add."
msgstr "stdin 沒有收到任何內容，沒有東西可加入。"

#: src/skit/cli.py:441
msgid "Add a script, executable, or command to skit."
msgstr "把腳本、可執行檔或命令加入 skit。"

#: src/skit/cli.py:443
#, python-brace-format
msgid "Examples:  skit add tools/resize.py  ·  skit add --cmd 'ffmpeg -i {input}' -n convert  ·  pbpaste | skit add - -n clip"
msgstr "例：skit add tools/resize.py · skit add --cmd 'ffmpeg -i {input}' -n convert · pbpaste | skit add - -n clip"

#: src/skit/cli.py:448
msgid "Path to a script or executable, or '-' to read a script from stdin"
msgstr "腳本或可執行檔路徑；「-」表示從 stdin 讀腳本"

#: src/skit/cli.py:451
msgid "Name / alias (defaults to the file name)"
msgstr "名稱 / alias(預設用檔名)"

#: src/skit/cli.py:457
msgid "Description (defaults to the first line of the docstring)"
msgstr "描述(預設抓 docstring 首行)"

#: src/skit/cli.py:460
msgid "Write a brand-new script in your editor, then add it"
msgstr "在編輯器裡新寫一支腳本,再加入 skit"

#: src/skit/cli.py:465
msgid "Reference mode: link to the original file instead of copying it"
msgstr "reference 模式:不複製,連結原檔"

#: src/skit/cli.py:470
msgid "Force the executable kind (normally inferred from the file itself)"
msgstr "強制當作可執行檔（一般會自動判斷）"

#: src/skit/cli.py:473
#, python-brace-format
msgid "Register a command template, e.g. --cmd 'ffmpeg -i {input}'"
msgstr "登記命令模板,如 --cmd 'ffmpeg -i {input}'"

#: src/skit/cli.py:478
msgid "A dependency (repeat for more; skips the interactive question)"
msgstr "一項依賴（可重複；會跳過互動詢問）"

#: src/skit/cli.py:481 src/skit/cli.py:1335
msgid "Python version constraint, e.g. \">=3.11\""
msgstr "Python 版本約束,如 \">=3.11\""

#: src/skit/cli.py:484
msgid "Never prompt; accept the detected suggestions"
msgstr "永不詢問;直接採用偵測到的建議"

#: src/skit/cli.py:491
msgid "Use --edit to write a new script, or pass a path to add an existing one — not both."
msgstr "用 --edit 新寫腳本,或傳入路徑加入現有檔案,兩者不能同時使用。"

#: src/skit/cli.py:505
msgid "A --cmd entry needs a --name"
msgstr "--cmd 條目必須指定 --name"

#: src/skit/cli.py:511
#, python-format
msgid "Detected parameters: %(names)s (the run form asks for them; your last values are remembered)"
msgstr "偵測到參數：%(names)s（執行表單會詢問；會記住你上次的值）"

#: src/skit/cli.py:518
msgid "Provide a script path, or use --cmd to register a command template"
msgstr "請提供腳本路徑,或用 --cmd 登記命令模板"

#: src/skit/cli.py:527 src/skit/tui_add.py:95
#, python-format
msgid "%(file)s isn't a .py file or an executable — pass --exe for a program, or --cmd for a command template."
msgstr "%(file)s 不是 .py 檔也不是可執行檔——程式請加 --exe，命令模板請用 --cmd。"

#: src/skit/cli.py:536
#, python-format
msgid "Can't read %(path)s: %(error)s"
msgstr "無法讀取 %(path)s:%(error)s"

#: src/skit/cli.py:559
msgid "Cancelled — nothing was added."
msgstr "已取消——沒有加入任何東西。"

#: src/skit/cli.py:583
#, python-format
msgid "(%(mode)s mode)"
msgstr "(%(mode)s 模式)"

#: src/skit/cli.py:588
#, python-format
msgid "Added: %(name)s"
msgstr "已加入:%(name)s"

#: src/skit/cli.py:592
#, python-format
msgid "Description: %(desc)s"
msgstr "描述:%(desc)s"

#: src/skit/cli.py:596
#, python-format
msgid "Dependencies: %(deps)s"
msgstr "依賴:%(deps)s"

#: src/skit/cli.py:600
#, python-format
msgid "Managed parameters: %(names)s"
msgstr "管理中的參數:%(names)s"

#: src/skit/cli.py:602
#, python-format
msgid "Run it: skit run %(name)s"
msgstr "執行:skit run %(name)s"

#: src/skit/cli.py:605
#, python-format
msgid "Secret parameter values are never saved to disk: %(names)s"
msgstr "機密參數的值不會寫入磁碟:%(names)s"

#: src/skit/cli.py:614
msgid "List every registered script."
msgstr "列出所有已登記的腳本。"

#: src/skit/cli.py:616 src/skit/cli.py:987 src/skit/cli.py:1337
#: src/skit/cli.py:1414 src/skit/cli.py:1553
msgid "Output as JSON"
msgstr "以 JSON 輸出"

#: src/skit/cli.py:639
msgid "No scripts yet. Add one with: skit add <path>"
msgstr "還沒有任何腳本。用 skit add <path> 加一個。"

#: src/skit/cli.py:644 src/skit/tui.py:292 src/skit/tui.py:828
#: src/skit/tui_add.py:208
msgid "Name"
msgstr "名稱"

#: src/skit/cli.py:645 src/skit/cli.py:1102 src/skit/tui.py:292
#: src/skit/tui.py:828
msgid "Kind"
msgstr "類型"

#: src/skit/cli.py:646 src/skit/tui_add.py:210
msgid "Description"
msgstr "說明"

#: src/skit/cli.py:661
msgid "Remove a registered script (the original file is left untouched)."
msgstr "移除一個已登記的腳本(原檔不受影響)。"

#: src/skit/cli.py:664
msgid "Skip confirmation"
msgstr "跳過確認"

#: src/skit/cli.py:673 src/skit/tui.py:121
#, python-format
msgid "Remove \"%(name)s\"?"
msgstr "移除「%(name)s」？"

#: src/skit/cli.py:675
#, python-format
msgid "Remove \"%(name)s\"? Your original file will not be deleted."
msgstr "移除「%(name)s」？你的原始檔不會被刪除。"

#: src/skit/cli.py:680
#, python-format
msgid "Removed: %(name)s"
msgstr "已移除:%(name)s"

#: src/skit/cli.py:687
#, python-format
msgid "No script named %(name)s."
msgstr "找不到名為 %(name)s 的腳本。"

#: src/skit/cli.py:691
#, python-format
msgid "No script named \"%(name)s\". Create it now?"
msgstr "找不到名為「%(name)s」的腳本。要現在建立嗎?"

#: src/skit/cli.py:700
msgid "Open a script's source in your editor (offers to create it if the name is new)."
msgstr "用編輯器開啟腳本原始碼(名稱不存在時可新建)。"

#: src/skit/cli.py:701
msgid "Example:  skit edit resize"
msgstr "例：skit edit resize"

#: src/skit/cli.py:712
#, python-format
msgid "%(name)s isn't a Python script, so it has no source to edit."
msgstr "%(name)s 不是 Python 腳本,沒有可編輯的原始碼。"

#: src/skit/cli.py:720
#, python-format
msgid "%(name)s: the referenced source file is gone: %(path)s"
msgstr "%(name)s:reference 原檔已消失:%(path)s"

#: src/skit/cli.py:725
#, python-format
msgid "Editing the original file (reference mode): %(path)s"
msgstr "正在編輯原始檔案(reference 模式):%(path)s"

#: src/skit/cli.py:732 src/skit/cli.py:1277
#, python-format
msgid "%(name)s has no stored copy to edit."
msgstr "%(name)s 沒有可編輯的副本。"

#: src/skit/cli.py:739
#, python-format
msgid "Saved %(name)s."
msgstr "已儲存 %(name)s。"

#: src/skit/cli.py:742
#, python-format
msgid "skit reconciles parameter drift at run time; review managed parameters with: skit params %(name)s"
msgstr "skit 會在執行時自動校對參數差異;可用 skit params %(name)s 檢視管理中的參數"

#: src/skit/cli.py:758 src/skit/cli.py:1029
#, python-format
msgid "Unknown preset \"%(preset)s\". Available: %(presets)s"
msgstr "沒有名為「%(preset)s」的參數組合。現有:%(presets)s"

#: src/skit/cli.py:792
#, python-format
msgid "Parameters for %(name)s (press Enter to keep the value shown):"
msgstr "%(name)s 的參數(按 Enter 沿用顯示的值):"

#: src/skit/cli.py:804
msgid "Run a registered script or command in the terminal."
msgstr "在終端機執行已登記的腳本或命令。"

#: src/skit/cli.py:806
msgid "Examples:  skit run stitch  ·  skit run stitch -p web -- extra.png  ·  skit run stitch --dry-run"
msgstr "例：skit run stitch · skit run stitch -p web -- extra.png · skit run stitch --dry-run"

#: src/skit/cli.py:812
msgid "Arguments passed through to the script (after --)"
msgstr "透傳給腳本的參數(接在 -- 之後)"

#: src/skit/cli.py:815
msgid "Never prompt; reuse last values and defaults"
msgstr "永不詢問;沿用上次的值 / 預設值"

#: src/skit/cli.py:821
msgid "Named preset of parameter values to prefill the form with"
msgstr "用哪個參數組合(preset)預填表單"

#: src/skit/cli.py:825
msgid "Save this run's values as a named preset"
msgstr "把這次的值存成參數組合"

#: src/skit/cli.py:828
msgid "Line-by-line prompts instead of the inline form"
msgstr "用逐行問答取代迷你表單"

#: src/skit/cli.py:834
msgid "Skip the parameter form and injection and run the script as-is (escape hatch)"
msgstr "跳過參數表單與注入,原樣執行腳本(逃生門)"

#: src/skit/cli.py:841
msgid "Print the exact command that would run (tokens and globs expanded), then exit"
msgstr "印出實際會執行的完整命令（token 與萬用字元已展開）後結束"

#: src/skit/cli.py:854
msgid "Raw mode: skipping the parameter form and injection."
msgstr "raw 模式:已跳過參數表單與注入。"

#: src/skit/cli.py:862
msgid "skit could not model this script's own arguments; pass them after -- instead."
msgstr "skit 無法讀懂這支腳本自己的參數宣告；請把參數放在 -- 之後直接傳入。"

#: src/skit/cli.py:886
#, python-format
msgid "Reusing your last arguments: %(args)s"
msgstr "沿用上次的參數:%(args)s"

#: src/skit/cli.py:900 src/skit/cli.py:980
#, python-format
msgid "Preset \"%(preset)s\" saved for %(name)s."
msgstr "已為 %(name)s 儲存參數組合「%(preset)s」。"

#: src/skit/cli.py:917
#, python-format
msgid "Script exited with code %(code)s"
msgstr "腳本以 exit code %(code)s 結束"

#: src/skit/cli.py:927
msgid "Manage named parameter presets for a script."
msgstr "管理腳本的參數組合(preset)。"

#: src/skit/cli.py:932
msgid "Save a set of parameter values as a named preset."
msgstr "把一組參數值儲存成參數組合(preset)。"

#: src/skit/cli.py:935 src/skit/cli.py:1014 src/skit/tui_form.py:232
msgid "Preset name"
msgstr "組合名稱"

#: src/skit/cli.py:939
msgid "Save the last run's values without asking (automation-friendly)"
msgstr "直接存上次執行的值，不再詢問（適合自動化）"

#: src/skit/cli.py:951
#, python-format
msgid "%(name)s has no form fields, so there's nothing to save."
msgstr "%(name)s 沒有表單欄位，沒有東西可存。"

#: src/skit/cli.py:961
#, python-format
msgid "%(name)s has no remembered values yet — run it once first."
msgstr "%(name)s 還沒有記住的值——先執行一次。"

#: src/skit/cli.py:974
#, python-format
msgid "Secret values are never stored in presets; skipped: %(names)s"
msgstr "機密值不會存入參數組合;已略過:%(names)s"

#: src/skit/cli.py:984
msgid "List a script's saved presets."
msgstr "列出腳本已儲存的參數組合(preset)。"

#: src/skit/cli.py:1001
#, python-format
msgid "No presets for %(name)s yet. Create one with: skit run %(name)s --save-preset <preset>"
msgstr "%(name)s 還沒有參數組合。建立一個：skit run %(name)s --save-preset <組合名>"

#: src/skit/cli.py:1011
msgid "Delete a named preset from a script."
msgstr "從腳本刪除一個參數組合(preset)。"

#: src/skit/cli.py:1023
#, python-format
msgid "Preset \"%(preset)s\" deleted from %(name)s."
msgstr "已從 %(name)s 刪除參數組合「%(preset)s」。"

#: src/skit/cli.py:1052 src/skit/cli.py:1053
msgid "yes"
msgstr "是"

#: src/skit/cli.py:1080
#, python-format
msgid "%(name)s has no managed parameters."
msgstr "%(name)s 沒有納管的參數。"

#: src/skit/cli.py:1083
msgid "Command template placeholders (the run form asks for them):"
msgstr "命令模板的佔位符（執行表單會詢問）："

#: src/skit/cli.py:1092
#, python-format
msgid "%(name)s has no managed parameters. Use --manage to bring a detected candidate under management."
msgstr "%(name)s 沒有納管的參數。用 --manage 把偵測到的候選納入管理。"

#: src/skit/cli.py:1101
msgid "Parameter"
msgstr "參數"

#: src/skit/cli.py:1103
msgid "Type"
msgstr "型別"

#: src/skit/cli.py:1104
msgid "Default"
msgstr "預設值"

#: src/skit/cli.py:1105
msgid "Secret"
msgstr "機密"

#: src/skit/cli.py:1106
msgid "Last value"
msgstr "上次的值"

#: src/skit/cli.py:1109 src/skit/cli.py:1113
msgid "•••"
msgstr "•••"

#: src/skit/cli.py:1128
#, python-format
msgid "Detected but not yet managed: %(names)s (use --manage to manage them)"
msgstr "偵測到但尚未納管：%(names)s（用 --manage 納管）"

#: src/skit/cli.py:1148
msgid "Show or edit a script's managed parameters."
msgstr "顯示或編輯腳本管理中的參數。"

#: src/skit/cli.py:1150
msgid "Examples:  skit params resize --manage WIDTH  ·  skit params api --secret KEY --env-source KEY=OPENAI_API_KEY"
msgstr "例：skit params resize --manage WIDTH · skit params api --secret KEY --env-source KEY=OPENAI_API_KEY"

#: src/skit/cli.py:1158
msgid "Prune definitions that no longer match the script and refresh changed types"
msgstr "修剪已對不上腳本的定義,並更新型別已變的項"

#: src/skit/cli.py:1163
msgid "Bring a currently detected candidate under management (repeatable)"
msgstr "把當前偵測到的候選納入管理(可重複)"

#: src/skit/cli.py:1166
msgid "Drop a managed parameter (repeatable)"
msgstr "移除一個受管理的參數(可重複)"

#: src/skit/cli.py:1169
msgid "Mark a managed parameter as secret (repeatable)"
msgstr "把某個受管參數標為機密(可重複)"

#: src/skit/cli.py:1174
msgid "Remove the secret mark from a managed parameter (repeatable)"
msgstr "取消某個受管參數的機密標記(可重複)"

#: src/skit/cli.py:1177
msgid "Set a parameter's form prompt, as NAME=text (repeatable)"
msgstr "以 NAME=text 設定參數的表單提示(可重複)"

#: src/skit/cli.py:1183
msgid "Read a secret parameter from an environment variable at run time, as NAME=ENVVAR (empty ENVVAR clears it; repeatable)"
msgstr "執行時從環境變數讀取機密參數，格式 NAME=ENVVAR（ENVVAR 留空表示清除；可重複）"

#: src/skit/cli.py:1186
msgid "Output the read view as JSON"
msgstr "讀取檢視以 JSON 輸出"

#: src/skit/cli.py:1231
#, python-format
msgid "%(name)s isn't a managed parameter; --env-source skipped."
msgstr "%(name)s 不是納管的參數；--env-source 已略過。"

#: src/skit/cli.py:1238
#, python-format
msgid "%(name)s isn't secret; --env-source only applies to secret parameters (mark it with --secret first)."
msgstr "%(name)s 不是機密參數；--env-source 只適用於機密參數（先用 --secret 標記）。"

