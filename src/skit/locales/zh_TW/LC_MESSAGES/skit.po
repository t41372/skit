msgstr "名稱"

#: src/skit/cli.py:808 src/skit/cli.py:1619 src/skit/tui.py:367
#: src/skit/tui.py:915
msgid "Kind"
msgstr "類型"

#: src/skit/cli.py:809 src/skit/tui_add.py:261
msgid "Description"
msgstr "說明"

#: src/skit/cli.py:834 src/skit/cli.py:835 src/skit/cli.py:946
#: src/skit/cli.py:1468 src/skit/cli.py:1469
msgid "yes"
msgstr "是"

#: src/skit/cli.py:881
#, python-format
msgid "Source: %(path)s"
msgstr "來源:%(path)s"

#: src/skit/cli.py:884
#, python-format
msgid "Working directory: %(dir)s"
msgstr "工作目錄:%(dir)s"

#: src/skit/cli.py:895 src/skit/cli.py:2190
#, python-format
msgid "Python constraint: %(python)s"
msgstr "Python 版本約束:%(python)s"

#: src/skit/cli.py:899
#, python-format
msgid "Needs: %(needs)s"
msgstr "所需命令：%(needs)s"

#: src/skit/cli.py:903
#, python-format
msgid "Command template: %(template)s"
msgstr "命令模板:%(template)s"

#: src/skit/cli.py:908 src/skit/cli.py:1260
msgid "skit could not model this script's own arguments; pass them after -- instead."
msgstr "skit 無法讀懂這支腳本自己的參數宣告；請把參數放在 -- 之後直接傳入。"

#: src/skit/cli.py:914
msgid "No form fields — arguments after -- pass straight through to the script."
msgstr "沒有表單欄位——接在 -- 之後的參數會透傳給腳本。"

#: src/skit/cli.py:918
#, python-format
msgid "Presets: %(names)s"
msgstr "參數組合:%(names)s"

#: src/skit/cli.py:927 src/skit/cli.py:1507 src/skit/cli.py:1618
msgid "Parameter"
msgstr "參數"

#: src/skit/cli.py:928 src/skit/cli.py:1509 src/skit/cli.py:1620
msgid "Type"
msgstr "型別"

#: src/skit/cli.py:929
msgid "Required"
msgstr "必填"

#: src/skit/cli.py:930 src/skit/cli.py:1510 src/skit/cli.py:1621
msgid "Default"
msgstr "預設值"

#: src/skit/cli.py:931
msgid "Choices"
msgstr "可選值"

#: src/skit/cli.py:932 src/skit/cli.py:1511 src/skit/cli.py:1622
msgid "Secret"
msgstr "機密"

#: src/skit/cli.py:933 src/skit/tui.py:337 src/skit/tui.py:473
msgid "Help"
msgstr "說明"

#: src/skit/cli.py:938 src/skit/cli.py:1475 src/skit/cli.py:1483
#: src/skit/cli.py:1493 src/skit/cli.py:1626 src/skit/cli.py:1630
msgid "•••"
msgstr "•••"

#: src/skit/cli.py:956
msgid "Show everything about one script: metadata, dependencies, parameters, presets."
msgstr "顯示一支腳本的完整資訊:中繼資料、依賴、參數、參數組合。"

#: src/skit/cli.py:957
msgid "Examples:  skit show resize  ·  skit show resize --json"
msgstr "例:skit show resize · skit show resize --json"

#: src/skit/cli.py:1001
msgid "Remove a registered script (the original file is left untouched)."
msgstr "移除一個已登記的腳本(原檔不受影響)。"

#: src/skit/cli.py:1004
msgid "Skip confirmation"
msgstr "跳過確認"

#: src/skit/cli.py:1014 src/skit/tui.py:151
#, python-format
msgid "Remove \"%(name)s\"?"
msgstr "移除「%(name)s」？"

#: src/skit/cli.py:1016
#, python-format
msgid "Remove \"%(name)s\"? Your original file will not be deleted."
msgstr "移除「%(name)s」？你的原始檔不會被刪除。"

#: src/skit/cli.py:1021
#, python-format
msgid "Removed: %(name)s"
msgstr "已移除:%(name)s"

#: src/skit/cli.py:1028
#, python-format
msgid "No script named %(name)s."
msgstr "找不到名為 %(name)s 的腳本。"

#: src/skit/cli.py:1032
#, python-format
msgid "No script named \"%(name)s\". Create it now?"
msgstr "找不到名為「%(name)s」的腳本。要現在建立嗎?"

#: src/skit/cli.py:1041
msgid "Open a script's source in your editor (offers to create it if the name is new)."
msgstr "用編輯器開啟腳本原始碼(名稱不存在時可新建)。"

#: src/skit/cli.py:1042
msgid "Example:  skit edit resize"
msgstr "例：skit edit resize"

#: src/skit/cli.py:1054 src/skit/tui.py:793
#, python-format
msgid "%(name)s has no editable source (programs and command templates run as-is)."
msgstr "%(name)s 沒有可編輯的原始碼（程式與命令模板按原樣執行）。"

#: src/skit/cli.py:1062
#, python-format
msgid "%(name)s: the referenced source file is gone: %(path)s"
msgstr "%(name)s:reference 原檔已消失:%(path)s"

#: src/skit/cli.py:1067
#, python-format
msgid "Editing the original file (reference mode): %(path)s"
msgstr "正在編輯原始檔案(reference 模式):%(path)s"

#: src/skit/cli.py:1074 src/skit/cli.py:1923 src/skit/cli.py:2029
#, python-format
msgid "%(name)s has no stored copy to edit."
msgstr "%(name)s 沒有可編輯的副本。"

#: src/skit/cli.py:1081
#, python-format
msgid "Saved %(name)s."
msgstr "已儲存 %(name)s。"

#: src/skit/cli.py:1084
#, python-format
msgid "skit reconciles parameter drift at run time; review managed parameters with: skit params %(name)s"
msgstr "skit 會在執行時自動校對參數差異;可用 skit params %(name)s 檢視管理中的參數"

#: src/skit/cli.py:1100 src/skit/cli.py:1445
#, python-format
msgid "Unknown preset \"%(preset)s\". Available: %(presets)s"
msgstr "沒有名為「%(preset)s」的參數組合。現有:%(presets)s"

#: src/skit/cli.py:1130
#, python-format
msgid "Malformed --set (expected NAME=VALUE): %(items)s"
msgstr "--set 格式錯誤(應為 NAME=VALUE):%(items)s"

#: src/skit/cli.py:1140
#, python-format
msgid "Unknown parameter for --set: %(names)s. This script's parameters: %(valid)s"
msgstr "--set 指到不存在的參數:%(names)s。這支腳本的參數:%(valid)s"

#: src/skit/cli.py:1174
#, python-format
msgid "Parameters for %(name)s (press Enter to keep the value shown):"
msgstr "%(name)s 的參數(按 Enter 沿用顯示的值):"

#: src/skit/cli.py:1186
msgid "Run a registered script or command in the terminal."
msgstr "在終端機執行已登記的腳本或命令。"

#: src/skit/cli.py:1188
msgid "Examples:  skit run stitch  ·  skit run stitch -p web -- extra.png  ·  skit run stitch --set width=800 --no-input  ·  skit run stitch --dry-run"
msgstr "例:skit run stitch · skit run stitch -p web -- extra.png · skit run stitch --set width=800 --no-input · skit run stitch --dry-run"

#: src/skit/cli.py:1194
msgid "Arguments passed through to the script (after --)"
msgstr "透傳給腳本的參數(接在 -- 之後)"

#: src/skit/cli.py:1197
msgid "Never prompt; reuse last values and defaults"
msgstr "永不詢問;沿用上次的值 / 預設值"

#: src/skit/cli.py:1203
msgid "Named preset of parameter values to prefill the form with"
msgstr "用哪個參數組合(preset)預填表單"

#: src/skit/cli.py:1210
#, python-brace-format
msgid "Set a parameter value by name, as NAME=VALUE (repeatable; values may use tokens like {cwd} or {env:VAR}; the form no longer asks for a field you set)"
msgstr "直接以 NAME=VALUE 指定參數值(可重複;值可用 {cwd}、{env:VAR} 等代換符;已指定的欄位表單不再詢問)"

#: src/skit/cli.py:1214
msgid "Save this run's values as a named preset"
msgstr "把這次的值存成參數組合"

#: src/skit/cli.py:1217
msgid "Line-by-line prompts instead of the inline form"
msgstr "用逐行問答取代迷你表單"

#: src/skit/cli.py:1223
msgid "Skip the parameter form and injection and run the script as-is (escape hatch)"
msgstr "跳過參數表單與注入,原樣執行腳本(逃生門)"

#: src/skit/cli.py:1230
msgid "Print the exact command that would run (tokens and globs expanded), then exit"
msgstr "印出實際會執行的完整命令（token 與萬用字元已展開）後結束"

#: src/skit/cli.py:1246
msgid "--raw runs the script as-is; --set, --preset, and --save-preset do not apply."
msgstr "--raw 會原樣執行腳本;--set、--preset、--save-preset 都不適用。"

#: src/skit/cli.py:1252
msgid "Raw mode: skipping the parameter form and injection."
msgstr "raw 模式:已跳過參數表單與注入。"

#: src/skit/cli.py:1296
#, python-format
msgid "Reusing your last arguments: %(args)s"
msgstr "沿用上次的參數:%(args)s"

#: src/skit/cli.py:1310 src/skit/cli.py:1396
#, python-format
msgid "Preset \"%(preset)s\" saved for %(name)s."
msgstr "已為 %(name)s 儲存參數組合「%(preset)s」。"

#: src/skit/cli.py:1333
#, python-format
msgid "Script exited with code %(code)s"
msgstr "腳本以 exit code %(code)s 結束"

#: src/skit/cli.py:1343
msgid "Manage named parameter presets for a script."
msgstr "管理腳本的參數組合(preset)。"

#: src/skit/cli.py:1348
msgid "Save a set of parameter values as a named preset."
msgstr "把一組參數值儲存成參數組合(preset)。"

#: src/skit/cli.py:1351 src/skit/cli.py:1430 src/skit/tui_form.py:232
msgid "Preset name"
msgstr "組合名稱"

#: src/skit/cli.py:1355
msgid "Save the last run's values without asking (automation-friendly)"
msgstr "直接存上次執行的值，不再詢問（適合自動化）"

#: src/skit/cli.py:1367
#, python-format
msgid "%(name)s has no form fields, so there's nothing to save."
msgstr "%(name)s 沒有表單欄位，沒有東西可存。"

#: src/skit/cli.py:1377
#, python-format
msgid "%(name)s has no remembered values yet — run it once first."
msgstr "%(name)s 還沒有記住的值——先執行一次。"

#: src/skit/cli.py:1390
#, python-format
msgid "Secret values are never stored in presets; skipped: %(names)s"
msgstr "機密值不會存入參數組合;已略過:%(names)s"

#: src/skit/cli.py:1400
msgid "List a script's saved presets."
msgstr "列出腳本已儲存的參數組合(preset)。"

#: src/skit/cli.py:1417
#, python-format
msgid "No presets for %(name)s yet. Create one with: skit run %(name)s --save-preset <preset>"
msgstr "%(name)s 還沒有參數組合。建立一個：skit run %(name)s --save-preset <組合名>"

#: src/skit/cli.py:1427
msgid "Delete a named preset from a script."
msgstr "從腳本刪除一個參數組合(preset)。"

#: src/skit/cli.py:1439
#, python-format
msgid "Preset \"%(preset)s\" deleted from %(name)s."
msgstr "已從 %(name)s 刪除參數組合「%(preset)s」。"

#: src/skit/cli.py:1494
#, python-format
msgid "default %(value)s"
msgstr "預設 %(value)s"

#: src/skit/cli.py:1496
msgid "optional"
msgstr "選填"

#: src/skit/cli.py:1498
msgid "secret"
msgstr "機密"

#: src/skit/cli.py:1508
msgid "Delivery"
msgstr "傳遞方式"

#: src/skit/cli.py:1512 src/skit/cli.py:1623
msgid "Last value"
msgstr "上次的值"

#: src/skit/cli.py:1535 src/skit/cli.py:1603
#, python-format
msgid "%(name)s has no managed parameters."
msgstr "%(name)s 沒有納管的參數。"

#: src/skit/cli.py:1539
msgid "Command template placeholders (the run form asks for them):"
msgstr "命令模板的佔位符（執行表單會詢問）："

#: src/skit/cli.py:1545
msgid "Declared environment variables (set on the run):"
msgstr "宣告的環境變數（執行時設定）："

#: src/skit/cli.py:1609
#, python-format
msgid "%(name)s has no managed parameters. Use --manage to bring a detected candidate under management."
msgstr "%(name)s 沒有納管的參數。用 --manage 把偵測到的候選納入管理。"

#: src/skit/cli.py:1645
#, python-format
msgid "Detected but not yet managed: %(names)s (use --manage to manage them)"
msgstr "偵測到但尚未納管：%(names)s（用 --manage 納管）"

#: src/skit/cli.py:1650
#, python-brace-format, python-format
msgid "This script locates itself ($0 / BASH_SOURCE). Injecting a constant runs it from a temporary copy, so it would see that copy path instead. `skit params %(name)s --normalize NAME` converts a constant into the ${NAME:-default} idiom, which is delivered through the environment and leaves the file untouched."
msgstr "這個腳本會定位自身（$0 / BASH_SOURCE）。注入常數會讓它從暫存副本執行，因此它看到的會是副本的路徑。`skit params %(name)s --normalize NAME` 可以把常數改寫成 ${NAME:-default} 慣用法——改用環境變數投遞，原檔案保持不動。"

#: src/skit/cli.py:1669
msgid "Show or edit a script's managed or declared parameters."
msgstr "檢視或編輯腳本的受管或宣告參數。"

#: src/skit/cli.py:1671
msgid "Examples:  skit params resize --manage WIDTH  ·  skit params conv --add size --type size=int --deliver size=flag --flag size=--size"
msgstr "例：skit params resize --manage WIDTH · skit params conv --add size --type size=int --deliver size=flag --flag size=--size"

#: src/skit/cli.py:1679
msgid "Prune definitions that no longer match the script and refresh changed types"
msgstr "修剪已對不上腳本的定義,並更新型別已變的項"

#: src/skit/cli.py:1684
msgid "Bring a currently detected candidate under management (repeatable)"
msgstr "把當前偵測到的候選納入管理(可重複)"

#: src/skit/cli.py:1687
msgid "Drop a managed parameter (repeatable)"
msgstr "移除一個受管理的參數(可重複)"

#: src/skit/cli.py:1692
msgid "Declare a new parameter on an exe/command entry, by name (repeatable)"
msgstr "為 exe/command 條目宣告一個新參數，依名稱指定(可重複)"

#: src/skit/cli.py:1695
msgid "Remove a declared parameter, by name (repeatable)"
msgstr "移除一個宣告的參數，依名稱指定(可重複)"

#: src/skit/cli.py:1700
msgid "Set a declared parameter's type, as NAME=str|int|float|bool|choice"
msgstr "設定宣告參數的類型，格式 NAME=str|int|float|bool|choice"

#: src/skit/cli.py:1703
msgid "Set a declared parameter's default, as NAME=VALUE"
msgstr "設定宣告參數的預設值，格式 NAME=VALUE"

#: src/skit/cli.py:1708
msgid "Set a declared parameter's choices, as NAME=a,b,c (comma separated)"
msgstr "設定宣告參數的可選值，格式 NAME=a,b,c(逗號分隔)"

#: src/skit/cli.py:1714
msgid "Set how a declared parameter reaches the program, as NAME=env|flag|placeholder"
msgstr "設定宣告參數如何傳遞給程式，格式 NAME=env|flag|placeholder"

#: src/skit/cli.py:1720
msgid "Set a declared flag parameter's option, as NAME=--out (empty = positional)"
msgstr "設定宣告的 flag 參數選項，格式 NAME=--out(留空為位置參數)"

#: src/skit/cli.py:1723
msgid "Mark a declared parameter as required (repeatable)"
msgstr "把某個宣告參數標為必填(可重複)"

#: src/skit/cli.py:1726
msgid "Mark a declared parameter as optional (repeatable)"
msgstr "把某個宣告參數標為選填(可重複)"

#: src/skit/cli.py:1729
msgid "Set a declared parameter's help text, as NAME=text"
msgstr "設定宣告參數的說明文字，格式 NAME=text"

#: src/skit/cli.py:1732
msgid "Mark a managed parameter as secret (repeatable)"
msgstr "把某個受管參數標為機密(可重複)"

#: src/skit/cli.py:1737
msgid "Remove the secret mark from a managed parameter (repeatable)"
msgstr "取消某個受管參數的機密標記(可重複)"

#: src/skit/cli.py:1740
msgid "Set a parameter's form prompt, as NAME=text (repeatable)"
msgstr "以 NAME=text 設定參數的表單提示(可重複)"

#: src/skit/cli.py:1746
msgid "Read a secret parameter from an environment variable at run time, as NAME=ENVVAR (empty ENVVAR clears it; repeatable)"
msgstr "執行時從環境變數讀取機密參數，格式 NAME=ENVVAR（ENVVAR 留空表示清除；可重複）"

#: src/skit/cli.py:1753
#, python-brace-format
msgid "Shell only: rewrite a constant into the ${NAME:-default} idiom in the stored copy, so its value is delivered as an environment variable instead of a rewritten temporary copy (repeatable)"
msgstr "僅限 Shell:把常數改寫成 ${NAME:-default} 寫法(改的是倉庫副本),之後它的值就用環境變數傳遞,不必再改寫臨時副本(可重複)"

#: src/skit/cli.py:1756
msgid "Output the read view as JSON"
msgstr "讀取檢視以 JSON 輸出"

#: src/skit/cli.py:1810
#, python-format
msgid "%(name)s manages its parameters from the script itself — use --manage / --unmanage, or edit the [tool.skit] block."
msgstr "%(name)s 由腳本自身管理參數——請使用 --manage / --unmanage，或直接編輯 [tool.skit] 區塊。"

#: src/skit/cli.py:1876
#, python-format
msgid "%(name)s isn't a managed parameter; --env-source skipped."
msgstr "%(name)s 不是納管的參數；--env-source 已略過。"

#: src/skit/cli.py:1883
#, python-format
msgid "%(name)s isn't secret; --env-source only applies to secret parameters (mark it with --secret first)."
msgstr "%(name)s 不是機密參數；--env-source 只適用於機密參數（先用 --secret 標記）。"

#: src/skit/cli.py:1908
#, python-format
msgid "%(name)s isn't a Python script; only Python entries have managed parameters."
msgstr "%(name)s 不是 Python 腳本;只有 Python 條目有受管理的參數。"

#: src/skit/cli.py:1915
#, python-format
msgid "%(name)s is in reference mode, and skit never writes the original file. Edit the [tool.skit] block in the source directly."
msgstr "%(name)s 是 reference 模式;skit 絕不寫原檔。請直接改原檔的 [tool.skit] 區塊。"

#: src/skit/cli.py:1928
#, python-format
msgid "Ignored a malformed value: %(item)s (expected NAME=text)."
msgstr "已忽略格式錯誤的值：%(item)s（應為 NAME=text）。"

#: src/skit/cli.py:1953 src/skit/cli.py:2148
#, python-format
msgid "Removed previously stored plaintext value(s) for now-secret parameter(s): %(names)s"
msgstr "已移除下列剛設為機密的參數先前以明文儲存的值:%(names)s"

#: src/skit/cli.py:1960
#, python-format
msgid "Updated %(name)s. Managed parameters: %(names)s"
msgstr "已更新 %(name)s。受管理的參數:%(names)s"

#: src/skit/cli.py:1971
#, python-format
msgid "%(name)s isn't a plain constant with a literal value, so there's nothing to normalize; skipped."
msgstr "%(name)s 不是帶字面值的普通常數,沒有可以正規化的東西;已略過。"

#: src/skit/cli.py:1974
#, python-format
msgid "%(name)s is assigned more than once at the top level; normalizing it would change which value wins. Skipped."
msgstr "%(name)s 在頂層被賦值多次;正規化會改變最終生效的值。已略過。"

#: src/skit/cli.py:1977
#, python-format
msgid "%(name)s is readonly, so the script could never take a value from the environment; skipped."
msgstr "%(name)s 是 readonly,腳本永遠不可能從環境變數取值;已略過。"

#: src/skit/cli.py:1979
#, python-format
msgid "%(name)s already reads from the environment; nothing to do."
msgstr "%(name)s 已經從環境變數讀取了;無需處理。"

#: src/skit/cli.py:1981
#, python-format
msgid "%(name)s's value contains a character that can't be moved into ${...:-...} safely (one of } \" ` $ \\ or a newline); skipped — it keeps being injected into a temporary copy."
msgstr "%(name)s 的值裡有無法安全放進 ${...:-...} 的字元(} \" ` $ \\ 或換行);已略過——它會繼續用臨時副本注入。"

#: src/skit/cli.py:1985
msgid "Could not parse the script (syntax error); nothing was normalized."
msgstr "無法解析腳本(語法錯誤);沒有做任何正規化。"

#: src/skit/cli.py:2013
#, python-brace-format, python-format
msgid "%(name)s has no --normalize: it is a shell idiom (VAR=value -> VAR=\"${VAR:-value}\")."
msgstr "%(name)s 沒有 --normalize:那是 shell 的寫法(VAR=value -> VAR=\"${VAR:-value}\")。"

#: src/skit/cli.py:2021
#, python-brace-format, python-format
msgid "%(name)s is in reference mode, and skit never writes the original file. Change the line to VAR=\"${VAR:-value}\" in the source directly."
msgstr "%(name)s 是 reference 模式;skit 絕不寫原檔案。請直接把原檔案裡那行改成 VAR=\"${VAR:-value}\"。"

#: src/skit/cli.py:2056
#, python-format
msgid "Normalized %(names)s in %(name)s: delivered as environment variables from now on (no temporary copy, and $0 stays your real file)."
msgstr "已正規化 %(name)s 中的 %(names)s:今後用環境變數傳值(不再寫臨時副本,$0 也仍指向你的真實檔案)。"

#: src/skit/cli.py:2066
#, python-format
msgid "%(name)s isn't a declared parameter; skipped."
msgstr "%(name)s 不是已宣告的參數，已跳過。"

#: src/skit/cli.py:2067
#, python-format
msgid "%(name)s is already declared; skipped."
msgstr "%(name)s 已經宣告過，已跳過。"

#: src/skit/cli.py:2068
#, python-format
msgid "%(name)s: that delivery isn't available for this kind; skipped."
msgstr "%(name)s：該傳遞方式不適用於此類型，已跳過。"

#: src/skit/cli.py:2070
#, python-format
msgid "%(name)s isn't a template placeholder, so it can't use placeholder delivery; skipped."
msgstr "%(name)s 不是模板佔位符，無法使用 placeholder 傳遞方式，已跳過。"

#: src/skit/cli.py:2073
#, python-format
msgid "%(name)s: unknown type; skipped (use str, int, float, bool, or choice)."
msgstr "%(name)s：未知類型，已跳過(可用 str、int、float、bool 或 choice)。"

#: src/skit/cli.py:2075
#, python-format
msgid "%(name)s: the default doesn't fit its type; skipped."
msgstr "%(name)s：預設值與其類型不符，已跳過。"

#: src/skit/cli.py:2077
#, python-format
msgid "%(name)s: a choice parameter needs choices; set --choices %(name)s=a,b,c."
msgstr "%(name)s：choice 參數需要可選值，請設定 --choices %(name)s=a,b,c。"

#: src/skit/cli.py:2119
#, python-format
msgid "Ignored a malformed value: %(item)s (expected NAME=VALUE)."
msgstr "已忽略格式錯誤的值：%(item)s（應為 NAME=VALUE）。"

#: src/skit/cli.py:2155
#, python-format
msgid "Updated %(name)s. Declared parameters: %(names)s"
msgstr "已更新 %(name)s。已宣告的參數:%(names)s"

#: src/skit/cli.py:2182
#, python-format
msgid "Dependencies of %(name)s: %(deps)s"
msgstr "%(name)s 的依賴:%(deps)s"

#: src/skit/cli.py:2194
#, python-format
msgid "External commands needed by %(name)s: %(needs)s"
msgstr "%(name)s 所需的外部命令：%(needs)s"

#: src/skit/cli.py:2200
msgid "View or update a script's dependencies, Python constraint, and needed commands."
msgstr "檢視或更新腳本的依賴、Python 版本限制，以及所需的外部命令。"

#: src/skit/cli.py:2202
msgid "Examples:  skit deps tool --dep \"requests>=2,<3\" --dep rich  ·  skit deps clip --need jq"
msgstr "範例：skit deps tool --dep \"requests>=2,<3\" --dep rich  ·  skit deps clip --need jq"

#: src/skit/cli.py:2208
msgid "A dependency (repeat for more; replaces the whole list)"
msgstr "一項依賴（可重複；整組取代原清單）"

#: src/skit/cli.py:2210
msgid "Remove every dependency"
msgstr "清空所有依賴"

#: src/skit/cli.py:2218
msgid "An external command the script needs on PATH (repeat; replaces the whole list)"
msgstr "腳本在 PATH 上所需的一個外部命令（可重複；整組取代原清單）"

#: src/skit/cli.py:2222
msgid "Remove every needed external command"
msgstr "清空所有所需的外部命令"

#: src/skit/cli.py:2242
#, python-format
msgid "%(name)s doesn't take package dependencies — only --need applies here."
msgstr "%(name)s 不接受套件依賴——這裡只能用 --need。"

#: src/skit/cli.py:2248
msgid "Use --dep to set the list or --clear to empty it — not both."
msgstr "--dep 用來設定清單、--clear 用來清空——兩者擇一。"

#: src/skit/cli.py:2253
msgid "Use --need to set the list or --clear-needs to empty it — not both."
msgstr "--need 用來設定清單、--clear-needs 用來清空——兩者擇一。"

#: src/skit/cli.py:2280
#, python-format
msgid "Dependencies of %(name)s updated: %(deps)s"
msgstr "%(name)s 的依賴已更新:%(deps)s"

#: src/skit/cli.py:2290
#, python-format
msgid "Needs of %(name)s updated: %(needs)s"
msgstr "%(name)s 所需的命令已更新：%(needs)s"

#: src/skit/cli.py:2303
msgid "Connect skit to AI agents: install the official Agent Skill."
msgstr "把 skit 接上 AI agent:安裝官方 Agent Skill。"

#: src/skit/cli.py:2318
#, python-format
msgid "Could not write the skill there: %(error)s"
msgstr "無法把 skill 寫到那裡:%(error)s"

#: src/skit/cli.py:2321
#, python-format
msgid "Installed the skit Agent Skill: %(path)s"
msgstr "已安裝 skit Agent Skill:%(path)s"

#: src/skit/cli.py:2327
msgid "user"
msgstr "使用者"

#: src/skit/cli.py:2327
msgid "project"
msgstr "專案"

#: src/skit/cli.py:2328
msgid "Agent directories on this machine:"
msgstr "這台機器上的 agent 目錄:"

#: src/skit/cli.py:2332
msgid "Install where?"
msgstr "要裝到哪裡?"

#: src/skit/cli.py:2339
#, python-format
msgid "Write the skill into %(path)s?"
msgstr "把 skill 寫入 %(path)s?"

#: src/skit/cli.py:2349
msgid "Install skit's Agent Skill into an AI agent's skills directory."
msgstr "把 skit 的 Agent Skill 安裝到 AI agent 的 skills 目錄。"

#: src/skit/cli.py:2351
msgid "Examples:  skit agent install  ·  skit agent install claude  ·  skit agent install codex --project  ·  skit agent install --to ~/.claude/skills"
msgstr "例:skit agent install · skit agent install claude · skit agent install codex --project · skit agent install --to ~/.claude/skills"

#: src/skit/cli.py:2358
msgid "Where to install: claude, codex, or agents (the cross-agent ./.agents directory)"
msgstr "安裝目標:claude、codex,或 agents(跨 agent 的 ./.agents 目錄)"

#: src/skit/cli.py:2364
msgid "Install into this skills directory instead of a named target"
msgstr "安裝到這個 skills 目錄,而不是具名目標"

#: src/skit/cli.py:2370
msgid "Install into the current project (./.claude, ./.codex) instead of your home directory"
msgstr "安裝到目前專案(./.claude、./.codex),而不是家目錄"

#: src/skit/cli.py:2379
msgid "Use a named target (with optional --project) or --to — not both."
msgstr "具名目標(可搭配 --project)和 --to 擇一使用,不能同時。"

#: src/skit/cli.py:2391
#, python-format
msgid "Unknown target %(name)s. Valid targets: claude, codex, agents."
msgstr "沒有 %(name)s 這個目標。可用目標:claude、codex、agents。"

#: src/skit/cli.py:2400
